---
import type { CollectionEntry } from 'astro:content';
import PlaceholderCover from '../../assets/blog-placeholder-about.jpg';
import {
	getBlogCategoryPath,
	type BlogCategory,
	type BlogCategoryCount,
} from '../../lib/blog';
import PaginationNav from '../PaginationNav.astro';
import FormattedDate from '../FormattedDate.astro';

interface Props {
	posts: CollectionEntry<'blog'>[];
	categoryCounts: BlogCategoryCount[];
	activeCategory?: BlogCategory;
	currentPage: number;
	totalPages: number;
	totalItems: number;
	basePath: string;
}

const { posts, categoryCounts, activeCategory, currentPage, totalPages, totalItems, basePath } = Astro.props;
const allPostCount = categoryCounts.reduce((total, item) => total + item.count, 0);

const getCoverImageAttrs = (coverImage: (typeof posts)[number]['data']['coverImage']) => {
	if (!coverImage) {
		return {
			src: PlaceholderCover.src,
			width: PlaceholderCover.width,
			height: PlaceholderCover.height,
		};
	}

	if (typeof coverImage === 'string') {
		return { src: coverImage };
	}

	return {
		src: coverImage.src,
		width: coverImage.width,
		height: coverImage.height,
	};
};

const postCards = posts.map((post) => ({
	post,
	coverImage: getCoverImageAttrs(post.data.coverImage),
}));
---

<main class="blog-page">
	<section class="blog-hero" aria-labelledby="blog-page-title">
		<p class="blog-kicker">Tech Blog</p>
		<h1 id="blog-page-title">{activeCategory ?? '技术博客'}</h1>
		<p class="blog-intro">
			共 {totalItems} 篇文章，当前第 {currentPage} / {totalPages} 页。类型筛选会检索全部文章。
		</p>
	</section>

	<div class="blog-shell">
		<section class="blog-list blog-list--posts" aria-label={activeCategory ? `${activeCategory}文章列表` : '全部文章列表'}>
			{
				postCards.map(({ post, coverImage }) => (
					<article class="surface-card blog-card blog-card--post">
						<a class="blog-card__link blog-card__link--compact" href={`/blog/${post.id}/`}>
							<img
								class="blog-card__image blog-card__image--compact"
								src={coverImage.src}
								width={coverImage.width}
								height={coverImage.height}
								alt=""
								loading="lazy"
								decoding="async"
							/>
							<div class="blog-card__content blog-card__content--compact">
								<div class="blog-card__main">
									<h2 title={post.data.title}>{post.data.title}</h2>
									<p class="blog-card__date blog-card__date--compact">
										<svg viewBox="0 0 24 24" aria-hidden="true">
											<path d="M7 3v3M17 3v3M4.5 9.5h15M5.5 5.5h13a1 1 0 0 1 1 1v12a1 1 0 0 1-1 1h-13a1 1 0 0 1-1-1v-12a1 1 0 0 1 1-1Z" />
										</svg>
										<FormattedDate date={post.data.pubDate} />
									</p>
								</div>
								<span class="blog-card__category blog-card__category--compact" title={post.data.category}>
									{post.data.category}
								</span>
							</div>
						</a>
					</article>
				))
			}
		</section>

		<aside class="blog-sidebar" aria-label="博客类型筛选">
			<nav class="blog-category-filter" aria-label="按类型筛选文章">
				<div class="blog-category-filter__heading">
					<strong>文章类型</strong>
					<span>筛选全部 {allPostCount} 篇内容</span>
				</div>
				<a class:list={['blog-category-filter__option', { active: !activeCategory }]} href="/blog/">
					<span>全部内容</span>
					<small>{allPostCount}</small>
				</a>
				{
					categoryCounts.filter(({ count }) => count > 0).map(({ category, count }) => (
						<a
							class:list={['blog-category-filter__option', { active: category === activeCategory }]}
							href={getBlogCategoryPath(category)}
						>
							<span>{category}</span>
							<small>{count}</small>
						</a>
					))
				}
			</nav>
		</aside>
	</div>

	<PaginationNav
		basePath={basePath}
		currentPage={currentPage}
		totalPages={totalPages}
		totalItems={totalItems}
		itemLabel="篇文章"
	/>
</main>
