---
import PaginationNav from '../PaginationNav.astro';
import type { InterviewNote } from '../../lib/interview-notes';
import { buildInterviewSearchText } from '../../lib/interview-notes';

interface Props {
	notes: InterviewNote[];
	currentPage: number;
	totalPages: number;
	totalItems: number;
	basePath: string;
	startIndex: number;
}

const { notes, currentPage, totalPages, totalItems, basePath, startIndex } = Astro.props;

const categoryCount = new Set(notes.map((note) => note.category)).size;
const totalAnswerPoints = notes.reduce((total, note) => total + note.answer.length, 0);

const noteCards = notes.map((note) => ({
	note,
	searchText: buildInterviewSearchText(note),
}));
---

<main class="interview-page" data-interview-page>
	<section class="surface-card interview-hero">
		<div class="interview-hero__copy">
			<p class="eyebrow">Interview Notes</p>
			<h1>把高频面试题和自己的回答整理成一份能长期增补的清单。</h1>
			<p>
				这里适合收纳常问题、回答思路和补充说明。后面新增内容时，直接编辑
				<code>src/data/interview-notes.json</code>，刷新页面就能看到更新。
			</p>
			<div class="interview-hero__actions">
				<a class="button" href="/about">返回更多</a>
				<a class="button secondary" href="/blog">查看博客</a>
			</div>
		</div>

		<div class="interview-hero__stats" aria-label="面经统计">
			<div class="interview-stat">
				<strong>{notes.length}</strong>
				<span>本页题目</span>
			</div>
			<div class="interview-stat">
				<strong>{categoryCount}</strong>
				<span>本页分类</span>
			</div>
			<div class="interview-stat">
				<strong>{totalAnswerPoints}</strong>
				<span>本页回答要点</span>
			</div>
		</div>
	</section>

	<div class="interview-shell">
		<aside class="surface-card interview-sidebar" aria-label="面经搜索">
			<section class="interview-sidebar__section">
				<label class="interview-search" for="interview-search-input">
					<span>搜索内容</span>
					<input id="interview-search-input" type="search" placeholder="搜索题目或回答..." data-interview-search />
				</label>
				<p class="interview-sidebar__hint">
					当前共 {totalItems} 道题，正在查看第 {currentPage} / {totalPages} 页。搜索只作用于当前页。
				</p>
			</section>

			<section class="interview-sidebar__section">
				<div class="interview-sidebar__title-row">
					<strong>筛选状态</strong>
					<span class="interview-sidebar__summary" data-interview-summary>全部题目</span>
				</div>
				<p class="interview-sidebar__status" data-interview-status>
					当前显示本页全部 {notes.length} 道题目。
				</p>
				<button type="button" class="interview-clear-button" data-interview-clear hidden>
					清空搜索
				</button>
			</section>

			<section class="interview-sidebar__section interview-sidebar__section--maintain">
				<strong>后续怎么加题？</strong>
				<p>
					直接在 <code>src/data/interview-notes.json</code> 里追加一个对象，写上题目、
					摘要、回答数组和分类，新内容就会自动出现在页面里。
				</p>
			</section>
		</aside>

		<section class="interview-list" aria-label="面经题目列表">
			{
				noteCards.map(({ note, searchText }, index) => (
					<article class="surface-card interview-card" data-interview-card data-search={searchText}>
						<div class="interview-card__header">
							<div class="interview-card__title-block">
								<span class="interview-card__index">
									Q{String(startIndex + index + 1).padStart(2, '0')}
								</span>
								<h2>{note.question}</h2>
							</div>
							<div class="interview-card__meta">
								<span class="interview-card__category">{note.category}</span>
								{
									note.updatedAt && (
										<span class="interview-card__updated">更新于 {note.updatedAt}</span>
									)
								}
							</div>
						</div>

						{
							note.summary && (
								<p class="interview-card__summary">{note.summary}</p>
							)
						}

						<div class="interview-card__answer">
							<p class="interview-card__answer-title">回答整理</p>
							<ul>
								{
									note.answer.map((answerItem) => (
										<li>{answerItem}</li>
									))
								}
							</ul>
						</div>
					</article>
				))
			}
		</section>
	</div>

	<PaginationNav
		basePath={basePath}
		currentPage={currentPage}
		totalPages={totalPages}
		totalItems={totalItems}
		itemLabel="道题目"
	/>

	<p class="surface-card interview-empty" data-interview-empty hidden>当前没有匹配的题目，试试换个关键词。</p>
</main>

<style>
	.interview-page {
		display: grid;
		gap: 1rem;
	}

	.interview-hero,
	.interview-sidebar,
	.interview-card,
	.interview-empty {
		padding: clamp(1.2rem, 2vw, 1.75rem);
	}

	.interview-hero {
		display: grid;
		grid-template-columns: minmax(0, 1.25fr) minmax(16rem, 0.75fr);
		gap: 1rem;
		align-items: stretch;
	}

	.interview-hero__copy {
		display: grid;
		gap: 0.95rem;
	}

	.interview-hero__copy h1 {
		margin-bottom: 0;
		font-size: clamp(2.2rem, 4vw, 3.8rem);
		text-wrap: balance;
	}

	.interview-hero__copy p:last-of-type {
		margin: 0;
		color: var(--color-subtext);
	}

	.interview-hero__actions {
		display: flex;
		flex-wrap: wrap;
		gap: 0.8rem;
		margin-top: 0.3rem;
	}

	.interview-hero__stats {
		display: grid;
		grid-template-columns: repeat(3, minmax(0, 1fr));
		gap: 0.8rem;
	}

	.interview-stat {
		display: grid;
		align-content: center;
		gap: 0.2rem;
		padding: 1rem;
		border: 1px solid rgba(153, 230, 255, 0.46);
		border-radius: 24px;
		background:
			radial-gradient(circle at top left, rgba(204, 255, 255, 0.52), transparent 42%),
			linear-gradient(135deg, rgba(255, 255, 255, 0.96), rgba(230, 250, 255, 0.84));
		box-shadow:
			0 18px 36px rgba(112, 159, 176, 0.08),
			inset 0 1px 0 rgba(255, 255, 255, 0.84);
	}

	.interview-stat strong {
		font-size: clamp(1.7rem, 3vw, 2.5rem);
		line-height: 1;
		color: var(--color-link-hover);
	}

	.interview-stat span {
		color: var(--color-subtext);
		font-size: 0.92rem;
		font-weight: 700;
	}

	.interview-shell {
		display: grid;
		grid-template-columns: minmax(17.5rem, 20rem) minmax(0, 1fr);
		gap: 1rem;
		align-items: start;
	}

	.interview-sidebar {
		position: sticky;
		top: 7rem;
		display: grid;
		gap: 1rem;
		background:
			radial-gradient(circle at top left, rgba(204, 255, 255, 0.32), transparent 36%),
			linear-gradient(180deg, rgba(255, 255, 255, 0.94), rgba(242, 253, 255, 0.84));
	}

	.interview-sidebar__section {
		display: grid;
		gap: 0.75rem;
	}

	.interview-sidebar__section + .interview-sidebar__section {
		padding-top: 0.95rem;
		border-top: 1px solid rgba(224, 242, 247, 0.92);
	}

	.interview-sidebar__title-row {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 0.8rem;
	}

	.interview-sidebar__title-row strong {
		font-size: 0.98rem;
	}

	.interview-sidebar__title-row span,
	.interview-sidebar__hint,
	.interview-sidebar__status,
	.interview-sidebar__section--maintain p {
		margin: 0;
		color: var(--color-subtext);
	}

	.interview-sidebar__summary {
		display: inline-flex;
		align-items: center;
		padding: 0.22rem 0.58rem;
		border-radius: 999px;
		background: rgba(153, 230, 255, 0.24);
		color: var(--color-link-hover);
		font-size: 0.82rem;
		font-weight: 700;
		line-height: 1.2;
	}

	.interview-search {
		display: grid;
		gap: 0.55rem;
	}

	.interview-search span,
	.interview-sidebar__section--maintain strong,
	.interview-card__answer-title {
		font-size: 0.96rem;
		font-weight: 700;
		color: #111827;
	}

	.interview-search input {
		width: 100%;
		padding: 0.85rem 0.95rem;
		border: 1px solid rgba(153, 230, 255, 0.52);
		border-radius: 18px;
		background: rgba(255, 255, 255, 0.92);
		color: var(--color-text);
		outline: none;
		box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.84);
		transition:
			border-color 180ms ease,
			box-shadow 180ms ease,
			background-color 180ms ease;
	}

	.interview-search input:focus {
		border-color: rgba(43, 114, 138, 0.48);
		box-shadow:
			0 0 0 4px rgba(153, 230, 255, 0.22),
			inset 0 1px 0 rgba(255, 255, 255, 0.84);
		background: #fff;
	}

	.interview-clear-button {
		justify-self: start;
		padding: 0.5rem 0.84rem;
		border: 1px solid var(--color-border);
		border-radius: 999px;
		background: rgba(255, 255, 255, 0.84);
		color: var(--color-text);
		cursor: pointer;
		font: inherit;
		font-size: 0.84rem;
		font-weight: 700;
		transition:
			transform 180ms ease,
			box-shadow 180ms ease,
			border-color 180ms ease,
			background-color 180ms ease;
	}

	.interview-clear-button:hover {
		transform: translateY(-1px);
		box-shadow: 0 12px 24px rgba(112, 159, 176, 0.1);
	}

	.interview-list {
		display: grid;
		gap: 1rem;
	}

	.interview-card {
		display: grid;
		gap: 0.95rem;
		background: rgba(255, 255, 255, 0.9);
		border-color: rgba(224, 242, 247, 0.96);
	}

	.interview-card.is-hidden {
		display: none;
	}

	.interview-card__header {
		display: flex;
		flex-wrap: wrap;
		align-items: flex-start;
		justify-content: space-between;
		gap: 0.9rem;
	}

	.interview-card__title-block {
		display: grid;
		gap: 0.55rem;
		flex: 1 1 28rem;
	}

	.interview-card__title-block h2 {
		margin: 0;
		font-size: clamp(1.42rem, 2vw, 1.92rem);
		line-height: 1.2;
		text-wrap: balance;
	}

	.interview-card__index {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: fit-content;
		padding: 0.32rem 0.62rem;
		border-radius: 999px;
		background: rgba(255, 244, 204, 0.82);
		color: #7a6212;
		font-size: 0.76rem;
		font-weight: 700;
		letter-spacing: 0.08em;
		text-transform: uppercase;
	}

	.interview-card__meta {
		display: flex;
		flex-wrap: wrap;
		align-items: center;
		justify-content: flex-end;
		gap: 0.55rem;
	}

	.interview-card__category,
	.interview-card__updated {
		display: inline-flex;
		align-items: center;
		padding: 0.36rem 0.72rem;
		border-radius: 999px;
		font-size: 0.82rem;
		font-weight: 700;
		line-height: 1.2;
	}

	.interview-card__category {
		background: rgba(153, 230, 255, 0.22);
		color: var(--color-link-hover);
	}

	.interview-card__updated {
		background: rgba(255, 255, 255, 0.84);
		border: 1px solid var(--color-border);
		color: var(--color-subtext);
	}

	.interview-card__summary {
		margin: 0;
		color: #334155;
		line-height: 1.72;
	}

	.interview-card__answer {
		display: grid;
		gap: 0.65rem;
		padding: 1rem;
		border: 1px solid rgba(224, 242, 247, 0.92);
		border-radius: 24px;
		background:
			radial-gradient(circle at top left, rgba(204, 255, 255, 0.32), transparent 42%),
			linear-gradient(180deg, rgba(255, 255, 255, 0.92), rgba(248, 254, 255, 0.92));
	}

	.interview-card__answer-title {
		margin: 0;
	}

	.interview-card__answer ul {
		display: grid;
		gap: 0.55rem;
		margin: 0;
		padding-left: 1.2rem;
	}

	.interview-card__answer li::marker {
		color: var(--color-link-hover);
		font-weight: 700;
	}

	.interview-empty {
		margin: 0;
		color: var(--color-subtext);
	}

	@media (max-width: 980px) {
		.interview-hero,
		.interview-shell {
			grid-template-columns: 1fr;
		}

		.interview-sidebar {
			position: static;
		}
	}

	@media (max-width: 720px) {
		.interview-hero__stats {
			grid-template-columns: 1fr;
		}

		.interview-card__meta {
			justify-content: flex-start;
		}

		.interview-card__answer {
			padding: 0.9rem;
		}
	}
</style>

<script>
	import '../../scripts/interview-notes-page';
</script>
