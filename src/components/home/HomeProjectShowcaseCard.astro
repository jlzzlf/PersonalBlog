---
import { projectShowcaseItems } from '../../data/home/projects';
---

<article class="surface-card panel project-showcase-card">
	<p class="eyebrow">Project Showcase</p>
	<h2>项目展示</h2>
	<div class:list={['project-showcase-grid', { 'is-single': projectShowcaseItems.length === 1 }]} aria-label="项目展示">
		{
			projectShowcaseItems.map((item) => (
				<a
					class:list={['project-showcase-tile', { 'is-more': item.isMore }]}
					href={item.href}
					aria-label={item.title}
				>
					<div class="project-showcase-tile__meta">
						<span>{item.meta}</span>
					</div>
					<div class="project-showcase-tile__body">
						<strong>{item.title}</strong>
						<p>{item.description}</p>
					</div>
				</a>
			))
		}
	</div>
</article>
