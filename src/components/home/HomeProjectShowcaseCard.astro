---
import type { HomeProjectShowcaseItem } from '../../lib/projects';

interface Props {
	items: HomeProjectShowcaseItem[];
}

const { items } = Astro.props;
const realProjects = items.filter((item) => !item.isMore);
const mainProject = realProjects[0];
const moreProject = items.find((item) => item.isMore);
const sideProjects = realProjects.filter((item) => item !== mainProject);
---

<div class="project-showcase-grid" aria-label="项目展示">
	{
		mainProject && (
			<article class="home-card project-feature-card home-reveal" data-reveal-card>
				<div class="project-feature-card__meta">
					<span>{mainProject.meta}</span>
					<span class="project-feature-card__type">{mainProject.label}</span>
				</div>
				<div class="project-feature-card__body">
					<h3>{mainProject.title}</h3>
					<p>{mainProject.description}</p>
					{
						mainProject.keywords.length > 0 && (
							<div class="project-feature-card__keywords" aria-label="项目技术关键词">
								{mainProject.keywords.map((keyword) => <span>{keyword}</span>)}
							</div>
						)
					}
				</div>
				<div class="project-feature-card__actions">
					<a class="button button-primary" href={mainProject.href}>查看详情</a>
				</div>
			</article>
		)
	}

	<aside class="home-card project-more-card home-reveal" data-reveal-card style="--reveal-delay: 100ms">
		<div class="project-more-card__header">
			<span class="project-more-card__icon" aria-hidden="true">All</span>
			<div>
				<p class="section-kicker">Projects</p>
				<h3>更多项目</h3>
			</div>
		</div>
		<div class="project-more-card__list">
			{
				sideProjects.length > 0 ? (
					sideProjects.map((item) => (
						<a class="project-more-card__item" href={item.href}>
							<span aria-hidden="true">•</span>
							<strong>{item.title}</strong>
						</a>
					))
				) : (
					<p class="project-more-card__empty">目前只有这个项目，新增 MDX 项目后会自动出现在这里。</p>
				)
			}
		</div>
		<a class="project-more-card__button" href={moreProject?.href ?? '/projects/'}>查看全部项目<span aria-hidden="true">→</span></a>
	</aside>
</div>
