---
import { profileActionButtons, profileContacts, profileContent } from '../../data/home/profile';
---

<article class="profile-card home-reveal" data-reveal-card>
	<div class="profile-copy">
		<div class="profile-heading">
			<p class="profile-kicker">{profileContent.lead}</p>
			<h1 class="profile-name">{profileContent.name}</h1>
			<p class="profile-role">{profileContent.role}</p>
		</div>
		<div class="profile-intro" aria-label="个人介绍">
			{profileContent.introLines.map((line) => <p>{line}</p>)}
		</div>
		<div class="profile-tags" aria-label="个人关注方向">
			{profileContent.tags.map((tag) => <span>{tag}</span>)}
		</div>
	</div>

	<div class="profile-contacts" aria-label="联系方式">
		{
			profileContacts.map((item) => (
				<p class="profile-contact">
					<span>{item.label}</span>
					<button
						class="profile-contact__copy"
						type="button"
						data-copy-text={item.value}
						data-copy-label={item.label}
						aria-label={`复制${item.label}：${item.value}`}
						title={`点击复制${item.label}`}
					>
						{item.value}
					</button>
				</p>
			))
		}
	</div>

	<div class="profile-actions" aria-label="个人主页与外部入口">
		{
			profileActionButtons.map((item) => (
				item.href ? (
					<a
						class="profile-action"
						href={item.href}
						target="_blank"
						rel="noreferrer"
						aria-label={item.label}
						title={item.label}
					>
						<img
							src={item.imageSrc}
							alt={item.alt}
							class:list={['profile-action-image', item.iconClass]}
						/>
					</a>
				) : (
					<button
						class="profile-action"
						type="button"
						aria-label={item.label}
						title={item.label}
					>
						<img
							src={item.imageSrc}
							alt={item.alt}
							class:list={['profile-action-image', item.iconClass]}
						/>
					</button>
				)
			))
		}
	</div>
</article>
