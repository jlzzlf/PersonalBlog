---
import type { HomeProjectLogItem } from '../../lib/project-logs';

interface Props {
	items: HomeProjectLogItem[];
}

const { items } = Astro.props;
const latestLog = items[0];
const earlierLogs = items.slice(1);
---

<div class="project-showcase-grid" aria-label="项目日志">
	{
		latestLog ? (
			<article class="home-card project-feature-card home-reveal" data-reveal-card>
				<div class="project-feature-card__meta">
					<span>{latestLog.pubDateLabel}</span>
					<span class="project-feature-card__type">{latestLog.project}</span>
				</div>
				<div class="project-feature-card__body">
					<h3>{latestLog.title}</h3>
					<p>{latestLog.description}</p>
				</div>
				<div class="project-feature-card__actions">
					<a class="button button-primary" href={latestLog.href}>查看日志</a>
				</div>
			</article>
		) : (
			<article class="home-card project-feature-card home-reveal" data-reveal-card>
				<div class="project-feature-card__body">
					<h3>还没有项目日志</h3>
					<p>后续开发记录会自动显示在这里。</p>
				</div>
			</article>
		)
	}

	<aside class="home-card project-more-card home-reveal" data-reveal-card style="--reveal-delay: 100ms">
		<div class="project-more-card__header">
			<span class="project-more-card__icon" aria-hidden="true">Log</span>
			<div>
				<p class="section-kicker">Development</p>
				<h3>近期项目日志</h3>
			</div>
		</div>
		<div class="project-more-card__list">
			{
				earlierLogs.length > 0 ? (
					earlierLogs.map((item) => (
						<a class="project-more-card__item" href={item.href}>
							<span aria-hidden="true">→</span>
							<strong>{item.title}</strong>
						</a>
					))
				) : (
					<p class="project-more-card__empty">更多开发记录会在这里按时间归档。</p>
				)
			}
		</div>
		<a class="project-more-card__button" href="/projects/">查看全部日志<span aria-hidden="true">→</span></a>
	</aside>
</div>
