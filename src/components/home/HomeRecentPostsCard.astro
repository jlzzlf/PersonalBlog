---
import { Image } from 'astro:assets';
import HomeAvatar from '../../assets/home-avatar.jpg';
import { profileContent } from '../../data/home/profile';
import type { HomeRecentPost } from '../../lib/homepage';

interface Props {
	posts: HomeRecentPost[];
}

const { posts } = Astro.props;
const heroPosts = posts.slice(0, 2);
---

<article class="home-card recent-card home-reveal" data-reveal-card>
	<div class="recent-card__avatar">
		<div class="recent-card__avatar-frame">
			<Image
				src={HomeAvatar}
				alt="头像"
				class="recent-card__avatar-image"
				width={160}
				loading="eager"
				decoding="async"
				quality={72}
			/>
		</div>
		<div>
			<p>{profileContent.note}</p>
			<span>{profileContent.role}</span>
		</div>
	</div>

	<div class="recent-card__header">
		<div>
			<p class="section-kicker">Recent Posts</p>
			<h2>最近内容</h2>
		</div>
		<a class="text-link" href="/blog/">查看全部<span aria-hidden="true">→</span></a>
	</div>

	<div class="recent-list">
		{
			heroPosts.map((post) => (
				<a class="recent-item" href={post.href}>
					<div class="recent-item__meta">
						<time datetime={post.dateTime}>{post.pubDateLabel}</time>
						<strong>{post.featured ? '最新归档' : '近期更新'}</strong>
					</div>
					<div class="recent-item__body">
						<strong>{post.title}</strong>
						<p>{post.description}</p>
					</div>
				</a>
			))
		}
	</div>
</article>
