---
import type { HomeRecentPost } from '../../lib/homepage';

interface Props {
	posts: HomeRecentPost[];
}

const { posts } = Astro.props;
const featuredPost = posts.find((post) => post.featured) ?? posts[0];
const regularPosts = featuredPost ? posts.filter((post) => post !== featuredPost) : [];
const visiblePosts = featuredPost ? [featuredPost, ...regularPosts] : [];
---

<div class="blog-showcase-grid" aria-label="博客文章">
	{
		visiblePosts.map((post, index) => (
			<article
				class:list={['home-card blog-entry-card home-reveal', { 'is-featured': post === featuredPost }]}
				data-reveal-card
				style={`--reveal-delay: ${(index + 1) * 80}ms`}
			>
				<div class="blog-card-meta">
					<time datetime={post.dateTime}>{post.pubDateLabel}</time>
				</div>
				<div class="blog-entry-card__copy">
					<h3>{post.title}</h3>
					<p>{post.description}</p>
				</div>
				<a class="blog-card-link" href={post.href}>阅读全文<span aria-hidden="true">→</span></a>
			</article>
		))
	}
</div>
