---
import { buildPaginatedPath, buildPaginationSequence } from '../lib/pagination';

interface Props {
	basePath: string;
	currentPage: number;
	totalPages: number;
	totalItems: number;
	itemLabel: string;
}

const { basePath, currentPage, totalPages, totalItems, itemLabel } = Astro.props;
const pageSequence = buildPaginationSequence(currentPage, totalPages);
const previousHref = currentPage > 1 ? buildPaginatedPath(basePath, currentPage - 1) : null;
const nextHref = currentPage < totalPages ? buildPaginatedPath(basePath, currentPage + 1) : null;
---

{
	totalPages > 1 && (
		<nav class="pagination-nav" aria-label="分页导航">
			<div class="pagination-nav__summary">
				<strong>共 {totalItems} {itemLabel}</strong>
				<span>第 {currentPage} / {totalPages} 页</span>
			</div>

			<div class="pagination-nav__controls">
				{
					previousHref ? (
						<a class="pagination-nav__button" href={previousHref}>
							上一页
						</a>
					) : (
						<span class="pagination-nav__button is-disabled" aria-disabled="true">
							上一页
						</span>
					)
				}

				<div class="pagination-nav__pages" aria-label="页码">
					{
						pageSequence.map((page, index) =>
							page === 'ellipsis' ? (
								<span class="pagination-nav__ellipsis" aria-hidden="true">
									…
								</span>
							) : (
								<a
									class:list={['pagination-nav__page', { 'is-current': page === currentPage }]}
									href={buildPaginatedPath(basePath, page)}
									aria-current={page === currentPage ? 'page' : undefined}
								>
									{page}
								</a>
							),
						)
					}
				</div>

				{
					nextHref ? (
						<a class="pagination-nav__button" href={nextHref}>
							下一页
						</a>
					) : (
						<span class="pagination-nav__button is-disabled" aria-disabled="true">
							下一页
						</span>
					)
				}
			</div>
		</nav>
	)
}

<style>
	.pagination-nav {
		display: grid;
		gap: 0.9rem;
		padding: clamp(1rem, 1.7vw, 1.35rem);
		border: 1px solid var(--color-border);
		border-radius: 24px;
		background: linear-gradient(180deg, rgba(255, 255, 255, 0.92), rgba(242, 253, 255, 0.82));
		box-shadow: var(--shadow-soft);
	}

	.pagination-nav__summary {
		display: flex;
		flex-wrap: wrap;
		align-items: center;
		justify-content: space-between;
		gap: 0.6rem;
	}

	.pagination-nav__summary strong {
		font-size: 0.95rem;
	}

	.pagination-nav__summary span {
		color: var(--color-subtext);
		font-size: 0.9rem;
	}

	.pagination-nav__controls,
	.pagination-nav__pages {
		display: flex;
		flex-wrap: wrap;
		align-items: center;
		gap: 0.55rem;
	}

	.pagination-nav__controls {
		justify-content: space-between;
	}

	.pagination-nav__button,
	.pagination-nav__page,
	.pagination-nav__ellipsis {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		min-width: 2.8rem;
		min-height: 2.8rem;
		padding: 0.55rem 0.9rem;
		border-radius: 999px;
		font-size: 0.88rem;
		font-weight: 700;
		line-height: 1.2;
		text-decoration: none;
	}

	.pagination-nav__button,
	.pagination-nav__page {
		border: 1px solid var(--color-border);
		background: rgba(255, 255, 255, 0.84);
		color: var(--color-text);
		transition:
			transform 180ms ease,
			border-color 180ms ease,
			box-shadow 180ms ease,
			background-color 180ms ease,
			color 180ms ease;
	}

	.pagination-nav__button:hover,
	.pagination-nav__page:hover {
		transform: translateY(-1px);
		border-color: rgba(153, 230, 255, 0.82);
		background: rgba(230, 250, 255, 0.92);
		box-shadow: 0 12px 24px rgba(112, 159, 176, 0.1);
		color: var(--color-link-hover);
	}

	.pagination-nav__page.is-current {
		border-color: rgba(153, 230, 255, 0.82);
		background: linear-gradient(180deg, rgba(230, 250, 255, 0.98), rgba(204, 255, 255, 0.92));
		color: var(--color-link-hover);
		box-shadow: 0 10px 22px rgba(112, 159, 176, 0.12);
	}

	.pagination-nav__button.is-disabled {
		border: 1px solid rgba(224, 242, 247, 0.94);
		background: rgba(255, 255, 255, 0.6);
		color: var(--color-subtext);
	}

	.pagination-nav__ellipsis {
		min-width: auto;
		padding-inline: 0.1rem;
		color: var(--color-subtext);
	}

	@media (max-width: 720px) {
		.pagination-nav__summary,
		.pagination-nav__controls {
			justify-content: flex-start;
		}
	}
</style>
