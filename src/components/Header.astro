---
import { SITE_TITLE } from '../consts';

const pathname = Astro.url.pathname.replace(import.meta.env.BASE_URL, '');
const currentSection = pathname.match(/[^\/]+/g)?.[0];
const navItems = [
	{ href: '/', label: '首页' },
	{ href: '/projects', label: '项目' },
	{ href: '/blog', label: '博客' },
	{ href: '/about', label: '关于' },
];

const isActive = (href: string) => href === pathname || href === '/' + (currentSection || '');
---

<header class="site-header">
	<nav>
		<a class="brand" href="/">
			<span class="brand-mark">MB</span>
			<span class="brand-copy">
				<strong>{SITE_TITLE}</strong>
				<small>学习、项目与生活记录</small>
			</span>
		</a>
		<div class="internal-links" aria-label="主导航">
			{
				navItems.map((item) => (
					<a href={item.href} class:list={['nav-link', { active: isActive(item.href) }]}>
						{item.label}
					</a>
				))
			}
		</div>
	</nav>
</header>

<style>
	.site-header {
		position: sticky;
		top: 0;
		z-index: 20;
		padding: 1rem;
	}

	nav {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 1rem;
		width: min(1360px, calc(100% - 2rem));
		margin: 0 auto;
		padding: 0.85rem 1rem;
		border: 1px solid var(--line);
		border-radius: 999px;
		background: rgba(255, 251, 244, 0.82);
		backdrop-filter: blur(18px);
		box-shadow: 0 12px 32px rgba(45, 49, 43, 0.08);
	}

	.brand {
		display: inline-flex;
		align-items: center;
		gap: 0.85rem;
		color: rgb(var(--black));
		text-decoration: none;
	}

	.brand-mark {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: 2.75rem;
		height: 2.75rem;
		border-radius: 999px;
		background: linear-gradient(135deg, rgba(22, 88, 71, 0.14), rgba(201, 111, 74, 0.18));
		color: var(--accent-dark);
		font-size: 0.82rem;
		font-weight: 700;
		letter-spacing: 0.12em;
	}

	.brand-copy {
		display: flex;
		flex-direction: column;
	}

	.brand-copy strong {
		font-size: 1rem;
	}

	.brand-copy small {
		color: rgb(var(--gray));
		font-size: 0.76rem;
		letter-spacing: 0.08em;
		text-transform: uppercase;
	}

	.internal-links {
		display: flex;
		flex-wrap: wrap;
		align-items: center;
		gap: 0.35rem;
	}

	.nav-link {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		padding: 0.7rem 1rem;
		border-radius: 999px;
		color: rgb(var(--gray-dark));
		font-size: 0.95rem;
		font-weight: 600;
		text-decoration: none;
		transition:
			transform 180ms ease,
			background-color 180ms ease,
			color 180ms ease;
	}

	.nav-link:hover {
		transform: translateY(-1px);
		background: rgba(255, 255, 255, 0.72);
		color: var(--accent-dark);
	}

	.nav-link.active {
		background: rgba(22, 88, 71, 0.12);
		color: var(--accent-dark);
	}

	@media (max-width: 720px) {
		.site-header {
			padding: 0.9rem;
		}

		nav {
			padding: 1rem;
			border-radius: 28px;
			flex-direction: column;
			align-items: flex-start;
		}

		.internal-links {
			width: 100%;
		}

		.nav-link {
			flex: 1 1 auto;
		}
	}
</style>
