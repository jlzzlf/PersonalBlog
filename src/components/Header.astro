---
import { SITE_TITLE } from '../consts';

const pathname = Astro.url.pathname.replace(import.meta.env.BASE_URL, '');
const currentSection = pathname.match(/[^\/]+/g)?.[0];
const navItems = [
	{ href: '/', label: '首页' },
	{ href: '/projects', label: '项目' },
	{ href: '/blog', label: '博客' },
	{ href: '/about', label: '更多' },
];

const isActive = (href: string) => href === pathname || href === '/' + (currentSection || '');
---

<header class="site-header" data-site-header>
	<nav class="header-shell" aria-label="主导航">
		<a class="brand" href="/">
			<span class="brand-mark">MB</span>
			<span class="brand-copy">
				<strong>{SITE_TITLE}</strong>
				<small>学习、项目与生活记录</small>
			</span>
		</a>
		<div class="internal-links">
			{
				navItems.map((item) => (
					<a href={item.href} class:list={['nav-link', { active: isActive(item.href) }]}>
						{item.label}
					</a>
				))
			}
		</div>
		<button class="settings-button" type="button" aria-label="设置">
			<img src="/images/更多.png" alt="" class="settings-icon" />
		</button>
	</nav>
</header>

<style>
	.site-header {
		position: fixed;
		top: 0;
		right: 0;
		left: 0;
		z-index: 30;
		width: 100%;
		border-bottom: 1px solid transparent;
		background: transparent;
		box-shadow: none;
		transition:
			padding 500ms ease,
			border-color 500ms ease,
			background-color 500ms ease,
			box-shadow 500ms ease,
			backdrop-filter 500ms ease;
	}

	.site-header.is-home-scrolled {
		border-bottom-color: rgba(204, 255, 255, 0.5);
		background: rgba(255, 255, 255, 0.85);
		backdrop-filter: blur(30px);
		-webkit-backdrop-filter: blur(30px);
		box-shadow: 0 8px 32px rgba(102, 204, 204, 0.15);
	}

	.header-shell {
		display: grid;
		grid-template-columns: minmax(14rem, 1fr) auto;
		align-items: center;
		gap: 1rem;
		width: min(1360px, calc(100% - 2rem));
		margin: 0 auto;
		padding: 1.1rem 0;
		min-height: 4.6rem;
		transition: padding 500ms ease;
	}

	.site-header.is-home-scrolled .header-shell {
		padding-block: 0.72rem;
	}

	.brand {
		display: inline-flex;
		align-items: center;
		gap: 0.85rem;
		color: var(--color-text);
		text-decoration: none;
	}

	.brand-mark {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: 2.55rem;
		height: 2.55rem;
		border: 1px solid rgba(153, 230, 255, 0.4);
		border-radius: 0.85rem;
		background: linear-gradient(135deg, #ccffff, #66cccc);
		color: var(--color-link-hover);
		box-shadow: 0 4px 20px rgba(102, 204, 204, 0.25);
		font-size: 0.82rem;
		font-weight: 700;
		letter-spacing: 0.12em;
	}

	.brand-copy {
		display: flex;
		flex-direction: column;
	}

	.brand-copy strong {
		color: #f4ffff;
		font-size: 1rem;
		text-shadow:
			0 1px 10px rgba(15, 76, 92, 0.78),
			0 0 2px rgba(15, 76, 92, 0.72);
	}

	.brand-copy small {
		color: var(--color-subtext);
		font-size: 0.76rem;
		letter-spacing: 0.08em;
		text-transform: uppercase;
	}

	.internal-links {
		display: flex;
		flex-wrap: wrap;
		align-items: center;
		justify-content: center;
		gap: 0.5rem;
		min-width: 0;
		justify-self: center;
	}

	.nav-link {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		padding: 0.7rem 1rem;
		border: 1px solid transparent;
		border-radius: 999px;
		background: transparent;
		color: var(--color-text);
		font-size: 0.95rem;
		font-weight: 600;
		text-decoration: none;
		transition:
			transform 180ms ease,
			background-color 180ms ease,
			color 180ms ease,
			border-color 180ms ease,
			box-shadow 180ms ease;
	}

	.nav-link:hover {
		transform: translateY(-1px);
		background: rgba(230, 250, 255, 0.78);
		border-color: rgba(153, 230, 255, 0.56);
		box-shadow: 0 10px 20px rgba(112, 159, 176, 0.08);
		color: var(--color-link-hover);
	}

	.nav-link.active {
		background: var(--color-primary-soft);
		border-color: rgba(153, 230, 255, 0.7);
		color: var(--color-link-hover);
	}

	.settings-button {
		display: none;
		align-items: center;
		justify-content: center;
		width: 2.9rem;
		height: 2.9rem;
		padding: 0;
		border: 1px solid rgba(224, 242, 247, 0.95);
		border-radius: 999px;
		background: rgba(255, 255, 255, 0.72);
		color: var(--color-link-hover);
		cursor: pointer;
		justify-self: end;
		box-shadow: 0 10px 24px rgba(112, 159, 176, 0.08);
		transition:
			transform 180ms ease,
			background-color 180ms ease,
			border-color 180ms ease,
			box-shadow 180ms ease;
	}

	.settings-button:hover {
		transform: translateY(-1px);
		background: rgba(255, 244, 204, 0.78);
		border-color: rgba(255, 244, 204, 0.95);
		box-shadow: 0 14px 24px rgba(112, 159, 176, 0.12);
	}

	.settings-icon {
		display: block;
		width: 1.55rem;
		height: 1.55rem;
		object-fit: contain;
	}

	@media (max-width: 720px) {
		.header-shell {
			grid-template-columns: 1fr;
			grid-template-areas:
				'brand'
				'links';
			align-items: start;
			gap: 0.9rem;
			width: calc(100% - 1rem);
			padding: 0.9rem 0;
		}

		.brand {
			grid-area: brand;
		}

		.internal-links {
			grid-area: links;
			width: 100%;
			justify-content: flex-start;
			overflow-x: auto;
			padding-bottom: 0.15rem;
			scrollbar-width: none;
		}

		.nav-link {
			flex: 0 0 auto;
		}

		.internal-links::-webkit-scrollbar {
			display: none;
		}

		.settings-button {
			grid-area: settings;
			justify-self: end;
		}
	}
</style>

<script>
	const HEADER_STATE_KEY = '__joylifeSiteHeaderState';

	const mountSiteHeader = () => {
		const windowWithState = window as typeof window & Record<string, unknown>;
		const previousCleanup = windowWithState[HEADER_STATE_KEY];
		if (typeof previousCleanup === 'function') {
			previousCleanup();
		}

		const header = document.querySelector('[data-site-header]');
		if (!(header instanceof HTMLElement)) return;

		const syncHeaderState = () => {
			header.classList.toggle('is-home-scrolled', window.scrollY > 50);
		};

		syncHeaderState();
		window.addEventListener('scroll', syncHeaderState, { passive: true });

		windowWithState[HEADER_STATE_KEY] = () => {
			window.removeEventListener('scroll', syncHeaderState);
			header.classList.remove('is-home-scrolled');
		};
	};

	document.addEventListener('astro:page-load', mountSiteHeader);
	document.addEventListener('astro:before-swap', () => {
		const windowWithState = window as typeof window & Record<string, unknown>;
		const cleanup = windowWithState[HEADER_STATE_KEY];
		if (typeof cleanup === 'function') {
			cleanup();
			delete windowWithState[HEADER_STATE_KEY];
		}
	});
	window.addEventListener('pageshow', (event) => {
		if (event.persisted) {
			mountSiteHeader();
		}
	});

	mountSiteHeader();
</script>
