---
const PLAYER_PERSIST_NAME = 'site-music-player';
---

<aside
	class="floating-music-player"
	data-floating-music-player
	data-expanded="false"
	data-loading="false"
	data-playing="false"
	data-ready="false"
	transition:persist={PLAYER_PERSIST_NAME}
>
	<button
		class="floating-music-player__launcher"
		type="button"
		data-player-toggle
		aria-expanded="false"
		aria-label="打开音乐播放器"
	>
		<svg viewBox="0 0 24 24" aria-hidden="true">
			<path
				d="M15.5 3.5a1 1 0 0 1 1 1v9.52a3.75 3.75 0 1 1-1.5-3V8.18l-6 1.34v6.5a3.75 3.75 0 1 1-1.5-3V6.9a1 1 0 0 1 .78-.98l7-1.56a1 1 0 0 1 .22-.02Z"
				fill="currentColor"
			/>
		</svg>
	</button>

	<div class="floating-music-player__panel" data-player-panel aria-hidden="true" hidden>
		<audio data-player-audio preload="none" hidden></audio>

		<div class="floating-music-player__meta">
			<span class="floating-music-player__current" data-player-current>...</span>
			<input
				class="floating-music-player__volume-slider"
				data-player-volume
				type="range"
				min="0"
				max="100"
				step="1"
				value="15"
				aria-label="调整音量"
			/>
		</div>

		<div class="floating-music-player__controls">
			<button type="button" class="floating-music-player__control" data-player-previous aria-label="上一曲">
				<svg viewBox="0 0 24 24" aria-hidden="true">
					<path
						d="M6.75 5.25a.75.75 0 0 1 .75.75v12a.75.75 0 0 1-1.5 0V6a.75.75 0 0 1 .75-.75Zm11.01.3a.75.75 0 0 1 .04 1.06L12.4 12l5.4 5.39a.75.75 0 1 1-1.06 1.06l-5.92-5.92a.75.75 0 0 1 0-1.06l5.92-5.92a.75.75 0 0 1 1.06 0Z"
						fill="currentColor"
					/>
				</svg>
			</button>

			<button
				type="button"
				class="floating-music-player__control floating-music-player__control--primary"
				data-player-play
				aria-label="播放"
			>
				<svg viewBox="0 0 24 24" aria-hidden="true">
					<path d="M8.75 6.78c0-.83.92-1.33 1.62-.88l7.1 4.72a1.06 1.06 0 0 1 0 1.76l-7.1 4.72a1.06 1.06 0 0 1-1.62-.88V6.78Z" fill="currentColor" />
				</svg>
			</button>

			<button type="button" class="floating-music-player__control" data-player-next aria-label="下一曲">
				<svg viewBox="0 0 24 24" aria-hidden="true">
					<path
						d="M17.25 5.25a.75.75 0 0 1 .75.75v12a.75.75 0 0 1-1.5 0V6a.75.75 0 0 1 .75-.75Zm-11.01.3a.75.75 0 0 1 1.06 0l5.92 5.92a.75.75 0 0 1 0 1.06L7.3 18.45a.75.75 0 1 1-1.06-1.06L11.64 12l-5.4-5.39a.75.75 0 0 1 0-1.06Z"
						fill="currentColor"
					/>
				</svg>
			</button>
		</div>
	</div>
</aside>

<script>
	import '../scripts/floating-music-player.ts';
</script>

<style>
	.floating-music-player {
		position: fixed;
		right: 1rem;
		bottom: max(1rem, calc(env(safe-area-inset-bottom) + 0.4rem));
		z-index: 60;
	}

	.floating-music-player__launcher,
	.floating-music-player__control,
	.floating-music-player__volume-slider {
		border: 0;
		font: inherit;
	}

	.floating-music-player__launcher {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: 3.6rem;
		height: 3.6rem;
		border-radius: 999px;
		background: linear-gradient(180deg, rgba(255, 251, 244, 0.98) 0%, rgba(241, 232, 217, 0.95) 100%);
		color: var(--accent-dark);
		box-shadow:
			0 16px 36px rgba(39, 43, 37, 0.18),
			inset 0 1px 0 rgba(255, 255, 255, 0.7);
		cursor: pointer;
		transition:
			transform 180ms ease,
			box-shadow 180ms ease,
			background-color 180ms ease,
			opacity 180ms ease;
	}

	.floating-music-player__launcher:hover:not(:disabled) {
		transform: translateY(-2px);
		box-shadow:
			0 18px 42px rgba(39, 43, 37, 0.22),
			inset 0 1px 0 rgba(255, 255, 255, 0.8);
	}

	.floating-music-player[data-expanded='true'] .floating-music-player__launcher {
		background: linear-gradient(180deg, rgba(22, 98, 74, 0.96) 0%, rgba(16, 81, 61, 0.94) 100%);
		color: rgb(255, 251, 245);
	}

	.floating-music-player[data-ready='false'] .floating-music-player__launcher {
		opacity: 0.9;
	}

	.floating-music-player[data-playing='true'] .floating-music-player__launcher {
		box-shadow:
			0 0 0 0 rgba(22, 98, 74, 0.28),
			0 18px 42px rgba(39, 43, 37, 0.2),
			inset 0 1px 0 rgba(255, 255, 255, 0.2);
		animation: floating-player-pulse 2.4s ease-out infinite;
	}

	.floating-music-player__launcher svg {
		width: 1.45rem;
		height: 1.45rem;
	}

	.floating-music-player__panel {
		position: absolute;
		right: 0;
		bottom: calc(100% + 0.75rem);
		display: grid;
		gap: 0.72rem;
		width: min(15.5rem, calc(100vw - 1rem));
		padding: 0.8rem;
		border-radius: 24px;
		background: linear-gradient(180deg, rgba(255, 251, 244, 0.96) 0%, rgba(244, 236, 223, 0.94) 100%);
		box-shadow: 0 22px 52px rgba(39, 43, 37, 0.16);
		opacity: 0;
		transform: translateY(0.5rem) scale(0.97);
		transform-origin: right bottom;
		pointer-events: none;
		transition:
			opacity 180ms ease,
			transform 180ms ease;
	}

	.floating-music-player[data-expanded='true'] .floating-music-player__panel {
		opacity: 1;
		transform: translateY(0) scale(1);
		pointer-events: auto;
	}

	.floating-music-player__meta {
		display: grid;
		gap: 0.5rem;
		align-items: center;
	}

	.floating-music-player__current {
		display: block;
		min-width: 0;
		padding: 0.74rem 0.85rem;
		border-radius: 16px;
		background: rgba(255, 255, 255, 0.68);
		color: rgb(var(--black));
		font-size: 0.9rem;
		line-height: 1.2;
		overflow: hidden;
		text-overflow: ellipsis;
		white-space: nowrap;
	}

	.floating-music-player__volume-slider,
	.floating-music-player__control {
		min-height: 2.35rem;
		border-radius: 18px;
		color: rgb(var(--black));
		transition:
			transform 180ms ease,
			background-color 180ms ease,
			box-shadow 180ms ease,
			opacity 180ms ease;
	}

	.floating-music-player__volume-slider {
		appearance: none;
		width: 100%;
		min-height: auto;
		height: 0.95rem;
		padding: 0;
		border-radius: 999px;
		background:
			linear-gradient(180deg, rgba(255, 255, 255, 0.62) 0%, rgba(244, 236, 223, 0.92) 100%);
		box-shadow: inset 0 0 0 1px rgba(56, 61, 56, 0.08);
		cursor: pointer;
	}

	.floating-music-player__volume-slider:hover:not(:disabled),
	.floating-music-player__control:hover:not(:disabled) {
		transform: translateY(-1px);
		box-shadow: 0 10px 20px rgba(39, 43, 37, 0.08);
	}

	.floating-music-player__volume-slider:disabled,
	.floating-music-player__control:disabled {
		cursor: default;
		opacity: 0.5;
	}

	.floating-music-player__controls {
		display: grid;
		grid-template-columns: repeat(3, minmax(0, 1fr));
		gap: 0.45rem;
	}

	.floating-music-player__control {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		padding: 0;
		background: rgba(255, 255, 255, 0.72);
		cursor: pointer;
	}

	.floating-music-player__control--primary {
		background: linear-gradient(180deg, rgba(22, 98, 74, 0.96) 0%, rgba(16, 81, 61, 0.94) 100%);
		color: rgb(255, 251, 245);
	}

	.floating-music-player__control--primary:hover:not(:disabled) {
		background: linear-gradient(180deg, rgba(24, 108, 81, 0.98) 0%, rgba(17, 88, 66, 0.96) 100%);
	}

	.floating-music-player__control svg {
		width: 0.95rem;
		height: 0.95rem;
	}

	.floating-music-player__volume-slider::-webkit-slider-runnable-track {
		height: 0.95rem;
		border-radius: 999px;
		background: linear-gradient(90deg, rgba(22, 98, 74, 0.2), rgba(201, 111, 74, 0.14));
	}

	.floating-music-player__volume-slider::-webkit-slider-thumb {
		appearance: none;
		width: 1rem;
		height: 1rem;
		margin-top: -0.02rem;
		border: 0;
		border-radius: 999px;
		background: linear-gradient(180deg, rgba(22, 98, 74, 0.96) 0%, rgba(16, 81, 61, 0.94) 100%);
		box-shadow: 0 4px 10px rgba(39, 43, 37, 0.18);
	}

	.floating-music-player__volume-slider::-moz-range-track {
		height: 0.95rem;
		border: 0;
		border-radius: 999px;
		background: linear-gradient(90deg, rgba(22, 98, 74, 0.2), rgba(201, 111, 74, 0.14));
	}

	.floating-music-player__volume-slider::-moz-range-thumb {
		width: 1rem;
		height: 1rem;
		border: 0;
		border-radius: 999px;
		background: linear-gradient(180deg, rgba(22, 98, 74, 0.96) 0%, rgba(16, 81, 61, 0.94) 100%);
		box-shadow: 0 4px 10px rgba(39, 43, 37, 0.18);
	}

	@keyframes floating-player-pulse {
		0% {
			box-shadow:
				0 0 0 0 rgba(22, 98, 74, 0.28),
				0 18px 42px rgba(39, 43, 37, 0.2),
				inset 0 1px 0 rgba(255, 255, 255, 0.2);
		}

		70% {
			box-shadow:
				0 0 0 12px rgba(22, 98, 74, 0),
				0 18px 42px rgba(39, 43, 37, 0.2),
				inset 0 1px 0 rgba(255, 255, 255, 0.2);
		}

		100% {
			box-shadow:
				0 0 0 0 rgba(22, 98, 74, 0),
				0 18px 42px rgba(39, 43, 37, 0.2),
				inset 0 1px 0 rgba(255, 255, 255, 0.2);
		}
	}

	@media (max-width: 720px) {
		.floating-music-player {
			right: 0.7rem;
			bottom: max(0.8rem, calc(env(safe-area-inset-bottom) + 0.35rem));
		}

		.floating-music-player__panel {
			width: min(14.8rem, calc(100vw - 1rem));
			padding: 0.75rem;
			background: rgba(255, 251, 244, 0.98);
		}

		.floating-music-player__launcher {
			width: 3.35rem;
			height: 3.35rem;
		}

		.floating-music-player[data-playing='true'] .floating-music-player__launcher {
			animation: none;
		}
	}

	@media (prefers-reduced-motion: reduce) {
		.floating-music-player__launcher,
		.floating-music-player__panel,
		.floating-music-player__volume-slider,
		.floating-music-player__control {
			transition: none;
		}

		.floating-music-player[data-playing='true'] .floating-music-player__launcher {
			animation: none;
		}
	}
</style>
