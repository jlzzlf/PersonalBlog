---
import type { MarkdownHeading } from 'astro';
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';

type Props = CollectionEntry<'projects'>['data'] & {
	headings?: MarkdownHeading[];
};

const { title, summary, teaser, status, year, role, tags = [], stack = [], coverImage } = Astro.props;
const usesPublicCoverImage = typeof coverImage === 'string';
const tocHeadings = (Astro.props.headings ?? []).filter(
	(heading) => heading.depth >= 2 && heading.depth <= 3,
);
const resolvedHeroImage =
	coverImage &&
	(usesPublicCoverImage
		? { src: coverImage }
		: {
				src: coverImage.src,
				width: coverImage.width,
				height: coverImage.height,
			});
---

<html lang="zh-CN">
	<head>
		<BaseHead title={`${title} | 项目展示`} description={summary} />
	</head>

	<body class="project-post-page">
		<Header />
		<main class="project-post-page__main">
			<div class="project-post-shell">
				<article class="project-post-layout">
					<header class="project-post-header">
						<nav class="project-post-breadcrumb" aria-label="面包屑">
							<a href="/projects/">项目</a>
							<span aria-hidden="true">/</span>
							<span>{status}</span>
						</nav>

						<h1>{title}</h1>
						<p class="project-post-summary">{summary}</p>
						{teaser && <p class="project-post-teaser">{teaser}</p>}

						<div class="project-post-meta" aria-label="项目信息">
							<span>{status}</span>
							<span aria-hidden="true">·</span>
							<span>{year}</span>
							<span aria-hidden="true">·</span>
							<span>{role}</span>
							{
								stack.length > 0 && (
									<>
										<span aria-hidden="true">·</span>
										<span>{stack.join(' / ')}</span>
									</>
								)
							}
						</div>

						{
							tags.length > 0 && (
								<div class="project-post-tags" aria-label="项目标签">
									{tags.map((tag) => <span class="project-post-tag">{tag}</span>)}
								</div>
							)
						}
					</header>

					{
						resolvedHeroImage && (
							<figure class="project-post-cover">
								<img
									src={resolvedHeroImage.src}
									width={resolvedHeroImage.width}
									height={resolvedHeroImage.height}
									alt={title}
									loading="eager"
									decoding="async"
								/>
							</figure>
						)
					}

					<section class="project-post-content prose">
						<slot />
					</section>
				</article>

				{
					tocHeadings.length > 0 && (
						<aside class="project-post-toc" aria-label="项目目录">
							<p class="project-post-toc__title">目录</p>
							<nav>
								<ol>
									{
										tocHeadings.map((heading) => (
											<li class={`project-post-toc__item project-post-toc__item--depth-${heading.depth}`}>
												<a href={`#${heading.slug}`}>{heading.text}</a>
											</li>
										))
									}
								</ol>
							</nav>
						</aside>
					)
				}
			</div>
		</main>
		<Footer />
	</body>
</html>

<style>
	.project-post-page__main {
		--project-post-content-width: min(760px, calc(100vw - 2rem));
		--project-post-shell-width: min(1060px, calc(100vw - 2rem));
		--project-post-radius: 8px;
		--project-post-border: rgba(15, 23, 42, 0.1);
		width: var(--project-post-shell-width);
		margin: 0 auto;
		padding-top: clamp(1.5rem, 3vw, 2.8rem);
	}

	.project-post-shell {
		display: grid;
		grid-template-columns: minmax(0, var(--project-post-content-width)) minmax(12rem, 15rem);
		gap: clamp(2rem, 4vw, 3rem);
		align-items: start;
	}

	.project-post-layout {
		display: grid;
		gap: clamp(1.7rem, 3vw, 2.5rem);
		min-width: 0;
	}

	.project-post-header {
		display: grid;
		gap: 0.85rem;
		padding-bottom: clamp(1.4rem, 3vw, 2rem);
		border-bottom: 1px solid rgba(15, 23, 42, 0.1);
	}

	.project-post-header h1 {
		margin: 0;
		color: #111827;
		font-size: clamp(2rem, 4.6vw, 3rem);
		font-weight: 700;
		line-height: 1.2;
		letter-spacing: 0;
		text-wrap: balance;
	}

	.project-post-breadcrumb,
	.project-post-meta {
		display: flex;
		flex-wrap: wrap;
		align-items: center;
		gap: 0.4rem;
		margin: 0;
		color: #6b7280;
		font-size: 0.86rem;
		line-height: 1.35;
	}

	.project-post-breadcrumb a {
		color: var(--color-link-hover);
		text-decoration: none;
	}

	.project-post-breadcrumb a:hover {
		text-decoration: underline;
		text-underline-offset: 0.2em;
	}

	.project-post-summary,
	.project-post-teaser {
		max-width: 42rem;
		margin: 0;
		color: #4b5563;
		text-wrap: pretty;
	}

	.project-post-summary {
		font-size: clamp(1.02rem, 1.3vw, 1.12rem);
		line-height: 1.7;
	}

	.project-post-teaser {
		font-size: 0.98rem;
		line-height: 1.68;
	}

	.project-post-tags {
		display: flex;
		flex-wrap: wrap;
		gap: 0.45rem;
		margin-top: 0.15rem;
	}

	.project-post-tag {
		display: inline-flex;
		align-items: center;
		padding: 0.26rem 0.58rem;
		border: 1px solid rgba(15, 23, 42, 0.1);
		border-radius: 999px;
		background: #fff;
		color: var(--color-link-hover);
		font-size: 0.78rem;
		font-weight: 700;
		line-height: 1.2;
	}

	.project-post-cover {
		margin: 0;
		overflow: hidden;
		border: 1px solid var(--project-post-border);
		border-radius: var(--project-post-radius);
		background: #fff;
	}

	.project-post-cover img {
		display: block;
		width: 100%;
		height: auto;
		aspect-ratio: 16 / 9;
		object-fit: cover;
		border-radius: inherit;
	}

	.project-post-content {
		width: 100%;
		min-width: 0;
		margin: 0 auto;
		padding: 0 0 0.35rem;
	}

	.project-post-toc {
		position: sticky;
		top: 7rem;
		max-height: calc(100vh - 8.5rem);
		overflow: auto;
		padding-left: 1rem;
		border-left: 1px solid rgba(15, 23, 42, 0.1);
		color: #6b7280;
		font-size: 0.86rem;
		line-height: 1.45;
		scrollbar-width: thin;
		scrollbar-color: rgba(153, 230, 255, 0.48) transparent;
	}

	.project-post-toc__title {
		margin: 0 0 0.72rem;
		color: #111827;
		font-size: 0.9rem;
		font-weight: 700;
		line-height: 1.3;
	}

	.project-post-toc ol {
		display: grid;
		gap: 0.18rem;
		margin: 0;
		padding: 0;
		list-style: none;
	}

	.project-post-toc__item {
		margin: 0;
	}

	.project-post-toc__item--depth-3 {
		padding-left: 0.9rem;
	}

	.project-post-toc a {
		display: block;
		padding: 0.28rem 0;
		color: inherit;
		text-decoration: none;
	}

	.project-post-toc a:hover,
	.project-post-toc a:focus-visible {
		color: var(--color-link-hover);
	}

	:global(body.project-post-page) {
		background: #fff;
	}

	:global(body.project-post-page::before) {
		display: none;
	}

	@media (max-width: 720px) {
		.project-post-page__main {
			--project-post-content-width: calc(100vw - 1.15rem);
			--project-post-shell-width: var(--project-post-content-width);
			width: var(--project-post-content-width);
			padding-top: 1rem;
		}

		.project-post-shell {
			grid-template-columns: 1fr;
		}

		.project-post-toc {
			display: none;
		}

		.project-post-header h1 {
			font-size: clamp(1.82rem, 8vw, 2.35rem);
		}
	}

	@media (min-width: 721px) and (max-width: 1040px) {
		.project-post-page__main {
			--project-post-shell-width: var(--project-post-content-width);
		}

		.project-post-shell {
			grid-template-columns: 1fr;
		}

		.project-post-toc {
			display: none;
		}
	}
</style>
