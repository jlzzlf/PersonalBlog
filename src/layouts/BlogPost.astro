---
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Comments from '../components/Comments.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';

type Props = CollectionEntry<'blog'>['data'];

const { title, description, category, pubDate, updatedDate, coverImage } = Astro.props;
const usesPublicCoverImage = typeof coverImage === 'string';
const tags = Astro.props.tags ?? [];
const resolvedHeroImage =
	coverImage &&
	(usesPublicCoverImage
		? { src: coverImage }
		: {
				src: coverImage.src,
				width: coverImage.width,
				height: coverImage.height,
			});
---

<html lang="zh-CN">
	<head>
		<BaseHead title={title} description={description} />
	</head>

	<body class="post-page">
		<Header />
		<main class="post-page__main">
			<article class="post-layout">
				<header class="post-header">
					<nav class="post-breadcrumb" aria-label="面包屑">
						<a href="/blog/">博客</a>
						<span aria-hidden="true">/</span>
						<span>{category}</span>
					</nav>

					<h1 id="article-title">{title}</h1>
					<p class="post-description">{description}</p>

					<div class="post-meta">
						<span>{category}</span>
						<span aria-hidden="true">·</span>
						<FormattedDate date={pubDate} />
						{
							updatedDate && (
								<>
									<span aria-hidden="true">·</span>
									<span>
										更新于 <FormattedDate date={updatedDate} />
									</span>
								</>
							)
						}
					</div>

					{
						tags.length > 0 && (
							<div class="post-tags" aria-label="文章标签">
								{
									tags.map((tag) => (
										<span class="post-tag">{tag}</span>
									))
								}
							</div>
						)
					}
				</header>

				{
					resolvedHeroImage && (
						<figure class="post-cover">
							<img
								src={resolvedHeroImage.src}
								width={resolvedHeroImage.width}
								height={resolvedHeroImage.height}
								alt={title}
								loading="eager"
								decoding="async"
							/>
						</figure>
					)
				}

				<section class="post-content prose">
					<slot />
				</section>

				<Comments />
			</article>
		</main>
		<script is:inline>
			(() => {
				const stateKey = '__joylifePostEmojiState';
				const state = (window[stateKey] ??= { bound: false });
				const wrapLeadingEmoji = () => {
					const root = document.querySelector('.post-content');
					if (!(root instanceof HTMLElement)) return;

					const emojiPattern =
						/^(\s*)((?:[\p{Extended_Pictographic}\p{Emoji_Presentation}]|\d\uFE0F?\u20E3|[#*]\uFE0F?\u20E3)(?:\uFE0F|\u200D(?:[\p{Extended_Pictographic}\p{Emoji_Presentation}]|\d\uFE0F?\u20E3))*)\s*/u;
					const targets = root.querySelectorAll('h1, h2, h3, h4, p, li');

					for (const element of targets) {
						if (!(element instanceof HTMLElement) || element.querySelector('.prose-emoji')) {
							continue;
						}

						const firstTextNode = Array.from(element.childNodes).find(
							(node) => node.nodeType === Node.TEXT_NODE && node.textContent?.trim(),
						);
						if (!firstTextNode?.textContent) continue;

						const match = firstTextNode.textContent.match(emojiPattern);
						if (!match) continue;

						const [, leadingSpace, emoji] = match;
						const emojiMarker = document.createElement('span');
						emojiMarker.className = 'prose-emoji';
						emojiMarker.setAttribute('aria-hidden', 'true');
						emojiMarker.textContent = emoji;

						const parent = firstTextNode.parentNode;
						if (!parent) continue;

						if (leadingSpace) {
							parent.insertBefore(document.createTextNode(leadingSpace), firstTextNode);
						}
						parent.insertBefore(emojiMarker, firstTextNode);
						firstTextNode.textContent = firstTextNode.textContent.slice(match[0].length);
						element.classList.add('has-leading-emoji');
					}
				};

				if (!state.bound) {
					state.bound = true;
					document.addEventListener('astro:page-load', wrapLeadingEmoji);
				}
				wrapLeadingEmoji();
			})();
		</script>
		<Footer />
	</body>
</html>

<style>
	.post-page__main {
		--post-content-width: min(760px, calc(100vw - 2rem));
		--post-radius: 8px;
		--post-border: rgba(15, 23, 42, 0.1);
		width: var(--post-content-width);
		margin: 0 auto;
		padding-top: clamp(1.5rem, 3vw, 2.8rem);
	}

	.post-layout {
		display: grid;
		gap: clamp(1.7rem, 3vw, 2.5rem);
	}

	.post-cover {
		width: 100%;
		margin: 0 auto;
		padding: 0;
		overflow: hidden;
		border: 1px solid var(--post-border);
		border-radius: var(--post-radius);
		background: #fff;
	}

	.post-cover img {
		display: block;
		width: 100%;
		height: auto;
		aspect-ratio: 16 / 9;
		object-fit: cover;
		border-radius: inherit;
	}

	.post-header {
		display: grid;
		gap: 0.85rem;
		padding-bottom: clamp(1.4rem, 3vw, 2rem);
		border-bottom: 1px solid rgba(15, 23, 42, 0.1);
	}

	.post-header h1 {
		margin: 0;
		color: #111827;
		font-size: clamp(2rem, 4.6vw, 3rem);
		font-weight: 700;
		line-height: 1.2;
		letter-spacing: 0;
		text-wrap: balance;
	}

	.post-breadcrumb,
	.post-meta {
		display: flex;
		flex-wrap: wrap;
		align-items: center;
		gap: 0.4rem;
		margin: 0;
		color: #6b7280;
		font-size: 0.86rem;
		line-height: 1.35;
	}

	.post-breadcrumb a {
		color: var(--color-link-hover);
		text-decoration: none;
	}

	.post-breadcrumb a:hover {
		text-decoration: underline;
		text-underline-offset: 0.2em;
	}

	.post-tags {
		display: flex;
		flex-wrap: wrap;
		gap: 0.45rem;
		margin-top: 0.15rem;
	}

	.post-tag {
		display: inline-flex;
		align-items: center;
		padding: 0.26rem 0.58rem;
		border: 1px solid rgba(15, 23, 42, 0.1);
		border-radius: 999px;
		background: #fff;
		color: var(--color-link-hover);
		font-size: 0.78rem;
		font-weight: 700;
		line-height: 1.2;
	}

	.post-description {
		max-width: 42rem;
		margin: 0;
		color: #4b5563;
		font-size: clamp(1.02rem, 1.3vw, 1.12rem);
		line-height: 1.7;
		text-wrap: pretty;
	}

	.post-content {
		width: var(--post-content-width);
		min-width: 0;
		margin: 0 auto;
		padding: 0 0 0.35rem;
	}

	:global(.post-page .comments-section) {
		width: var(--post-content-width);
		margin: 0 auto;
		border-radius: 8px;
		border-color: rgba(15, 23, 42, 0.1);
		background: #fff;
		box-shadow: none;
	}

	@media (max-width: 720px) {
		.post-page__main {
			--post-content-width: calc(100vw - 1.15rem);
			width: var(--post-content-width);
			padding-top: 1rem;
		}

		.post-header h1 {
			font-size: clamp(1.82rem, 8vw, 2.35rem);
		}
	}
</style>
