---
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Comments from '../components/Comments.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';

type Props = CollectionEntry<'blog'>['data'];

const { title, description, pubDate, updatedDate, coverImage } = Astro.props;
const usesPublicCoverImage = typeof coverImage === 'string';
const tags = Astro.props.tags ?? [];
const resolvedHeroImage =
	coverImage &&
	(usesPublicCoverImage
		? { src: coverImage }
		: {
				src: coverImage.src,
				width: coverImage.width,
				height: coverImage.height,
			});
---

<html lang="zh-CN">
	<head>
		<BaseHead title={title} description={description} />
	</head>

	<body class="post-page">
		<Header />
		<main class="post-page__main">
			<article class="post-layout">
				{
					resolvedHeroImage && (
						<figure class="surface-card post-cover">
							<img
								src={resolvedHeroImage.src}
								width={resolvedHeroImage.width}
								height={resolvedHeroImage.height}
								alt={title}
								loading="eager"
								decoding="async"
							/>
						</figure>
					)
				}

				<section class="surface-card post-header">
					<p class="eyebrow">Blog Post</p>
					<div class="post-header__meta">
						<div class="post-header__dates">
							<FormattedDate date={pubDate} />
							{
								updatedDate && (
									<span class="post-updated">
										更新于 <FormattedDate date={updatedDate} />
									</span>
								)
							}
						</div>
						{
							tags.length > 0 && (
								<div class="post-tags" aria-label="文章标签">
									{
										tags.map((tag) => (
											<span class="post-tag">{tag}</span>
										))
									}
								</div>
							)
						}
					</div>
					<h1>{title}</h1>
					<p class="post-description">{description}</p>
				</section>

				<section class="surface-card post-content prose">
					<slot />
				</section>

				<Comments />
			</article>
		</main>
		<Footer />
	</body>
</html>

<style>
	.post-page__main {
		width: min(980px, calc(100% - 1.2rem));
		margin: 0 auto;
		padding-top: 1.6rem;
	}

	.post-layout {
		display: grid;
		gap: 1rem;
	}

	.post-cover {
		margin: 0;
		padding: 0;
		overflow: hidden;
	}

	.post-cover img {
		display: block;
		width: 100%;
		height: auto;
		aspect-ratio: 16 / 9;
		object-fit: cover;
		border-radius: inherit;
	}

	.post-header {
		display: grid;
		gap: 1rem;
		padding: clamp(1.5rem, 2.4vw, 2.2rem);
	}

	.post-header h1 {
		margin-bottom: 0;
	}

	.post-header__meta {
		display: flex;
		flex-wrap: wrap;
		align-items: flex-start;
		justify-content: space-between;
		gap: 1rem;
	}

	.post-header__dates {
		display: grid;
		gap: 0.2rem;
		color: var(--color-subtext);
		font-size: 0.95rem;
	}

	.post-updated {
		color: var(--color-text);
		font-style: italic;
	}

	.post-tags {
		display: flex;
		flex-wrap: wrap;
		justify-content: flex-end;
		gap: 0.45rem;
	}

	.post-tag {
		display: inline-flex;
		align-items: center;
		padding: 0.36rem 0.72rem;
		border: 1px solid var(--color-border);
		border-radius: 999px;
		background: rgba(230, 250, 255, 0.84);
		color: var(--color-link-hover);
		font-size: 0.84rem;
		font-weight: 700;
		line-height: 1.2;
	}

	.post-description {
		margin: 0;
		color: var(--color-subtext);
		font-size: 1.05rem;
	}

	.post-content {
		padding: clamp(1.5rem, 2.2vw, 2.2rem);
	}

	@media (max-width: 720px) {
		.post-page__main {
			width: calc(100% - 1rem);
			padding-top: 1rem;
		}

		.post-header__meta {
			flex-direction: column;
		}

		.post-tags {
			justify-content: flex-start;
		}
	}
</style>
