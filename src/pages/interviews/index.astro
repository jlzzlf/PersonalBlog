---
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import ContentArchiveListView from '../../components/views/ContentArchiveListView.astro';
import Footer from '../../components/Footer.astro';
import Header from '../../components/Header.astro';
import { SITE_TITLE } from '../../consts';
import { sortInterviewEntries } from '../../lib/interviews';

const interviews = sortInterviewEntries(await getCollection('interviews'));
const pageTitle = `面试归档 | ${SITE_TITLE}`;
const items = interviews.map((entry) => ({
	title: entry.data.title,
	description: entry.data.description,
	meta: entry.data.subject,
	pubDate: entry.data.pubDate,
	href: `/interviews/${entry.id}/`,
}));
---

<!doctype html>
<html lang="zh-CN">
	<head>
		<BaseHead title={pageTitle} description="集中整理 Unity 与 C# 面试题、复盘和回答思路。" />
	</head>
	<body>
		<Header />
		<ContentArchiveListView
			eyebrow="Interview Archive"
			title="面试归档"
			intro="把面试题、复盘与回答思路集中在一起，作为可持续维护的资料库。"
			items={items}
		/>
		<Footer />
	</body>
</html>
