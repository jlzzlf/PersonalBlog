---
import { getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);

const toDayKey = (date: Date) =>
	`${date.getFullYear()}-${String(date.getMonth() + 1).padStart(2, '0')}-${String(
		date.getDate(),
	).padStart(2, '0')}`;

const formatArchiveDate = (date: Date) =>
	new Intl.DateTimeFormat('zh-CN', {
		month: 'short',
		day: 'numeric',
	}).format(date);

const archiveDateFormatter = new Intl.DateTimeFormat('zh-CN', {
	month: 'short',
	day: 'numeric',
});

const fullDateFormatter = new Intl.DateTimeFormat('zh-CN', {
	year: 'numeric',
	month: 'long',
	day: 'numeric',
});

const postFeedItems = posts.map((post) => ({
	id: post.id,
	href: `/blog/${post.id}/`,
	title: post.data.title,
	description: post.data.description,
	pubDateISO: post.data.pubDate.toISOString(),
	archiveDateLabel: formatArchiveDate(post.data.pubDate),
	year: String(post.data.pubDate.getFullYear()),
	dayKey: toDayKey(post.data.pubDate),
}));

const archiveGroups = Array.from(
	posts.reduce((groups, post) => {
		const year = String(post.data.pubDate.getFullYear());
		const yearPosts = groups.get(year);
		if (yearPosts) {
			yearPosts.push(post);
		} else {
			groups.set(year, [post]);
		}
		return groups;
	}, new Map<string, typeof posts>()),
).map(([year, items]) => ({ year, items }));

const latestUpdatedDate = posts.reduce((latest, post) => {
	const candidate = post.data.updatedDate ?? post.data.pubDate;
	return candidate > latest ? candidate : latest;
}, posts[0]?.data.updatedDate ?? posts[0]?.data.pubDate ?? new Date());

const heroStats = [
	{ label: '文章总数', value: String(posts.length) },
	{ label: '归档年份', value: String(archiveGroups.length) },
	{ label: '最近更新', value: fullDateFormatter.format(latestUpdatedDate) },
];

const weekDays = ['一', '二', '三', '四', '五', '六', '日'];
const pageTitle = `归档 | ${SITE_TITLE}`;
const pageDescription = `独立归档页，结合日历与完整时间线查看所有文章更新。${SITE_DESCRIPTION}`;
---

<!doctype html>
<html lang="zh-CN">
	<head>
		<BaseHead title={pageTitle} description={pageDescription} />
	</head>
	<body>
		<Header />
		<main class="archive-page" data-archive-page>
			<section class="surface-card archive-hero">
				<p class="eyebrow">Archive Desk</p>
				<h1>归档与日历</h1>
				<p class="archive-hero__copy">
					把时间线单独放到这一页以后，首页会更干净，归档本身也可以完整展开。你可以按日历筛选当天内容，也可以直接从年份时间线里一路往下翻。
				</p>
				<div class="archive-hero__stats" aria-label="归档概览">
					{
						heroStats.map((stat) => (
							<div class="archive-hero__stat">
								<strong>{stat.value}</strong>
								<span>{stat.label}</span>
							</div>
						))
					}
				</div>
				<div class="archive-hero__actions">
					<a class="button" href="/">返回首页</a>
					<a class="button secondary" href="/blog/">查看博客列表</a>
				</div>
			</section>

			<section class="archive-workspace">
				<article class="surface-card calendar-card">
					<p class="eyebrow">Calendar</p>
					<div class="calendar-header">
						<h2>日历筛选</h2>
						<span data-calendar-month-label>加载中...</span>
					</div>
					<p class="calendar-copy">点某一天只看当天发布的内容，再点一次就恢复完整归档。</p>
					<div class="calendar-weekdays">
						{
							weekDays.map((day) => (
								<span>{day}</span>
							))
						}
					</div>
					<div class="calendar-grid" data-calendar-grid></div>
				</article>

				<article class="surface-card archive-panel">
					<div class="archive-header">
						<div>
							<p class="eyebrow">Timeline</p>
							<h2>完整归档</h2>
							<p class="archive-copy">按年份展开所有文章，列表长度直接由页面承载，不再限制在首页卡片里。</p>
						</div>
						<span class="archive-count" data-archive-count>{posts.length} 篇文章</span>
					</div>

					<div class="archive-timeline" data-archive-timeline>
						{
							archiveGroups.map((group) => (
								<section class="archive-group">
									<div class="archive-year">{group.year}</div>
									<div class="archive-items">
										{
											group.items.map((post) => (
												<a class="archive-item" href={`/blog/${post.id}/`}>
													<time datetime={post.data.pubDate.toISOString()} class="archive-date">
														{archiveDateFormatter.format(post.data.pubDate)}
													</time>
													<div class="archive-item-body">
														<strong>{post.data.title}</strong>
														<p>{post.data.description}</p>
													</div>
												</a>
											))
										}
									</div>
								</section>
							))
						}
					</div>
				</article>
			</section>

			<script type="application/json" data-post-feed set:html={JSON.stringify(postFeedItems)}></script>
		</main>
		<Footer />
	</body>
</html>

<style>
	.archive-page {
		display: grid;
		gap: 1.35rem;
	}

	.archive-hero,
	.archive-workspace {
		width: min(1360px, calc(100% - 2rem));
		margin: 0 auto;
	}

	.archive-hero {
		display: grid;
		gap: 0.95rem;
		max-width: 70rem;
		padding: clamp(1.6rem, 2vw, 2.15rem);
		background:
			radial-gradient(circle at 0% 0%, rgba(255, 214, 232, 0.24), transparent 30%),
			radial-gradient(circle at 100% 100%, rgba(204, 255, 255, 0.22), transparent 32%),
			linear-gradient(135deg, rgba(255, 255, 255, 0.95), rgba(230, 250, 255, 0.86));
	}

	.archive-hero__copy {
		margin: 0;
		max-width: 48rem;
		color: var(--color-subtext);
		font-size: 1rem;
		line-height: 1.8;
	}

	.archive-hero__stats {
		display: grid;
		grid-template-columns: repeat(3, minmax(0, 1fr));
		gap: 0.85rem;
		margin-top: 0.2rem;
	}

	.archive-hero__stat {
		display: grid;
		gap: 0.28rem;
		padding: 0.95rem 1rem;
		border: 1px solid rgba(153, 230, 255, 0.38);
		border-radius: 22px;
		background: rgba(255, 255, 255, 0.74);
	}

	.archive-hero__stat strong {
		font-size: 1.3rem;
		line-height: 1.15;
		color: var(--color-text);
	}

	.archive-hero__stat span {
		color: var(--color-subtext);
		font-size: 0.84rem;
		font-weight: 700;
		letter-spacing: 0.04em;
	}

	.archive-hero__actions {
		display: flex;
		flex-wrap: wrap;
		gap: 0.8rem;
		margin-top: 0.2rem;
	}

	.archive-workspace {
		display: grid;
		grid-template-columns: minmax(17rem, 21rem) minmax(0, 1fr);
		gap: 1rem;
		align-items: start;
	}

	.calendar-card,
	.archive-panel {
		position: relative;
		overflow: hidden;
	}

	.calendar-card {
		position: sticky;
		top: calc(4.8rem + 1rem);
		display: grid;
		gap: 0.95rem;
		padding: 1.35rem;
		background: linear-gradient(180deg, rgba(255, 255, 255, 0.94), rgba(230, 250, 255, 0.82));
	}

	.calendar-header {
		display: flex;
		align-items: end;
		justify-content: space-between;
		gap: 0.75rem;
	}

	.calendar-header h2 {
		font-size: 1.45rem;
	}

	.calendar-header span {
		color: var(--color-subtext);
		font-size: 0.94rem;
	}

	.calendar-copy {
		margin: 0;
		color: var(--color-subtext);
		font-size: 0.92rem;
		line-height: 1.65;
	}

	.calendar-weekdays,
	.calendar-grid {
		display: grid;
		grid-template-columns: repeat(7, minmax(0, 1fr));
		gap: 0.45rem;
	}

	.calendar-weekdays span {
		text-align: center;
		color: var(--color-subtext);
		font-size: 0.84rem;
	}

	:global(.calendar-day) {
		display: flex;
		align-items: center;
		justify-content: center;
		min-height: 2.45rem;
		padding: 0;
		border: 1px solid var(--color-border);
		border-radius: 14px;
		background: rgba(255, 255, 255, 0.86);
		color: var(--color-text);
		font-family: inherit;
		font-size: 0.92rem;
		line-height: 1;
	}

	:global(button.calendar-day) {
		cursor: pointer;
		transition:
			transform 180ms ease,
			background-color 180ms ease,
			border-color 180ms ease,
			box-shadow 180ms ease;
	}

	:global(button.calendar-day:hover) {
		transform: translateY(-1px);
		border-color: rgba(153, 230, 255, 0.78);
		background: rgba(230, 250, 255, 0.92);
		box-shadow: 0 12px 24px rgba(112, 159, 176, 0.08);
	}

	:global(button.calendar-day.selected) {
		background: linear-gradient(180deg, rgba(153, 230, 255, 0.96), rgba(255, 214, 232, 0.82));
		border-color: rgba(153, 230, 255, 0.92);
		color: var(--color-text);
		font-weight: 700;
	}

	:global(.calendar-day.today) {
		background: linear-gradient(180deg, var(--color-primary-deep), var(--color-primary));
		border-color: rgba(153, 230, 255, 0.9);
		color: var(--color-text);
		font-weight: 700;
	}

	:global(.calendar-day.empty) {
		border-color: transparent;
		background: transparent;
	}

	.archive-panel {
		display: grid;
		gap: 1.2rem;
		padding: 1.45rem;
		container-type: inline-size;
		background: linear-gradient(180deg, rgba(255, 255, 255, 0.94), rgba(230, 250, 255, 0.82));
	}

	.archive-header {
		display: flex;
		align-items: end;
		justify-content: space-between;
		gap: 1rem;
	}

	.archive-copy {
		margin: 0.45rem 0 0;
		color: var(--color-subtext);
		font-size: 0.94rem;
		line-height: 1.68;
	}

	.archive-count {
		padding: 0.45rem 0.8rem;
		border: 1px solid rgba(153, 230, 255, 0.5);
		border-radius: 999px;
		background: rgba(153, 230, 255, 0.22);
		color: var(--color-link-hover);
		font-size: 0.9rem;
		font-weight: 700;
		white-space: nowrap;
	}

	.archive-timeline {
		display: grid;
		gap: 1.35rem;
	}

	:global(.archive-group) {
		display: grid;
		grid-template-columns: auto minmax(0, 1fr);
		gap: 1rem;
		align-items: start;
	}

	:global(.archive-year) {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		min-width: 4.8rem;
		padding: 0.55rem 0.8rem;
		border: 1px solid var(--color-border);
		border-radius: 999px;
		background: rgba(255, 255, 255, 0.84);
		color: var(--color-link-hover);
		font-size: 0.95rem;
		font-weight: 700;
		letter-spacing: 0.06em;
	}

	:global(.archive-items) {
		position: relative;
		display: grid;
		gap: 0.9rem;
		padding-left: 1.25rem;
	}

	:global(.archive-items)::before {
		content: '';
		position: absolute;
		top: 0.55rem;
		bottom: 0.55rem;
		left: 0.3rem;
		width: 2px;
		border-radius: 999px;
		background: linear-gradient(180deg, rgba(153, 230, 255, 0.72), rgba(255, 214, 232, 0.54));
	}

	:global(.archive-item) {
		position: relative;
		display: grid;
		grid-template-columns: minmax(5.6rem, auto) minmax(0, 1fr);
		gap: 1rem;
		align-items: start;
		padding: 1rem 1.1rem 1rem 1.2rem;
		border: 1px solid var(--color-border);
		border-radius: 22px;
		background: rgba(255, 255, 255, 0.84);
		color: var(--color-text);
		text-decoration: none;
		transition:
			transform 180ms ease,
			box-shadow 180ms ease,
			border-color 180ms ease,
			background-color 180ms ease;
	}

	:global(.archive-item)::before {
		content: '';
		position: absolute;
		top: 1.25rem;
		left: -1.02rem;
		width: 0.8rem;
		height: 0.8rem;
		border-radius: 999px;
		background: linear-gradient(180deg, var(--color-primary-deep), var(--color-accent-pink));
		box-shadow: 0 0 0 6px rgba(248, 254, 255, 0.92);
	}

	:global(.archive-item:hover) {
		transform: translateY(-2px);
		border-color: rgba(153, 230, 255, 0.72);
		background: rgba(230, 250, 255, 0.88);
		box-shadow: 0 16px 32px rgba(112, 159, 176, 0.1);
	}

	:global(.archive-date) {
		color: var(--color-link-hover);
		font-size: 0.95rem;
		font-weight: 700;
		white-space: nowrap;
	}

	:global(.archive-item-body) {
		min-width: 0;
		display: grid;
		gap: 0.35rem;
	}

	:global(.archive-item-body strong) {
		display: block;
		font-size: 1.08rem;
		line-height: 1.4;
	}

	:global(.archive-item-body p) {
		margin: 0;
		color: var(--color-subtext);
		font-size: 0.92rem;
		line-height: 1.6;
	}

	:global(.archive-empty) {
		padding: 1.2rem 0.2rem 0.2rem;
	}

	:global(.archive-empty p) {
		color: var(--color-subtext);
	}

	@container (max-width: 36rem) {
		:global(.archive-item) {
			grid-template-columns: 1fr;
		}

		:global(.archive-date) {
			display: inline-flex;
		}
	}

	@media (max-width: 960px) {
		.archive-workspace {
			grid-template-columns: 1fr;
		}

		.calendar-card {
			position: static;
		}
	}

	@media (max-width: 860px) {
		.archive-hero,
		.archive-workspace {
			width: min(44rem, calc(100% - 1rem));
		}

		.archive-hero__stats {
			grid-template-columns: 1fr;
		}
	}

	@media (max-width: 720px) {
		.archive-page {
			gap: 1.05rem;
		}

		.archive-hero,
		.archive-workspace {
			width: calc(100% - 1rem);
		}

		.calendar-card,
		.archive-panel {
			padding: 1rem;
		}

		.calendar-header,
		.archive-header {
			flex-direction: column;
			align-items: flex-start;
		}

		:global(.archive-group),
		:global(.archive-item) {
			grid-template-columns: 1fr;
		}

		:global(.archive-items) {
			padding-left: 0.95rem;
		}

		:global(.archive-date) {
			display: inline-flex;
		}
	}
</style>

<script>
	import '../scripts/archive-page.ts';
</script>
