---
import { getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_TITLE } from '../consts';

const pageTitle = `更多 | ${SITE_TITLE}`;
const cheatSheetHref = '/cheat_sheet/';
const interviewNotesHref = '/interview-notes/';
const mediaReviews = (await getCollection('reviews'))
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
	.slice(0, 4);

const widgetNotes = [
	'图片库现在收成了一个独立入口，打开后直接进入完整图库页。',
	'评分与评论现在已经支持独立 MDX 文件，后面直接新增内容就行。',
	'如果还想扩展，这一页也适合继续加收藏夹、追番清单和游玩记录。',
];
---

<!doctype html>
<html lang="zh-CN">
	<head>
		<BaseHead title={pageTitle} description="更多页面：放一些图片收藏、评分评论和杂项小组件。" />
	</head>
	<body>
		<Header />
		<main class="extras-page">
			<section class="surface-card extras-hero">
				<div class="extras-hero__copy">
					<p class="eyebrow">More</p>
					<h1>把一些不适合放首页，但又很想保留的内容，集中放在这里。</h1>
					<p>
						这个页面现在更像一个杂项实验区。后面可以慢慢加上图片库、评分评论、收藏记录，或者别的轻量小组件，让它变成更有生活感的角落。
					</p>
				</div>
				<div class="extras-hero__chips" aria-label="页面内容概览">
					<span>学习速查表</span>
					<span>面经整理</span>
					<span>图片库预览</span>
					<span>游戏 / 动漫评分</span>
					<span>短评记录</span>
					<span>杂项小组件</span>
				</div>
			</section>

			<section class="extras-grid">
				<article class="surface-card widget-card widget-card--cheat-sheet">
					<div class="widget-card__header">
						<p class="widget-card__eyebrow">Featured</p>
						<div class="widget-card__title-row">
							<div>
								<h2>C# / Unity Cheat Sheet</h2>
								<p>你新建的速查表已经接入站内，现在可以直接从“更多”页进入，不再是一个孤立的独立文件。</p>
							</div>
							<a class="button widget-card__link" href={cheatSheetHref}>进入速查表</a>
						</div>
					</div>

					<div class="featured-entry-panel" aria-label="Cheat Sheet 入口">
						<div class="featured-entry-panel__copy">
							<p>
								这里收纳的是一套偏学习向的卡片式速查表，适合拿来快速翻 C# / Unity
								常用知识点、代码片段和坑点记录。
							</p>
						</div>
						<div class="featured-entry-panel__meta" aria-label="Cheat Sheet 特性">
							<span>站内入口</span>
							<span>搜索卡片</span>
							<span>拖拽排序</span>
							<span>随站点一起发布</span>
						</div>
					</div>
				</article>

				<article class="surface-card widget-card widget-card--interview">
					<div class="widget-card__header">
						<p class="widget-card__eyebrow">Interview</p>
						<div class="widget-card__title-row">
							<div>
								<h2>面经整理</h2>
								<p>把面试题和自己的回答集中整理成一页，支持关键词搜索，输入后只显示匹配题目，后面追加 JSON 就能扩充。</p>
							</div>
							<a class="button secondary widget-card__link" href={interviewNotesHref}>进入面经页</a>
						</div>
					</div>

					<div class="featured-entry-panel featured-entry-panel--interview" aria-label="面经整理入口">
						<div class="featured-entry-panel__copy">
							<p>适合长期积累高频题、标准回答思路和补充追问。页面左侧固定搜索区，右侧按卡片展示每道题。</p>
						</div>
						<div class="featured-entry-panel__meta" aria-label="面经整理特性">
							<span>关键词搜索</span>
							<span>即时过滤</span>
							<span>JSON 维护</span>
							<span>站内入口</span>
						</div>
					</div>
				</article>

				<article class="surface-card widget-card widget-card--gallery">
					<div class="widget-card__header">
						<p class="widget-card__eyebrow">Gallery</p>
						<div class="widget-card__title-row">
							<div>
								<h2>图片库</h2>
								<p>这里不再放预览图，保留一个清晰入口，点击后直接进入独立图片库页面。</p>
							</div>
						</div>
					</div>

					<div class="gallery-entry-panel" aria-label="图片库入口">
						<p>打开后会进入完整图片库页面，统一查看所有图片内容。</p>
						<a class="button secondary widget-card__link" href="/gallery">进入图片库</a>
					</div>
				</article>

				<article class="surface-card widget-card widget-card--reviews">
					<div class="widget-card__header">
						<p class="widget-card__eyebrow">Reviews</p>
						<h2>游戏 / 动漫评分与评论</h2>
						<p>这里会自动读取 <code>src/content/reviews</code> 里的 MDX 文件，点击条目就能进入详情页。</p>
					</div>
					<div class="review-list">
						{
							mediaReviews.map((item) => (
								<a class="review-card" href={`/reviews/${item.id}/`}>
									<div class="review-card__meta">
										<p class="review-card__type">{item.data.mediaType}</p>
										<h3>{item.data.title}</h3>
									</div>
									<div class="review-card__score">
										<span>{item.data.score.toFixed(1)}</span>
										<small>/ 10</small>
									</div>
								</a>
							))
						}
					</div>
				</article>

				<article class="surface-card widget-card widget-card--notes">
					<div class="widget-card__header">
						<p class="widget-card__eyebrow">Next Widgets</p>
						<h2>这个页面后面还能放什么</h2>
					</div>
					<ul class="widget-note-list">
						{
							widgetNotes.map((note) => (
								<li>{note}</li>
							))
						}
					</ul>
				</article>

				<article class="surface-card widget-card widget-card--tracker">
					<div class="widget-card__header">
						<p class="widget-card__eyebrow">Tracker</p>
						<h2>最近想补上的小模块</h2>
					</div>
					<div class="tracker-list">
						<div class="tracker-item">
							<strong>图片分类</strong>
							<span>后面可以继续把插画、截图、横幅素材拆成不同子分类。</span>
						</div>
						<div class="tracker-item">
							<strong>评分数据化</strong>
							<span>把评分和评论改成单独文件，后续新增会比直接写死在页面里更舒服。</span>
						</div>
						<div class="tracker-item">
							<strong>更多收藏</strong>
							<span>后面可以继续加音乐、壁纸、角色偏好和游玩记录。</span>
						</div>
					</div>
				</article>
			</section>
		</main>
		<Footer />
	</body>
</html>

<style>
	.extras-page {
		display: grid;
		gap: 1rem;
	}

	.extras-hero,
	.widget-card {
		padding: clamp(1.35rem, 2vw, 1.9rem);
	}

	.extras-hero {
		display: grid;
		grid-template-columns: minmax(0, 1.2fr) minmax(16rem, 0.8fr);
		gap: 1rem;
		align-items: stretch;
	}

	.extras-hero__copy {
		display: grid;
		gap: 0.95rem;
	}

	.extras-hero__copy h1 {
		margin-bottom: 0;
		font-size: clamp(2.2rem, 4vw, 3.8rem);
	}

	.extras-hero__copy p:last-child,
	.widget-card__header p {
		margin: 0;
		color: var(--color-subtext);
	}

	.extras-hero__chips {
		display: flex;
		flex-wrap: wrap;
		align-content: start;
		gap: 0.65rem;
		padding: 1rem;
		border: 1px solid rgba(153, 230, 255, 0.42);
		border-radius: 24px;
		background:
			radial-gradient(circle at top left, rgba(204, 255, 255, 0.5), transparent 45%),
			linear-gradient(135deg, rgba(255, 255, 255, 0.88), rgba(230, 250, 255, 0.72));
	}

	.extras-hero__chips span {
		display: inline-flex;
		align-items: center;
		padding: 0.48rem 0.86rem;
		border-radius: 999px;
		background: rgba(255, 255, 255, 0.78);
		border: 1px solid rgba(153, 230, 255, 0.5);
		color: var(--color-link-hover);
		font-size: 0.84rem;
		font-weight: 700;
	}

	.extras-grid {
		display: grid;
		grid-template-columns: repeat(12, minmax(0, 1fr));
		gap: 1rem;
	}

	.widget-card {
		display: grid;
		gap: 1rem;
	}

	.widget-card--gallery {
		grid-column: span 7;
	}

	.widget-card--cheat-sheet {
		grid-column: 1 / -1;
	}

	.widget-card--interview {
		grid-column: 1 / -1;
	}

	.widget-card--reviews {
		grid-column: span 5;
	}

	.widget-card--notes,
	.widget-card--tracker {
		grid-column: span 6;
	}

	.widget-card__header {
		display: grid;
		gap: 0.35rem;
	}

	.widget-card__header h2 {
		margin: 0;
		font-size: clamp(1.5rem, 2.2vw, 2rem);
	}

	.widget-card__eyebrow {
		margin: 0;
		font-size: 0.82rem;
		font-weight: 700;
		letter-spacing: 0.12em;
		text-transform: uppercase;
		color: var(--color-subtext);
	}

	.widget-card__title-row {
		display: flex;
		align-items: flex-end;
		justify-content: space-between;
		gap: 1rem;
	}

	.widget-card__link {
		flex: 0 0 auto;
	}

	.gallery-entry-panel {
		display: grid;
		justify-items: start;
		gap: 1rem;
		padding: clamp(1.3rem, 2vw, 1.8rem);
		border: 1px solid rgba(187, 231, 245, 0.72);
		border-radius: 26px;
		background:
			radial-gradient(circle at top left, rgba(204, 255, 255, 0.46), transparent 48%),
			linear-gradient(135deg, rgba(255, 255, 255, 0.94), rgba(238, 248, 252, 0.92));
		box-shadow:
			0 18px 36px rgba(112, 159, 176, 0.1),
			inset 0 1px 0 rgba(255, 255, 255, 0.84);
	}

	.featured-entry-panel {
		display: grid;
		grid-template-columns: minmax(0, 1.2fr) auto;
		gap: 1rem;
		align-items: center;
		padding: clamp(1.3rem, 2vw, 1.8rem);
		border: 1px solid rgba(187, 231, 245, 0.78);
		border-radius: 26px;
		background:
			radial-gradient(circle at top left, rgba(204, 255, 255, 0.56), transparent 44%),
			linear-gradient(135deg, rgba(255, 255, 255, 0.96), rgba(255, 244, 204, 0.46));
		box-shadow:
			0 18px 36px rgba(112, 159, 176, 0.1),
			inset 0 1px 0 rgba(255, 255, 255, 0.84);
	}

	.featured-entry-panel--interview {
		background:
			radial-gradient(circle at top left, rgba(255, 214, 232, 0.32), transparent 44%),
			linear-gradient(135deg, rgba(255, 255, 255, 0.96), rgba(230, 250, 255, 0.84));
	}

	.featured-entry-panel__copy p,
	.gallery-entry-panel p {
		margin: 0;
		color: var(--color-subtext);
		line-height: 1.7;
	}

	.featured-entry-panel__meta {
		display: flex;
		flex-wrap: wrap;
		justify-content: flex-end;
		gap: 0.65rem;
	}

	.featured-entry-panel__meta span {
		display: inline-flex;
		align-items: center;
		padding: 0.5rem 0.82rem;
		border-radius: 999px;
		background: rgba(255, 255, 255, 0.82);
		border: 1px solid rgba(153, 230, 255, 0.5);
		color: var(--color-link-hover);
		font-size: 0.84rem;
		font-weight: 700;
	}

	.review-list,
	.tracker-list {
		display: grid;
		gap: 0.72rem;
	}

	.review-card,
	.tracker-item {
		display: grid;
		padding: 1rem;
		border: 1px solid var(--color-border);
		border-radius: 22px;
		background: rgba(255, 255, 255, 0.78);
	}

	.review-card {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 1rem;
		padding-block: 0.95rem;
		color: inherit;
		text-decoration: none;
		transition:
			transform 180ms ease,
			border-color 180ms ease,
			box-shadow 180ms ease;
	}

	.review-card:hover {
		transform: translateY(-2px);
		border-color: rgba(153, 230, 255, 0.76);
		box-shadow: 0 16px 28px rgba(112, 159, 176, 0.11);
	}

	.review-card__meta {
		display: grid;
		gap: 0.24rem;
	}

	.review-card__type {
		margin: 0;
		color: var(--color-subtext);
		font-size: 0.74rem;
		font-weight: 700;
		letter-spacing: 0.12em;
		text-transform: uppercase;
	}

	.review-card h3 {
		margin: 0;
		font-size: 1.02rem;
		line-height: 1.3;
	}

	.review-card__score {
		display: inline-flex;
		align-items: baseline;
		gap: 0.1rem;
		padding: 0.45rem 0.7rem;
		border-radius: 18px;
		background: linear-gradient(135deg, rgba(204, 255, 255, 0.78), rgba(255, 214, 232, 0.54));
		color: var(--color-link-hover);
		font-weight: 700;
	}

	.review-card__score span {
		font-size: 1.28rem;
		line-height: 1;
	}

	.review-card__score small {
		font-size: 0.74rem;
	}

	.widget-note-list {
		display: grid;
		gap: 0.9rem;
		margin: 0;
		padding-left: 1.15rem;
	}

	.widget-note-list li::marker {
		color: var(--accent);
	}

	.tracker-item strong {
		font-size: 1rem;
	}

	.tracker-item span {
		color: var(--color-subtext);
		line-height: 1.6;
	}

	@media (max-width: 980px) {
		.extras-hero,
		.extras-grid {
			grid-template-columns: 1fr;
		}

		.widget-card--gallery,
		.widget-card--reviews,
		.widget-card--notes,
		.widget-card--tracker {
			grid-column: auto;
		}
	}

	@media (max-width: 720px) {
		.extras-hero,
		.widget-card {
			padding: 1.15rem;
		}

		.widget-card__title-row {
			flex-direction: column;
			align-items: flex-start;
		}

		.featured-entry-panel {
			grid-template-columns: 1fr;
		}

		.featured-entry-panel__meta {
			justify-content: flex-start;
		}

		.review-card {
			align-items: flex-start;
		}
	}
</style>
