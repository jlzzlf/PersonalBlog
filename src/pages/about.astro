---
import { getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_TITLE } from '../consts';
import { galleryItems } from '../data/gallery';

const pageTitle = `更多 | ${SITE_TITLE}`;
const galleryPreviewItems = galleryItems.slice(0, 4);
const mediaReviews = (await getCollection('reviews'))
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
	.slice(0, 4);
const galleryPreviewFallbackJson = JSON.stringify(galleryItems);

const widgetNotes = [
	'图片库现在只在这里展示少量预览图，完整内容会进入独立图库页。',
	'评分与评论现在已经支持独立 MDX 文件，后面直接新增内容就行。',
	'如果还想扩展，这一页也适合继续加收藏夹、追番清单和游玩记录。',
];
---

<!doctype html>
<html lang="zh-CN">
	<head>
		<BaseHead title={pageTitle} description="更多页面：放一些图片收藏、评分评论和杂项小组件。" />
	</head>
	<body>
		<Header />
		<main class="extras-page">
			<section class="surface-card extras-hero">
				<div class="extras-hero__copy">
					<p class="eyebrow">More</p>
					<h1>把一些不适合放首页，但又很想保留的内容，集中放在这里。</h1>
					<p>
						这个页面现在更像一个杂项实验区。后面可以慢慢加上图片库、评分评论、收藏记录，或者别的轻量小组件，让它变成更有生活感的角落。
					</p>
				</div>
				<div class="extras-hero__chips" aria-label="页面内容概览">
					<span>图片库预览</span>
					<span>游戏 / 动漫评分</span>
					<span>短评记录</span>
					<span>杂项小组件</span>
				</div>
			</section>

			<section class="extras-grid">
				<article class="surface-card widget-card widget-card--gallery">
					<div class="widget-card__header">
						<p class="widget-card__eyebrow">Gallery</p>
						<div class="widget-card__title-row">
							<div>
								<h2>图片库</h2>
								<p>这里只放几张预览图，点击后进入独立图片库页面查看照片墙。</p>
							</div>
							<a class="button secondary widget-card__link" href="/gallery">进入图片库</a>
						</div>
					</div>

					<div class="gallery-preview-grid" aria-label="图片库预览" data-gallery-preview-grid data-preview-limit="4">
						{
							galleryPreviewItems.map((item) => (
								<a class="gallery-preview-item" href="/gallery" aria-label="打开图片库">
									<img src={item.src} alt={item.alt} loading="lazy" decoding="async" />
								</a>
							))
						}
					</div>
				</article>

				<article class="surface-card widget-card widget-card--reviews">
					<div class="widget-card__header">
						<p class="widget-card__eyebrow">Reviews</p>
						<h2>游戏 / 动漫评分与评论</h2>
						<p>这里会自动读取 <code>src/content/reviews</code> 里的 MDX 文件，点击条目就能进入详情页。</p>
					</div>
					<div class="review-list">
						{
							mediaReviews.map((item) => (
								<a class="review-card" href={`/reviews/${item.id}/`}>
									<div class="review-card__meta">
										<p class="review-card__type">{item.data.mediaType}</p>
										<h3>{item.data.title}</h3>
									</div>
									<div class="review-card__score">
										<span>{item.data.score.toFixed(1)}</span>
										<small>/ 10</small>
									</div>
								</a>
							))
						}
					</div>
				</article>

				<article class="surface-card widget-card widget-card--notes">
					<div class="widget-card__header">
						<p class="widget-card__eyebrow">Next Widgets</p>
						<h2>这个页面后面还能放什么</h2>
					</div>
					<ul class="widget-note-list">
						{
							widgetNotes.map((note) => (
								<li>{note}</li>
							))
						}
					</ul>
				</article>

				<article class="surface-card widget-card widget-card--tracker">
					<div class="widget-card__header">
						<p class="widget-card__eyebrow">Tracker</p>
						<h2>最近想补上的小模块</h2>
					</div>
					<div class="tracker-list">
						<div class="tracker-item">
							<strong>图片分类</strong>
							<span>后面可以继续把插画、截图、横幅素材拆成不同子分类。</span>
						</div>
						<div class="tracker-item">
							<strong>评分数据化</strong>
							<span>把评分和评论改成单独文件，后续新增会比直接写死在页面里更舒服。</span>
						</div>
						<div class="tracker-item">
							<strong>更多收藏</strong>
							<span>后面可以继续加音乐、壁纸、角色偏好和游玩记录。</span>
						</div>
					</div>
				</article>
			</section>
		</main>
		<Footer />
		<script type="application/json" data-gallery-preview-fallback set:html={galleryPreviewFallbackJson}></script>

		<script is:inline>
			(() => {
				const root = document.querySelector('[data-gallery-preview-grid]');
				const fallback = document.querySelector('[data-gallery-preview-fallback]');
				if (!(root instanceof HTMLElement)) return;

				const previewLimit = Number(root.dataset.previewLimit || '4');
				const fallbackItems =
					fallback instanceof HTMLScriptElement && fallback.textContent ? JSON.parse(fallback.textContent) : [];

				const pickRandomItems = (items, limit) => {
					const shuffled = [...items];
					for (let index = shuffled.length - 1; index > 0; index -= 1) {
						const swapIndex = Math.floor(Math.random() * (index + 1));
						[shuffled[index], shuffled[swapIndex]] = [shuffled[swapIndex], shuffled[index]];
					}
					return shuffled.slice(0, Math.min(limit, shuffled.length));
				};

				const createPreviewLink = (item) => {
					const link = document.createElement('a');
					link.href = '/gallery';
					link.className = 'gallery-preview-item';
					link.setAttribute('aria-label', '打开图片库');

					const image = document.createElement('img');
					image.src = item.src;
					image.alt = item.alt || '图片库预览图';
					image.loading = 'lazy';
					image.decoding = 'async';

					link.append(image);
					return link;
				};

				const renderPreview = (items) => {
					root.replaceChildren(...pickRandomItems(items, previewLimit).map((item) => createPreviewLink(item)));
				};

				if (Array.isArray(fallbackItems) && fallbackItems.length > 0) {
					renderPreview(fallbackItems);
				}

				fetch('/api/gallery', { headers: { Accept: 'application/json' } })
					.then((response) => (response.ok ? response.json() : null))
					.then((data) => {
						if (!data || !Array.isArray(data.images) || data.images.length === 0) return;
						renderPreview(data.images);
					})
					.catch(() => {
						// Keep the static preview as a fallback when the runtime API is unavailable.
					});
			})();
		</script>
	</body>
</html>

<style>
	.extras-page {
		display: grid;
		gap: 1rem;
	}

	.extras-hero,
	.widget-card {
		padding: clamp(1.35rem, 2vw, 1.9rem);
	}

	.extras-hero {
		display: grid;
		grid-template-columns: minmax(0, 1.2fr) minmax(16rem, 0.8fr);
		gap: 1rem;
		align-items: stretch;
	}

	.extras-hero__copy {
		display: grid;
		gap: 0.95rem;
	}

	.extras-hero__copy h1 {
		margin-bottom: 0;
		font-size: clamp(2.2rem, 4vw, 3.8rem);
	}

	.extras-hero__copy p:last-child,
	.widget-card__header p {
		margin: 0;
		color: var(--color-subtext);
	}

	.extras-hero__chips {
		display: flex;
		flex-wrap: wrap;
		align-content: start;
		gap: 0.65rem;
		padding: 1rem;
		border: 1px solid rgba(153, 230, 255, 0.42);
		border-radius: 24px;
		background:
			radial-gradient(circle at top left, rgba(204, 255, 255, 0.5), transparent 45%),
			linear-gradient(135deg, rgba(255, 255, 255, 0.88), rgba(230, 250, 255, 0.72));
	}

	.extras-hero__chips span {
		display: inline-flex;
		align-items: center;
		padding: 0.48rem 0.86rem;
		border-radius: 999px;
		background: rgba(255, 255, 255, 0.78);
		border: 1px solid rgba(153, 230, 255, 0.5);
		color: var(--color-link-hover);
		font-size: 0.84rem;
		font-weight: 700;
	}

	.extras-grid {
		display: grid;
		grid-template-columns: repeat(12, minmax(0, 1fr));
		gap: 1rem;
	}

	.widget-card {
		display: grid;
		gap: 1rem;
	}

	.widget-card--gallery {
		grid-column: span 7;
	}

	.widget-card--reviews {
		grid-column: span 5;
	}

	.widget-card--notes,
	.widget-card--tracker {
		grid-column: span 6;
	}

	.widget-card__header {
		display: grid;
		gap: 0.35rem;
	}

	.widget-card__header h2 {
		margin: 0;
		font-size: clamp(1.5rem, 2.2vw, 2rem);
	}

	.widget-card__eyebrow {
		margin: 0;
		font-size: 0.82rem;
		font-weight: 700;
		letter-spacing: 0.12em;
		text-transform: uppercase;
		color: var(--color-subtext);
	}

	.widget-card__title-row {
		display: flex;
		align-items: flex-end;
		justify-content: space-between;
		gap: 1rem;
	}

	.widget-card__link {
		flex: 0 0 auto;
	}

	.gallery-preview-grid {
		display: grid;
		grid-template-columns: repeat(2, minmax(0, 1fr));
		gap: 0.95rem;
		align-self: start;
	}

	.gallery-preview-item {
		display: block;
		min-width: 0;
		overflow: hidden;
		aspect-ratio: 1 / 1;
		border-radius: 24px;
		border: 1px solid rgba(187, 231, 245, 0.72);
		background:
			linear-gradient(180deg, rgba(255, 255, 255, 0.96), rgba(239, 248, 253, 0.92)),
			radial-gradient(circle at top left, rgba(214, 255, 255, 0.45), transparent 55%);
		box-shadow: 0 18px 36px rgba(112, 159, 176, 0.1);
		transition:
			transform 180ms ease,
			box-shadow 180ms ease,
			border-color 180ms ease;
	}

	.gallery-preview-item:hover {
		transform: translateY(-3px);
		border-color: rgba(153, 230, 255, 0.76);
		box-shadow: 0 22px 40px rgba(112, 159, 176, 0.14);
	}

	.gallery-preview-item img {
		display: block;
		width: 100%;
		height: 100%;
		object-fit: cover;
		background: linear-gradient(180deg, rgba(248, 252, 255, 0.9), rgba(232, 244, 249, 0.86));
	}

	.review-list,
	.tracker-list {
		display: grid;
		gap: 0.72rem;
	}

	.review-card,
	.tracker-item {
		display: grid;
		padding: 1rem;
		border: 1px solid var(--color-border);
		border-radius: 22px;
		background: rgba(255, 255, 255, 0.78);
	}

	.review-card {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 1rem;
		padding-block: 0.95rem;
		color: inherit;
		text-decoration: none;
		transition:
			transform 180ms ease,
			border-color 180ms ease,
			box-shadow 180ms ease;
	}

	.review-card:hover {
		transform: translateY(-2px);
		border-color: rgba(153, 230, 255, 0.76);
		box-shadow: 0 16px 28px rgba(112, 159, 176, 0.11);
	}

	.review-card__meta {
		display: grid;
		gap: 0.24rem;
	}

	.review-card__type {
		margin: 0;
		color: var(--color-subtext);
		font-size: 0.74rem;
		font-weight: 700;
		letter-spacing: 0.12em;
		text-transform: uppercase;
	}

	.review-card h3 {
		margin: 0;
		font-size: 1.02rem;
		line-height: 1.3;
	}

	.review-card__score {
		display: inline-flex;
		align-items: baseline;
		gap: 0.1rem;
		padding: 0.45rem 0.7rem;
		border-radius: 18px;
		background: linear-gradient(135deg, rgba(204, 255, 255, 0.78), rgba(255, 214, 232, 0.54));
		color: var(--color-link-hover);
		font-weight: 700;
	}

	.review-card__score span {
		font-size: 1.28rem;
		line-height: 1;
	}

	.review-card__score small {
		font-size: 0.74rem;
	}

	.widget-note-list {
		display: grid;
		gap: 0.9rem;
		margin: 0;
		padding-left: 1.15rem;
	}

	.widget-note-list li::marker {
		color: var(--accent);
	}

	.tracker-item strong {
		font-size: 1rem;
	}

	.tracker-item span {
		color: var(--color-subtext);
		line-height: 1.6;
	}

	@media (max-width: 980px) {
		.extras-hero,
		.extras-grid {
			grid-template-columns: 1fr;
		}

		.widget-card--gallery,
		.widget-card--reviews,
		.widget-card--notes,
		.widget-card--tracker {
			grid-column: auto;
		}
	}

	@media (max-width: 720px) {
		.extras-hero,
		.widget-card {
			padding: 1.15rem;
		}

		.widget-card__title-row {
			flex-direction: column;
			align-items: flex-start;
		}

		.review-card {
			align-items: flex-start;
		}
	}
</style>
