---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_TITLE } from '../consts';

const pageTitle = `关于 | ${SITE_TITLE}`;

const cards = [
	{
		title: '这个博客会写什么',
		text: '以学习笔记、项目实践和阶段性思考为主，也会保留一点生活气息，让它更像真正属于自己的空间。',
	},
	{
		title: '为什么先从首页开始',
		text: '首页决定了站点的整体气质，也决定后面新增模块时有没有统一的视觉与结构基础。',
	},
	{
		title: '接下来会继续补什么',
		text: '个人介绍、项目展示、内容分类、联系入口，以及一些更细的页面动效与排版细节。',
	},
];
---

<!doctype html>
<html lang="zh-CN">
	<head>
		<BaseHead title={pageTitle} description="关于这个博客与后续建设方向。" />
	</head>
	<body>
		<Header />
		<main class="about-page">
			<section class="surface-card about-hero">
				<p class="eyebrow">About This Blog</p>
				<h1>这里会慢慢长成一个更像“我”的地方。</h1>
				<p>
					当前版本先专注于干净的内容表达和稳定的页面结构。后面我们可以继续把它扩展成一个完整的
					个人博客主页，让每次新增内容都自然地融入这个站点。
				</p>
			</section>

			<section class="about-grid">
				{
					cards.map((card) => (
						<article class="surface-card about-card">
							<h2>{card.title}</h2>
							<p>{card.text}</p>
						</article>
					))
				}
			</section>
		</main>
		<Footer />
	</body>
</html>

<style>
	.about-page {
		display: grid;
		gap: 1.4rem;
	}

	.about-hero,
	.about-card {
		padding: clamp(1.5rem, 2vw, 2rem);
	}

	.about-hero {
		max-width: 56rem;
	}

	.about-hero p:last-child,
	.about-card p:last-child {
		margin-bottom: 0;
		color: rgb(var(--gray));
	}

	.about-grid {
		display: grid;
		grid-template-columns: repeat(3, minmax(0, 1fr));
		gap: 1rem;
	}

	.about-card h2 {
		font-size: 1.45rem;
	}

	@media (max-width: 860px) {
		.about-grid {
			grid-template-columns: 1fr;
		}
	}
</style>
