---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_TITLE } from '../consts';
import { galleryItems } from '../data/gallery';

const pageTitle = `更多 | ${SITE_TITLE}`;
const galleryPreviewItems = galleryItems.slice(0, 4);
const galleryPreviewFallbackJson = JSON.stringify(galleryPreviewItems);
const previewFramePresets = [
	{ tilt: '-1.8deg', lift: '0px' },
	{ tilt: '1.35deg', lift: '1px' },
	{ tilt: '-0.95deg', lift: '-4px' },
	{ tilt: '2.2deg', lift: '2px' },
];

const getPreviewFrameStyle = (index: number) => {
	const preset = previewFramePresets[index % previewFramePresets.length];
	return `--frame-tilt: ${preset.tilt}; --frame-lift: ${preset.lift};`;
};

const mediaReviews = [
	{
		type: '动画',
		title: '葬送的芙莉莲',
		score: 9.4,
		comment: '节奏很稳，画面和情绪留白都很舒服，是那种会想慢慢看下去的作品。',
		tags: ['氛围感', '旅行感', '角色关系'],
	},
	{
		type: '游戏',
		title: '吸血鬼幸存者',
		score: 9.1,
		comment: '反馈非常快，成长节奏抓人，短时间内就能让人进入“再来一局”的状态。',
		tags: ['成长循环', '反馈强', '高重复游玩'],
	},
	{
		type: '动画',
		title: '孤独摇滚！',
		score: 8.9,
		comment: '角色演出很有记忆点，夸张和真实之间平衡得很好，能量很足。',
		tags: ['演出', '角色塑造', '轻松感'],
	},
];

const widgetNotes = [
	'图片库现在只在这里展示少量预览图，完整内容会进入独立图库页。',
	'评分与评论后面可以继续改成单独数据源，方便持续补充。',
	'如果还想扩展，这一页也适合继续加收藏夹、追番清单和游玩记录。',
];
---

<!doctype html>
<html lang="zh-CN">
	<head>
		<BaseHead title={pageTitle} description="更多页面：放一些图片收藏、评分评论和杂项小组件。" />
	</head>
	<body>
		<Header />
		<main class="extras-page">
			<section class="surface-card extras-hero">
				<div class="extras-hero__copy">
					<p class="eyebrow">More</p>
					<h1>把一些不适合放首页，但又很想保留的内容，集中放在这里。</h1>
					<p>
						这个页面现在更像一个杂项实验区。后面可以慢慢加上图片库、评分评论、收藏记录，或者别的轻量小组件，让它变成更有生活感的角落。
					</p>
				</div>
				<div class="extras-hero__chips" aria-label="页面内容概览">
					<span>图片库预览</span>
					<span>游戏 / 动漫评分</span>
					<span>短评记录</span>
					<span>杂项小组件</span>
				</div>
			</section>

			<section class="extras-grid">
				<article class="surface-card widget-card widget-card--gallery">
					<div class="widget-card__header">
						<p class="widget-card__eyebrow">Gallery</p>
						<div class="widget-card__title-row">
							<div>
								<h2>图片库</h2>
								<p>这里只放几张预览图，点击后进入独立图片库页面查看照片墙。</p>
							</div>
							<a class="button secondary widget-card__link" href="/gallery">进入图片库</a>
						</div>
					</div>

					<div class="gallery-preview-grid" aria-label="图片库预览" data-gallery-preview-grid data-preview-limit="4">
						{
							galleryPreviewItems.map((item, index) => (
								<a class="gallery-preview-item" href="/gallery" aria-label="打开图片库" style={getPreviewFrameStyle(index)}>
									<img src={item.src} alt={item.alt} loading="lazy" decoding="async" />
								</a>
							))
						}
					</div>
				</article>

				<article class="surface-card widget-card widget-card--reviews">
					<div class="widget-card__header">
						<p class="widget-card__eyebrow">Reviews</p>
						<h2>游戏 / 动漫评分与评论</h2>
						<p>以后这里可以像“迷你评分墙”一样，持续补充看过或玩过的内容。</p>
					</div>
					<div class="review-list">
						{
							mediaReviews.map((item) => (
								<article class="review-card">
									<div class="review-card__top">
										<div>
											<p class="review-card__type">{item.type}</p>
											<h3>{item.title}</h3>
										</div>
										<div class="review-card__score">
											<span>{item.score.toFixed(1)}</span>
											<small>/ 10</small>
										</div>
									</div>
									<p class="review-card__comment">{item.comment}</p>
									<div class="review-card__tags" aria-label="评价关键词">
										{
											item.tags.map((tag) => (
												<span>{tag}</span>
											))
										}
									</div>
								</article>
							))
						}
					</div>
				</article>

				<article class="surface-card widget-card widget-card--notes">
					<div class="widget-card__header">
						<p class="widget-card__eyebrow">Next Widgets</p>
						<h2>这个页面后面还能放什么</h2>
					</div>
					<ul class="widget-note-list">
						{
							widgetNotes.map((note) => (
								<li>{note}</li>
							))
						}
					</ul>
				</article>

				<article class="surface-card widget-card widget-card--tracker">
					<div class="widget-card__header">
						<p class="widget-card__eyebrow">Tracker</p>
						<h2>最近想补上的小模块</h2>
					</div>
					<div class="tracker-list">
						<div class="tracker-item">
							<strong>图片分类</strong>
							<span>后面可以继续把插画、截图、横幅素材拆成不同子分类。</span>
						</div>
						<div class="tracker-item">
							<strong>评分数据化</strong>
							<span>把评分和评论改成单独文件，后续新增会比直接写死在页面里更舒服。</span>
						</div>
						<div class="tracker-item">
							<strong>更多收藏</strong>
							<span>后面可以继续加音乐、壁纸、角色偏好和游玩记录。</span>
						</div>
					</div>
				</article>
			</section>
		</main>
		<Footer />
		<script type="application/json" data-gallery-preview-fallback set:html={galleryPreviewFallbackJson}></script>

		<script is:inline>
			(() => {
				const root = document.querySelector('[data-gallery-preview-grid]');
				const fallback = document.querySelector('[data-gallery-preview-fallback]');
				if (!(root instanceof HTMLElement)) return;

				const previewLimit = Number(root.dataset.previewLimit || '4');
				const fallbackItems =
					fallback instanceof HTMLScriptElement && fallback.textContent ? JSON.parse(fallback.textContent) : [];

				const shuffleItems = (items) => {
					const shuffled = [...items];
					for (let index = shuffled.length - 1; index > 0; index -= 1) {
						const swapIndex = Math.floor(Math.random() * (index + 1));
						[shuffled[index], shuffled[swapIndex]] = [shuffled[swapIndex], shuffled[index]];
					}
					return shuffled;
				};

				const applyRandomFrame = (element) => {
					const tilt = (Math.random() * 5.4 - 2.7).toFixed(2);
					const lift = (Math.random() * 10 - 5).toFixed(1);
					element.style.setProperty('--frame-tilt', `${tilt}deg`);
					element.style.setProperty('--frame-lift', `${lift}px`);
				};

				const createPreviewLink = (item) => {
					const link = document.createElement('a');
					link.href = '/gallery';
					link.className = 'gallery-preview-item';
					link.setAttribute('aria-label', '打开图片库');
					applyRandomFrame(link);

					const image = document.createElement('img');
					image.src = item.src;
					image.alt = item.alt || '图片库预览图';
					image.loading = 'lazy';
					image.decoding = 'async';

					link.append(image);
					return link;
				};

				const renderPreview = (items) => {
					root.replaceChildren(...shuffleItems(items).slice(0, previewLimit).map((item) => createPreviewLink(item)));
				};

				if (Array.isArray(fallbackItems) && fallbackItems.length > 0) {
					renderPreview(fallbackItems);
				}

				fetch('/api/gallery', { headers: { Accept: 'application/json' } })
					.then((response) => (response.ok ? response.json() : null))
					.then((data) => {
						if (!data || !Array.isArray(data.images) || data.images.length === 0) return;
						renderPreview(data.images);
					})
					.catch(() => {
						// Keep the static preview as a fallback when the runtime API is unavailable.
					});
			})();
		</script>
	</body>
</html>

<style>
	.extras-page {
		display: grid;
		gap: 1rem;
	}

	.extras-hero,
	.widget-card {
		padding: clamp(1.35rem, 2vw, 1.9rem);
	}

	.extras-hero {
		display: grid;
		grid-template-columns: minmax(0, 1.2fr) minmax(16rem, 0.8fr);
		gap: 1rem;
		align-items: stretch;
	}

	.extras-hero__copy {
		display: grid;
		gap: 0.95rem;
	}

	.extras-hero__copy h1 {
		margin-bottom: 0;
		font-size: clamp(2.2rem, 4vw, 3.8rem);
	}

	.extras-hero__copy p:last-child,
	.widget-card__header p,
	.review-card__comment {
		margin: 0;
		color: var(--color-subtext);
	}

	.extras-hero__chips {
		display: flex;
		flex-wrap: wrap;
		align-content: start;
		gap: 0.65rem;
		padding: 1rem;
		border: 1px solid rgba(153, 230, 255, 0.42);
		border-radius: 24px;
		background:
			radial-gradient(circle at top left, rgba(204, 255, 255, 0.5), transparent 45%),
			linear-gradient(135deg, rgba(255, 255, 255, 0.88), rgba(230, 250, 255, 0.72));
	}

	.extras-hero__chips span {
		display: inline-flex;
		align-items: center;
		padding: 0.48rem 0.86rem;
		border-radius: 999px;
		background: rgba(255, 255, 255, 0.78);
		border: 1px solid rgba(153, 230, 255, 0.5);
		color: var(--color-link-hover);
		font-size: 0.84rem;
		font-weight: 700;
	}

	.extras-grid {
		display: grid;
		grid-template-columns: repeat(12, minmax(0, 1fr));
		gap: 1rem;
	}

	.widget-card {
		display: grid;
		gap: 1rem;
	}

	.widget-card--gallery {
		grid-column: span 7;
	}

	.widget-card--reviews {
		grid-column: span 5;
	}

	.widget-card--notes,
	.widget-card--tracker {
		grid-column: span 6;
	}

	.widget-card__header {
		display: grid;
		gap: 0.35rem;
	}

	.widget-card__header h2 {
		margin: 0;
		font-size: clamp(1.5rem, 2.2vw, 2rem);
	}

	.widget-card__eyebrow {
		margin: 0;
		font-size: 0.82rem;
		font-weight: 700;
		letter-spacing: 0.12em;
		text-transform: uppercase;
		color: var(--color-subtext);
	}

	.widget-card__title-row {
		display: flex;
		align-items: flex-end;
		justify-content: space-between;
		gap: 1rem;
	}

	.widget-card__link {
		flex: 0 0 auto;
	}

	.gallery-preview-grid {
		column-count: 3;
		column-gap: 1rem;
		align-self: start;
	}

	.gallery-preview-item {
		display: block;
		position: relative;
		margin: 0 0 1rem;
		padding: 0.7rem;
		break-inside: avoid;
		overflow: hidden;
		border-radius: 28px;
		border: 1px solid rgba(187, 231, 245, 0.72);
		background:
			linear-gradient(180deg, rgba(255, 255, 255, 0.98), rgba(239, 248, 253, 0.92)),
			radial-gradient(circle at top left, rgba(214, 255, 255, 0.5), transparent 55%);
		box-shadow:
			0 18px 36px rgba(112, 159, 176, 0.12),
			inset 0 1px 0 rgba(255, 255, 255, 0.82);
		transform: translateY(var(--frame-lift, 0px)) rotate(var(--frame-tilt, 0deg));
		transition:
			transform 180ms ease,
			box-shadow 180ms ease,
			border-color 180ms ease;
	}

	.gallery-preview-item::before {
		content: '';
		position: absolute;
		top: 0.8rem;
		left: 50%;
		width: 3rem;
		height: 0.45rem;
		border-radius: 999px;
		background: rgba(255, 255, 255, 0.72);
		transform: translateX(-50%);
		box-shadow: 0 2px 10px rgba(112, 159, 176, 0.08);
		pointer-events: none;
	}

	.gallery-preview-item:hover {
		transform: translateY(calc(var(--frame-lift, 0px) - 5px)) rotate(var(--frame-tilt, 0deg));
		border-color: rgba(153, 230, 255, 0.76);
		box-shadow:
			0 24px 42px rgba(112, 159, 176, 0.16),
			inset 0 1px 0 rgba(255, 255, 255, 0.84);
	}

	.gallery-preview-item img {
		display: block;
		width: 100%;
		height: auto;
		border-radius: 20px;
		background: linear-gradient(180deg, rgba(248, 252, 255, 0.9), rgba(232, 244, 249, 0.86));
	}

	.review-list,
	.tracker-list {
		display: grid;
		gap: 0.8rem;
	}

	.review-card,
	.tracker-item {
		display: grid;
		gap: 0.7rem;
		padding: 1rem;
		border: 1px solid var(--color-border);
		border-radius: 22px;
		background: rgba(255, 255, 255, 0.78);
	}

	.review-card__top {
		display: flex;
		align-items: flex-start;
		justify-content: space-between;
		gap: 0.85rem;
	}

	.review-card__type {
		margin: 0 0 0.3rem;
		color: var(--color-subtext);
		font-size: 0.74rem;
		font-weight: 700;
		letter-spacing: 0.12em;
		text-transform: uppercase;
	}

	.review-card h3 {
		margin: 0;
		font-size: 1.2rem;
	}

	.review-card__score {
		display: inline-flex;
		align-items: baseline;
		gap: 0.1rem;
		padding: 0.45rem 0.7rem;
		border-radius: 18px;
		background: linear-gradient(135deg, rgba(204, 255, 255, 0.78), rgba(255, 214, 232, 0.54));
		color: var(--color-link-hover);
		font-weight: 700;
	}

	.review-card__score span {
		font-size: 1.28rem;
		line-height: 1;
	}

	.review-card__score small {
		font-size: 0.74rem;
	}

	.review-card__tags {
		display: flex;
		flex-wrap: wrap;
		gap: 0.45rem;
	}

	.review-card__tags span {
		display: inline-flex;
		align-items: center;
		padding: 0.34rem 0.68rem;
		border-radius: 999px;
		background: rgba(230, 250, 255, 0.82);
		border: 1px solid rgba(153, 230, 255, 0.45);
		color: var(--color-link-hover);
		font-size: 0.78rem;
		font-weight: 700;
	}

	.widget-note-list {
		display: grid;
		gap: 0.9rem;
		margin: 0;
		padding-left: 1.15rem;
	}

	.widget-note-list li::marker {
		color: var(--accent);
	}

	.tracker-item strong {
		font-size: 1rem;
	}

	.tracker-item span {
		color: var(--color-subtext);
		line-height: 1.6;
	}

	@media (max-width: 980px) {
		.extras-hero,
		.extras-grid {
			grid-template-columns: 1fr;
		}

		.widget-card--gallery,
		.widget-card--reviews,
		.widget-card--notes,
		.widget-card--tracker {
			grid-column: auto;
		}
	}

	@media (max-width: 720px) {
		.extras-hero,
		.widget-card {
			padding: 1.15rem;
		}

		.widget-card__title-row {
			flex-direction: column;
			align-items: flex-start;
		}

		.gallery-preview-grid {
			column-count: 2;
		}

		.gallery-preview-item {
			margin-bottom: 0.85rem;
		}

		.review-card__top {
			flex-direction: column;
		}
	}

	@media (max-width: 520px) {
		.gallery-preview-grid {
			column-count: 1;
		}
	}
</style>
