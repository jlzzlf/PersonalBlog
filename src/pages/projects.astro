---
import { getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_TITLE } from '../consts';
import { sortProjectEntries } from '../lib/projects';

const pageTitle = `项目展示 | ${SITE_TITLE}`;
const entries = sortProjectEntries(await getCollection('projects'));

const tagCountMap = entries.reduce((map, entry) => {
	for (const tag of entry.data.tags ?? []) {
		map.set(tag, (map.get(tag) ?? 0) + 1);
	}

	return map;
}, new Map<string, number>());
const allTags = Array.from(tagCountMap.entries())
	.sort((first, second) => second[1] - first[1] || first[0].localeCompare(second[0], 'zh-CN'))
	.map(([tag, count]) => ({ tag, count }));

const getCoverImageAttrs = (coverImage: (typeof entries)[number]['data']['coverImage']) => {
	if (!coverImage) return null;
	if (typeof coverImage === 'string') return { src: coverImage };
	return {
		src: coverImage.src,
		width: coverImage.width,
		height: coverImage.height,
	};
};

const getTagColorStyle = (tag: string) => {
	let hash = 0;
	for (const character of tag) {
		hash = (hash * 33 + character.charCodeAt(0)) >>> 0;
	}

	const variants = [
		{
			bg: 'rgba(230, 250, 255, 0.9)',
			border: 'rgba(153, 230, 255, 0.56)',
			color: 'var(--color-link-hover)',
		},
		{
			bg: 'rgba(255, 214, 232, 0.62)',
			border: 'rgba(255, 214, 232, 0.92)',
			color: '#7a4961',
		},
		{
			bg: 'rgba(255, 244, 204, 0.72)',
			border: 'rgba(255, 244, 204, 0.94)',
			color: '#7a6212',
		},
		{
			bg: 'rgba(204, 255, 255, 0.82)',
			border: 'rgba(153, 230, 255, 0.72)',
			color: 'var(--color-link-hover)',
		},
	];
	const variant = variants[hash % variants.length];
	return `--tag-bg: ${variant.bg}; --tag-border: ${variant.border}; --tag-color: ${variant.color};`;
};

const projectCards = entries.map((entry) => ({
	entry,
	href: `/projects/${entry.id}/`,
	coverImage: getCoverImageAttrs(entry.data.coverImage),
	tagsAttr: JSON.stringify(entry.data.tags ?? []),
}));
---

<!doctype html>
<html lang="zh-CN">
	<head>
		<BaseHead title={pageTitle} description="浏览独立项目与技术实践。" />
	</head>
	<body>
		<Header />
		<main class="projects-page" data-project-index>
			<section class="blog-hero projects-hero" aria-labelledby="projects-page-title">
				<p class="blog-kicker">Project Showcase</p>
				<h1 id="projects-page-title">项目展示</h1>
			</section>

			<div class="blog-shell projects-shell">
				<section class="blog-list projects-list" aria-label="项目列表">
					{
						projectCards.map(({ entry, href, coverImage, tagsAttr }) => (
							<article class="surface-card blog-card project-card" data-project-card data-tags={tagsAttr}>
								<a class="blog-card__link project-card__link" href={href}>
									{
										coverImage ? (
											<img
												class="blog-card__image project-card__image"
												src={coverImage.src}
												width={coverImage.width}
												height={coverImage.height}
												alt=""
												loading="lazy"
												decoding="async"
											/>
										) : (
											<div class="blog-card__image project-card__placeholder" aria-hidden="true">
												<span>{entry.data.title.slice(0, 2)}</span>
											</div>
										)
									}
									<div class="blog-card__content project-card__content">
										<div class="blog-card__meta">
											<span class="blog-card__category">{entry.data.status}</span>
											<p class="blog-card__date">{entry.data.year}</p>
										</div>
										<h2>{entry.data.title}</h2>
										<p class="blog-card__description">{entry.data.summary}</p>
										{
											entry.data.stack.length > 0 && (
												<p class="project-card__stack">{entry.data.stack.join(' / ')}</p>
											)
										}
										{
											entry.data.tags.length > 0 && (
												<div class="blog-card__tags project-card__tags" aria-label="项目标签">
													{
														entry.data.tags.map((tag) => (
															<span class="blog-card__tag" style={getTagColorStyle(tag)}>
																{tag}
															</span>
														))
													}
												</div>
											)
										}
									</div>
								</a>
							</article>
						))
					}
				</section>

				{
					allTags.length > 0 && (
						<aside class="blog-sidebar project-sidebar" aria-label="项目标签筛选">
							<section class="blog-tag-filter" data-project-tag-filter>
								<div class="blog-tag-filter__toolbar">
									<div class="blog-tag-filter__heading">
										<strong>标签筛选</strong>
										<span class="blog-tag-filter__summary" data-project-tag-summary>全部标签</span>
									</div>
									<button
										type="button"
										class="blog-tag-filter__clear"
										data-project-tag-clear
										hidden
									>
										清空
									</button>
								</div>
								<p class="blog-filter-status" data-project-filter-status>当前显示全部项目。</p>
								<div class="blog-tag-filter__selected" data-project-selected-tags hidden></div>
								<div class="blog-tag-picker" data-project-tag-picker>
									<div class="blog-tag-picker__list" data-project-tag-options>
										{
											allTags.map(({ tag, count }) => (
												<label
													class="blog-tag-option"
													data-project-tag-option
													data-tag-option={tag}
													style={getTagColorStyle(tag)}
												>
													<input type="checkbox" value={tag} data-project-tag-checkbox />
													<span class="blog-tag-option__swatch" aria-hidden="true"></span>
													<span class="blog-tag-option__name">{tag}</span>
													<span class="blog-tag-option__count">{count}</span>
												</label>
											))
										}
									</div>
								</div>
							</section>
						</aside>
					)
				}
			</div>

			<p class="blog-empty project-empty" data-project-empty hidden>当前标签下还没有项目。</p>
		</main>
		<Footer />
	</body>
</html>

<script is:inline>
	(() => {
		const PROJECT_INDEX_STATE_KEY = '__joylifeProjectIndexState';
		const state = (window[PROJECT_INDEX_STATE_KEY] ??= {
			bound: false,
			cleanup: null,
			activeTags: [],
		});

		const mountProjectIndex = () => {
			if (typeof state.cleanup === 'function') {
				state.cleanup();
				state.cleanup = null;
			}

			const root = document.querySelector('[data-project-index]');
			if (!(root instanceof HTMLElement)) return;

			const tagClearButton = root.querySelector('[data-project-tag-clear]');
			const tagOptions = Array.from(root.querySelectorAll('[data-project-tag-option]'));
			const tagCheckboxes = Array.from(root.querySelectorAll('[data-project-tag-checkbox]'));
			const selectedTags = root.querySelector('[data-project-selected-tags]');
			const tagSummary = root.querySelector('[data-project-tag-summary]');
			const cards = Array.from(root.querySelectorAll('[data-project-card]'));
			const status = root.querySelector('[data-project-filter-status]');
			const emptyState = root.querySelector('[data-project-empty]');

			if (!(emptyState instanceof HTMLElement)) return;

			const getTagColorStyleValue = (tag) => {
				let hash = 0;
				for (const character of tag) {
					hash = (hash * 33 + character.charCodeAt(0)) >>> 0;
				}

				const variants = [
					{
						bg: 'rgba(230, 250, 255, 0.9)',
						border: 'rgba(153, 230, 255, 0.56)',
						color: 'var(--color-link-hover)',
					},
					{
						bg: 'rgba(255, 214, 232, 0.62)',
						border: 'rgba(255, 214, 232, 0.92)',
						color: '#7a4961',
					},
					{
						bg: 'rgba(255, 244, 204, 0.72)',
						border: 'rgba(255, 244, 204, 0.94)',
						color: '#7a6212',
					},
					{
						bg: 'rgba(204, 255, 255, 0.82)',
						border: 'rgba(153, 230, 255, 0.72)',
						color: 'var(--color-link-hover)',
					},
				];
				const variant = variants[hash % variants.length];
				return `--tag-bg: ${variant.bg}; --tag-border: ${variant.border}; --tag-color: ${variant.color};`;
			};

			const availableTags = new Set(
				tagCheckboxes
					.map((checkbox) => (checkbox instanceof HTMLInputElement ? checkbox.value : ''))
					.filter(Boolean),
			);
			let activeTags = new Set(
				Array.isArray(state.activeTags)
					? state.activeTags.filter((tag) => typeof tag === 'string' && availableTags.has(tag))
					: [],
			);

			const readCardTags = (card) => {
				if (!(card instanceof HTMLElement)) return [];
				try {
					const parsed = JSON.parse(card.dataset.tags || '[]');
					return Array.isArray(parsed) ? parsed : [];
				} catch {
					return [];
				}
			};

			const syncState = () => {
				state.activeTags = Array.from(activeTags);
			};

			const renderSelectedTags = () => {
				if (!(selectedTags instanceof HTMLElement)) return;
				selectedTags.replaceChildren();

				const selectedList = Array.from(activeTags);
				selectedTags.hidden = selectedList.length === 0;

				for (const tag of selectedList) {
					const button = document.createElement('button');
					button.type = 'button';
					button.className = 'blog-selected-tag';
					button.dataset.removeTag = tag;
					button.style.cssText = getTagColorStyleValue(tag);
					button.setAttribute('aria-label', `移除标签 ${tag}`);
					button.textContent = tag;

					const close = document.createElement('span');
					close.className = 'blog-selected-tag__remove';
					close.setAttribute('aria-hidden', 'true');
					close.textContent = '×';
					button.append(close);

					selectedTags.append(button);
				}
			};

			const applyFilter = () => {
				tagCheckboxes.forEach((checkbox) => {
					if (!(checkbox instanceof HTMLInputElement)) return;
					checkbox.checked = activeTags.has(checkbox.value);
					const option = checkbox.closest('[data-project-tag-option]');
					if (option instanceof HTMLElement) {
						option.classList.toggle('active', checkbox.checked);
					}
				});

				let visibleCount = 0;
				cards.forEach((card) => {
					if (!(card instanceof HTMLElement)) return;
					const cardTags = readCardTags(card);
					const matches =
						activeTags.size === 0 ||
						Array.from(activeTags).every((tag) => cardTags.includes(tag));
					card.hidden = !matches;
					if (matches) {
						visibleCount += 1;
					}
				});

				const selectedTagList = Array.from(activeTags);
				if (tagSummary instanceof HTMLElement) {
					tagSummary.textContent =
						selectedTagList.length === 0
							? '全部标签'
							: `已选 ${selectedTagList.length} 个`;
				}
				if (tagClearButton instanceof HTMLButtonElement) {
					tagClearButton.hidden = selectedTagList.length === 0;
				}

				renderSelectedTags();
				tagOptions.forEach((option) => {
					if (option instanceof HTMLElement) {
						option.hidden = false;
					}
				});

				if (status instanceof HTMLElement) {
					status.textContent =
						selectedTagList.length === 0
							? '当前显示全部项目。'
							: `当前包含 ${selectedTagList.map((tag) => `“${tag}”`).join(' / ')}，共 ${visibleCount} 个项目。`;
				}
				emptyState.textContent =
					selectedTagList.length === 0 ? '这里还没有发布项目。' : '当前标签下还没有项目。';
				emptyState.hidden = visibleCount > 0;
				syncState();
			};

			const handleTagChange = (event) => {
				const checkbox = event.currentTarget;
				if (!(checkbox instanceof HTMLInputElement)) return;
				if (checkbox.checked) {
					activeTags.add(checkbox.value);
				} else {
					activeTags.delete(checkbox.value);
				}
				applyFilter();
			};

			const handleClearTags = () => {
				if (activeTags.size === 0) return;
				activeTags.clear();
				applyFilter();
			};

			const handleSelectedTagClick = (event) => {
				const target = event.target;
				if (!(target instanceof HTMLElement)) return;
				const removeButton = target.closest('[data-remove-tag]');
				if (!(removeButton instanceof HTMLButtonElement)) return;
				const tag = removeButton.dataset.removeTag;
				if (!tag || !activeTags.has(tag)) return;
				activeTags.delete(tag);
				applyFilter();
			};

			if (tagClearButton instanceof HTMLButtonElement) {
				tagClearButton.addEventListener('click', handleClearTags);
			}

			if (selectedTags instanceof HTMLElement) {
				selectedTags.addEventListener('click', handleSelectedTagClick);
			}

			tagCheckboxes.forEach((checkbox) => {
				if (!(checkbox instanceof HTMLInputElement)) return;
				checkbox.addEventListener('change', handleTagChange);
			});

			applyFilter();

			state.cleanup = () => {
				if (tagClearButton instanceof HTMLButtonElement) {
					tagClearButton.removeEventListener('click', handleClearTags);
				}

				if (selectedTags instanceof HTMLElement) {
					selectedTags.removeEventListener('click', handleSelectedTagClick);
				}

				tagCheckboxes.forEach((checkbox) => {
					if (!(checkbox instanceof HTMLInputElement)) return;
					checkbox.removeEventListener('change', handleTagChange);
				});
			};
		};

		if (!state.bound) {
			state.bound = true;
			document.addEventListener('astro:page-load', mountProjectIndex);
			document.addEventListener('astro:before-swap', () => {
				if (typeof state.cleanup === 'function') {
					state.cleanup();
					state.cleanup = null;
				}
			});
		}

		mountProjectIndex();
	})();
</script>

<style>
	.projects-page {
		display: grid;
		gap: clamp(2rem, 4vw, 3.2rem);
	}

	.projects-hero {
		max-width: 48rem;
		padding: clamp(0.6rem, 2vw, 1.4rem) 0 0.2rem;
	}

	.project-card__placeholder {
		display: grid;
		place-items: center;
		background:
			radial-gradient(circle at 20% 18%, rgba(255, 255, 255, 0.28), transparent 18%),
			linear-gradient(135deg, rgba(204, 255, 255, 0.72), rgba(255, 214, 232, 0.42));
	}

	.project-card__placeholder span {
		color: rgba(24, 72, 93, 0.78);
		font-size: clamp(1.3rem, 3vw, 2.2rem);
		font-weight: 700;
		letter-spacing: 0.1em;
	}

	.project-card__stack {
		margin: -0.2rem 0 0;
		color: var(--color-subtext);
		font-size: 0.88rem;
		line-height: 1.5;
	}

	.project-card[hidden],
	.project-empty[hidden] {
		display: none !important;
	}

	@media (max-width: 860px) {
		.project-card__placeholder {
			border-radius: 28px 28px 0 0;
		}
	}
</style>
