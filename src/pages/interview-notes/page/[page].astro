---
import BaseHead from '../../../components/BaseHead.astro';
import Footer from '../../../components/Footer.astro';
import Header from '../../../components/Header.astro';
import InterviewNotesView from '../../../components/views/InterviewNotesView.astro';
import { SITE_TITLE } from '../../../consts';
import { getInterviewNotes } from '../../../lib/interview-notes';
import { INTERVIEW_PAGE_SIZE, paginateItems } from '../../../lib/pagination';

export async function getStaticPaths() {
	const allNotes = getInterviewNotes();
	const firstPage = paginateItems(allNotes, INTERVIEW_PAGE_SIZE, 1);

	if (firstPage.totalPages <= 1) {
		return [];
	}

	return Array.from({ length: firstPage.totalPages - 1 }, (_, index) => {
		const currentPage = index + 2;
		const pagination = paginateItems(allNotes, INTERVIEW_PAGE_SIZE, currentPage);

		return {
			params: { page: String(currentPage) },
			props: { pagination },
		};
	});
}

const { pagination } = Astro.props;
const pageTitle = `面经整理 第 ${pagination.currentPage} 页 | ${SITE_TITLE}`;
---

<!doctype html>
<html lang="zh-CN">
	<head>
		<BaseHead
			title={pageTitle}
			description={`面经整理分页列表，第 ${pagination.currentPage} 页，共 ${pagination.totalPages} 页。`}
		/>
	</head>
	<body>
		<Header />
		<InterviewNotesView
			notes={pagination.items}
			currentPage={pagination.currentPage}
			totalPages={pagination.totalPages}
			totalItems={pagination.totalItems}
			basePath="/interview-notes"
			startIndex={(pagination.currentPage - 1) * INTERVIEW_PAGE_SIZE}
		/>
		<Footer />
	</body>
</html>
