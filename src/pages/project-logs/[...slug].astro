---
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
	const projectLogs = await getCollection('projectLogs');
	return projectLogs.map((projectLog) => ({
		params: { slug: projectLog.id },
		props: { redirectTo: `/projects/logs/${projectLog.id}/` },
	}));
}

const { redirectTo } = Astro.props;
// Project log IDs can contain Chinese characters. Redirect URLs become HTTP headers,
// so they must be percent-encoded before Astro creates the response.
return Astro.redirect(encodeURI(redirectTo), 301);
---
