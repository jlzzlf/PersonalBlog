---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_TITLE } from '../consts';

const pageTitle = `学习日报 | ${SITE_TITLE}`;

const sections = [
	{
		title: '今日学习',
		text: '这里以后可以按天记录学习任务、进度、遇到的问题和当天的总结，形成稳定的学习日志。',
	},
	{
		title: '复盘整理',
		text: '除了记录做了什么，也可以写清楚哪里卡住了、哪些方法有效、下一次准备怎么继续推进。',
	},
	{
		title: '积累方式',
		text: '后面如果需要，还能继续加日期筛选、标签分类和按主题归档，让学习记录变得更好查找。',
	},
];
---

<!doctype html>
<html lang="zh-CN">
	<head>
		<BaseHead title={pageTitle} description="学习日报页，占位用于后续整理学习记录与复盘。" />
	</head>
	<body>
		<Header />
		<main class="feature-page">
			<section class="surface-card feature-hero">
				<p class="eyebrow">Study Log</p>
				<h1>学习日报</h1>
				<p>
					这里后面适合放每天的学习记录。无论是课程笔记、做题进度、技术总结还是阶段复盘，都可以收进同一条时间线里。
				</p>
				<div class="feature-actions">
					<a class="button" href="/">返回首页</a>
					<a class="button secondary" href="/blog">查看博客</a>
				</div>
			</section>

			<section class="feature-grid">
				{
					sections.map((section) => (
						<article class="surface-card feature-card">
							<h2>{section.title}</h2>
							<p>{section.text}</p>
						</article>
					))
				}
			</section>
		</main>
		<Footer />
	</body>
</html>

<style>
	.feature-page {
		display: grid;
		gap: 1.4rem;
	}

	.feature-hero,
	.feature-card {
		padding: clamp(1.5rem, 2vw, 2rem);
	}

	.feature-hero {
		max-width: 62rem;
	}

	.feature-hero p:last-of-type,
	.feature-card p:last-child {
		margin-bottom: 0;
		color: rgb(var(--gray));
	}

	.feature-actions {
		display: flex;
		flex-wrap: wrap;
		gap: 0.8rem;
		margin-top: 1.4rem;
	}

	.feature-grid {
		display: grid;
		grid-template-columns: repeat(3, minmax(0, 1fr));
		gap: 1rem;
	}

	.feature-card h2 {
		font-size: 1.45rem;
	}

	@media (max-width: 860px) {
		.feature-grid {
			grid-template-columns: 1fr;
		}
	}
</style>
