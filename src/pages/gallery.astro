---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_TITLE } from '../consts';
import { galleryItems } from '../data/gallery';

const pageTitle = `图片库 | ${SITE_TITLE}`;
const galleryFallbackJson = JSON.stringify(galleryItems);
const photoFramePresets = [
	{ tilt: '-0.65deg', lift: '0px' },
	{ tilt: '0.8deg', lift: '-1px' },
	{ tilt: '-0.45deg', lift: '1px' },
	{ tilt: '0.95deg', lift: '1px' },
	{ tilt: '-0.9deg', lift: '0px' },
];

const getPhotoFrameStyle = (index: number) => {
	const preset = photoFramePresets[index % photoFramePresets.length];
	return `--frame-tilt: ${preset.tilt}; --frame-lift: ${preset.lift};`;
};
---

<!doctype html>
<html lang="zh-CN">
	<head>
		<BaseHead title={pageTitle} description="图片库页面，使用 R2 CDN 地址展示照片墙。" />
	</head>
	<body>
		<Header />
		<main class="gallery-page">
			<section class="surface-card gallery-hero">
				<div class="gallery-hero__copy">
					<p class="eyebrow">Gallery</p>
					<h1>图片库</h1>
					<p>这里是完整图片库页面，统一从 R2 CDN 地址读取图片，下面改成了混合网格加瀑布流的照片墙展示。</p>
				</div>
				<div class="gallery-hero__meta">
					<span data-gallery-count>{galleryItems.length} 张图片</span>
					<a class="button secondary" href="/about">返回更多</a>
				</div>
			</section>

			<section class="photo-wall" aria-label="图片墙" data-photo-wall>
				{
					galleryItems.map((item, index) => (
						<figure
							class="photo-wall__item photo-wall__item--ready"
							data-shape="square"
							style={`${getPhotoFrameStyle(index)} --photo-ratio: 4 / 5; grid-row-end: span 30;`}
						>
							<img src={item.src} alt={item.alt} loading="lazy" decoding="async" />
						</figure>
					))
				}
			</section>
		</main>
		<Footer />
		<script type="application/json" data-gallery-fallback set:html={galleryFallbackJson}></script>

		<script is:inline>
			(() => {
				const wall = document.querySelector('[data-photo-wall]');
				const count = document.querySelector('[data-gallery-count]');
				const fallback = document.querySelector('[data-gallery-fallback]');
				if (!(wall instanceof HTMLElement)) return;

				const fallbackItems =
					fallback instanceof HTMLScriptElement && fallback.textContent ? JSON.parse(fallback.textContent) : [];
				let resizeFrame = 0;

				const shuffleItems = (items) => {
					const shuffled = [...items];
					for (let index = shuffled.length - 1; index > 0; index -= 1) {
						const swapIndex = Math.floor(Math.random() * (index + 1));
						[shuffled[index], shuffled[swapIndex]] = [shuffled[swapIndex], shuffled[index]];
					}
					return shuffled;
				};

				const applyRandomFrame = (element) => {
					const tilt = (Math.random() * 2.2 - 1.1).toFixed(2);
					const lift = (Math.random() * 4 - 2).toFixed(1);
					element.style.setProperty('--frame-tilt', `${tilt}deg`);
					element.style.setProperty('--frame-lift', `${lift}px`);
				};

				const getShapeFromRatio = (ratio) => {
					if (ratio >= 1.85) return 'panorama';
					if (ratio >= 1.2) return 'landscape';
					if (ratio <= 0.76) return 'portrait';
					return 'square';
				};

				const measureItem = (figure, image) => {
					const styles = window.getComputedStyle(wall);
					const rowSize = Number.parseFloat(styles.gridAutoRows);
					const rowGap = Number.parseFloat(styles.rowGap);
					if (!Number.isFinite(rowSize) || rowSize <= 0) return;

					const figureStyles = window.getComputedStyle(figure);
					const paddingBlock =
						Number.parseFloat(figureStyles.paddingTop) + Number.parseFloat(figureStyles.paddingBottom);
					const imageHeight =
						image instanceof HTMLImageElement ? image.getBoundingClientRect().height : figure.scrollHeight;
					const contentHeight = Math.max(imageHeight + paddingBlock, 220);
					const span = Math.max(16, Math.ceil((contentHeight + rowGap) / (rowSize + rowGap)));
					figure.style.gridRowEnd = `span ${span}`;
					figure.classList.add('photo-wall__item--ready');
				};

				const applyImageLayout = (figure, image) => {
					const naturalWidth = image.naturalWidth || 4;
					const naturalHeight = image.naturalHeight || 5;
					const ratio = naturalWidth / naturalHeight;
					figure.dataset.shape = getShapeFromRatio(ratio);
					figure.style.setProperty('--photo-ratio', `${naturalWidth} / ${naturalHeight}`);
					window.requestAnimationFrame(() => measureItem(figure, image));
				};

				const scheduleRefresh = () => {
					window.cancelAnimationFrame(resizeFrame);
					resizeFrame = window.requestAnimationFrame(() => {
						const items = wall.querySelectorAll('.photo-wall__item');
						items.forEach((item) => {
							if (item instanceof HTMLElement) {
								const image = item.querySelector('img');
								measureItem(item, image instanceof HTMLImageElement ? image : undefined);
							}
						});
					});
				};

				const createWallItem = (item) => {
					const figure = document.createElement('figure');
					figure.className = 'photo-wall__item';
					figure.dataset.shape = 'square';
					figure.style.setProperty('--photo-ratio', '4 / 5');
					figure.style.gridRowEnd = 'span 30';
					applyRandomFrame(figure);

					const image = document.createElement('img');
					image.src = item.src;
					image.alt = item.alt || '图片库图片';
					image.loading = 'lazy';
					image.decoding = 'async';
					image.addEventListener(
						'load',
						() => {
							applyImageLayout(figure, image);
						},
						{ once: true },
					);
					image.addEventListener(
						'error',
						() => {
							figure.classList.add('photo-wall__item--ready');
							scheduleRefresh();
						},
						{ once: true },
					);

					if (image.complete && image.naturalWidth > 0) {
						applyImageLayout(figure, image);
					}

					figure.append(image);
					return figure;
				};

				const renderWall = (items) => {
					wall.replaceChildren(...shuffleItems(items).map((item) => createWallItem(item)));
					if (count instanceof HTMLElement) {
						count.textContent = `${items.length} 张图片`;
					}
					scheduleRefresh();
				};

				if (Array.isArray(fallbackItems) && fallbackItems.length > 0) {
					renderWall(fallbackItems);
				}

				fetch('/api/gallery', { headers: { Accept: 'application/json' } })
					.then((response) => (response.ok ? response.json() : null))
					.then((data) => {
						if (!data || !Array.isArray(data.images) || data.images.length === 0) return;
						renderWall(data.images);
					})
					.catch(() => {
						// Keep the static wall as a fallback when the runtime API is unavailable.
					});

				window.addEventListener('resize', scheduleRefresh, { passive: true });

				if ('ResizeObserver' in window) {
					const observer = new ResizeObserver(() => {
						scheduleRefresh();
					});
					observer.observe(wall);
				}
			})();
		</script>
	</body>
</html>

<style>
	.gallery-page {
		display: grid;
		gap: 1rem;
	}

	.gallery-hero {
		display: flex;
		flex-wrap: wrap;
		align-items: flex-end;
		justify-content: space-between;
		gap: 1rem;
		padding: clamp(1.35rem, 2vw, 1.9rem);
	}

	.gallery-hero__copy {
		display: grid;
		gap: 0.8rem;
		max-width: 42rem;
	}

	.gallery-hero__copy h1 {
		margin-bottom: 0;
	}

	.gallery-hero__copy p:last-child,
	.gallery-hero__meta span {
		margin: 0;
		color: var(--color-subtext);
	}

	.gallery-hero__meta {
		display: flex;
		flex-wrap: wrap;
		align-items: center;
		gap: 0.8rem;
	}

	.gallery-hero__meta span {
		font-size: 0.95rem;
		font-weight: 700;
	}

	.photo-wall {
		display: grid;
		grid-template-columns: repeat(12, minmax(0, 1fr));
		grid-auto-flow: dense;
		grid-auto-rows: 12px;
		gap: 1rem;
		align-items: start;
	}

	.photo-wall__item {
		position: relative;
		grid-column: span 4;
		margin: 0;
		overflow: hidden;
		padding: 0.85rem;
		border-radius: 30px;
		border: 1px solid rgba(187, 231, 245, 0.75);
		background:
			linear-gradient(180deg, rgba(255, 255, 255, 0.98), rgba(240, 248, 252, 0.92)),
			radial-gradient(circle at top left, rgba(204, 255, 255, 0.46), transparent 56%);
		box-shadow:
			0 20px 40px rgba(112, 159, 176, 0.12),
			inset 0 1px 0 rgba(255, 255, 255, 0.84);
		transform: translateY(var(--frame-lift, 0px)) rotate(var(--frame-tilt, 0deg));
		transition:
			transform 180ms ease,
			box-shadow 180ms ease,
			border-color 180ms ease;
	}

	.photo-wall__item[data-shape='portrait'] {
		grid-column: span 3;
	}

	.photo-wall__item[data-shape='landscape'] {
		grid-column: span 5;
	}

	.photo-wall__item[data-shape='panorama'] {
		grid-column: span 6;
	}

	.photo-wall__item::before {
		content: '';
		position: absolute;
		top: 0.95rem;
		left: 50%;
		width: 3.2rem;
		height: 0.5rem;
		border-radius: 999px;
		background: rgba(255, 255, 255, 0.72);
		transform: translateX(-50%);
		box-shadow: 0 2px 10px rgba(112, 159, 176, 0.08);
		pointer-events: none;
	}

	.photo-wall__item:hover {
		transform: translateY(calc(var(--frame-lift, 0px) - 4px)) rotate(var(--frame-tilt, 0deg));
		border-color: rgba(153, 230, 255, 0.82);
		box-shadow:
			0 24px 42px rgba(112, 159, 176, 0.15),
			inset 0 1px 0 rgba(255, 255, 255, 0.88);
	}

	.photo-wall__item img {
		display: block;
		width: 100%;
		height: auto;
		aspect-ratio: var(--photo-ratio, 4 / 5);
		object-fit: cover;
		border-radius: 22px;
		background: linear-gradient(180deg, rgba(248, 252, 255, 0.9), rgba(232, 244, 249, 0.86));
	}

	@media (max-width: 980px) {
		.photo-wall {
			grid-template-columns: repeat(8, minmax(0, 1fr));
			grid-auto-rows: 11px;
		}

		.photo-wall__item,
		.photo-wall__item[data-shape='square'],
		.photo-wall__item[data-shape='landscape'] {
			grid-column: span 4;
		}

		.photo-wall__item[data-shape='portrait'] {
			grid-column: span 3;
		}

		.photo-wall__item[data-shape='panorama'] {
			grid-column: span 8;
		}
	}

	@media (max-width: 720px) {
		.gallery-hero {
			padding: 1.15rem;
		}

		.photo-wall {
			grid-template-columns: repeat(4, minmax(0, 1fr));
			grid-auto-rows: 10px;
			gap: 0.8rem;
		}

		.photo-wall__item,
		.photo-wall__item[data-shape='portrait'],
		.photo-wall__item[data-shape='square'] {
			grid-column: span 2;
		}

		.photo-wall__item[data-shape='landscape'],
		.photo-wall__item[data-shape='panorama'] {
			grid-column: span 4;
		}
	}

	@media (max-width: 520px) {
		.photo-wall {
			grid-template-columns: repeat(2, minmax(0, 1fr));
			grid-auto-rows: 10px;
		}

		.photo-wall__item,
		.photo-wall__item[data-shape='portrait'],
		.photo-wall__item[data-shape='square'],
		.photo-wall__item[data-shape='landscape'],
		.photo-wall__item[data-shape='panorama'] {
			grid-column: span 2;
		}
	}
</style>
