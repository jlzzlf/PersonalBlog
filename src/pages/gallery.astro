---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_TITLE } from '../consts';
import { galleryItems } from '../data/gallery';

const pageTitle = `图片库 | ${SITE_TITLE}`;
const galleryFallbackJson = JSON.stringify(galleryItems);
---

<!doctype html>
<html lang="zh-CN">
	<head>
		<BaseHead title={pageTitle} description="图片库页面，使用 R2 CDN 地址展示照片墙。" />
	</head>
	<body>
		<Header />
		<main class="gallery-page">
			<section class="surface-card gallery-hero">
				<div class="gallery-hero__copy">
					<p class="eyebrow">Gallery</p>
					<h1>图片库</h1>
					<p>这里是完整图片库页面，统一从 R2 CDN 地址读取图片，下面改回更直接的瀑布流照片墙展示。</p>
				</div>
				<div class="gallery-hero__meta">
					<span data-gallery-count>{galleryItems.length} 张图片</span>
					<a class="button secondary" href="/about">返回更多</a>
				</div>
			</section>

			<section class="photo-wall" aria-label="图片墙" data-photo-wall>
				{
					galleryItems.map((item) => (
						<figure class="photo-wall__item">
							<div class="photo-wall__media">
								<img src={item.src} alt={item.alt} loading="lazy" decoding="async" />
							</div>
						</figure>
					))
				}
			</section>
		</main>
		<Footer />
		<script type="application/json" data-gallery-fallback set:html={galleryFallbackJson}></script>

		<script is:inline>
			(() => {
				const wall = document.querySelector('[data-photo-wall]');
				const count = document.querySelector('[data-gallery-count]');
				const fallback = document.querySelector('[data-gallery-fallback]');
				if (!(wall instanceof HTMLElement)) return;

				const fallbackItems =
					fallback instanceof HTMLScriptElement && fallback.textContent ? JSON.parse(fallback.textContent) : [];

				const shuffleItems = (items) => {
					const shuffled = [...items];
					for (let index = shuffled.length - 1; index > 0; index -= 1) {
						const swapIndex = Math.floor(Math.random() * (index + 1));
						[shuffled[index], shuffled[swapIndex]] = [shuffled[swapIndex], shuffled[index]];
					}
					return shuffled;
				};

				const createWallItem = (item) => {
					const figure = document.createElement('figure');
					figure.className = 'photo-wall__item';

					const media = document.createElement('div');
					media.className = 'photo-wall__media';

					const image = document.createElement('img');
					image.src = item.src;
					image.alt = item.alt || '图片库图片';
					image.loading = 'lazy';
					image.decoding = 'async';

					media.append(image);
					figure.append(media);
					return figure;
				};

				const renderWall = (items) => {
					wall.replaceChildren(...shuffleItems(items).map((item) => createWallItem(item)));
					if (count instanceof HTMLElement) {
						count.textContent = `${items.length} 张图片`;
					}
				};

				if (Array.isArray(fallbackItems) && fallbackItems.length > 0) {
					renderWall(fallbackItems);
				}

				fetch('/api/gallery', { headers: { Accept: 'application/json' } })
					.then((response) => (response.ok ? response.json() : null))
					.then((data) => {
						if (!data || !Array.isArray(data.images) || data.images.length === 0) return;
						renderWall(data.images);
					})
					.catch(() => {
						// Keep the static wall as a fallback when the runtime API is unavailable.
					});
			})();
		</script>
	</body>
</html>

<style>
	.gallery-page {
		display: grid;
		gap: 1rem;
	}

	.gallery-hero {
		display: flex;
		flex-wrap: wrap;
		align-items: flex-end;
		justify-content: space-between;
		gap: 1rem;
		padding: clamp(1.35rem, 2vw, 1.9rem);
	}

	.gallery-hero__copy {
		display: grid;
		gap: 0.8rem;
		max-width: 42rem;
	}

	.gallery-hero__copy h1 {
		margin-bottom: 0;
	}

	.gallery-hero__copy p:last-child,
	.gallery-hero__meta span {
		margin: 0;
		color: var(--color-subtext);
	}

	.gallery-hero__meta {
		display: flex;
		flex-wrap: wrap;
		align-items: center;
		gap: 0.8rem;
	}

	.gallery-hero__meta span {
		font-size: 0.95rem;
		font-weight: 700;
	}

	.photo-wall {
		column-count: 4;
		column-gap: 1rem;
	}

	.photo-wall__item {
		position: relative;
		display: block;
		margin: 0 0 1rem;
		break-inside: avoid;
		overflow: hidden;
		padding: 0.85rem;
		border-radius: 30px;
		border: 1px solid rgba(187, 231, 245, 0.75);
		background:
			linear-gradient(180deg, rgba(255, 255, 255, 0.98), rgba(240, 248, 252, 0.92)),
			radial-gradient(circle at top left, rgba(204, 255, 255, 0.46), transparent 56%);
		box-shadow:
			0 20px 40px rgba(112, 159, 176, 0.12),
			inset 0 1px 0 rgba(255, 255, 255, 0.84);
		transition:
			transform 180ms ease,
			box-shadow 180ms ease,
			border-color 180ms ease;
	}

	.photo-wall__item::before {
		content: '';
		position: absolute;
		top: 0.95rem;
		left: 50%;
		width: 3.2rem;
		height: 0.5rem;
		border-radius: 999px;
		background: rgba(255, 255, 255, 0.72);
		transform: translateX(-50%);
		box-shadow: 0 2px 10px rgba(112, 159, 176, 0.08);
		pointer-events: none;
	}

	.photo-wall__item:hover {
		transform: translateY(-4px);
		border-color: rgba(153, 230, 255, 0.82);
		box-shadow:
			0 26px 48px rgba(112, 159, 176, 0.16),
			inset 0 1px 0 rgba(255, 255, 255, 0.88);
	}

	.photo-wall__media {
		width: 100%;
		overflow: hidden;
		border-radius: 22px;
		background: linear-gradient(180deg, rgba(248, 252, 255, 0.9), rgba(232, 244, 249, 0.86));
	}

	.photo-wall__item img {
		display: block;
		width: 100%;
		height: auto;
	}

	@media (max-width: 980px) {
		.photo-wall {
			column-count: 3;
		}
	}

	@media (max-width: 720px) {
		.gallery-hero {
			padding: 1.15rem;
		}

		.photo-wall {
			column-count: 2;
			column-gap: 0.8rem;
		}
	}

	@media (max-width: 520px) {
		.photo-wall {
			column-count: 1;
		}
	}
</style>
