---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_TITLE } from '../consts';
import { galleryItems } from '../data/gallery';

const pageTitle = `图片库 | ${SITE_TITLE}`;
const galleryFallbackJson = JSON.stringify(galleryItems);
type GalleryItem = (typeof galleryItems)[number];

const createPhotoColumns = (items: GalleryItem[], columnCount: number) => {
	const totalColumns = Math.max(1, Math.min(columnCount, items.length || 1));
	const columns: GalleryItem[][] = Array.from({ length: totalColumns }, () => []);

	items.forEach((item, index) => {
		columns[index % totalColumns].push(item);
	});

	return columns;
};

const initialPhotoColumns = createPhotoColumns(galleryItems, 4);
---

<!doctype html>
<html lang="zh-CN">
	<head>
		<BaseHead title={pageTitle} description="图片库页面，使用 R2 CDN 地址展示照片墙。" />
	</head>
	<body>
		<Header />
		<main class="gallery-page">
			<section class="surface-card gallery-hero">
				<div class="gallery-hero__copy">
					<p class="eyebrow">Gallery</p>
					<h1>图片库</h1>
					<p>这里是完整图片库页面，统一从 R2 CDN 地址读取图片，下面会用按列滚动的动态瀑布流方式展示。</p>
				</div>
				<div class="gallery-hero__meta">
					<span data-gallery-count>{galleryItems.length} 张图片</span>
					<a class="button secondary" href="/about">返回更多</a>
				</div>
			</section>

			<section class="photo-flow" aria-label="图片墙" data-photo-flow>
				{
					initialPhotoColumns.map((columnItems, columnIndex) => (
						<div class="photo-column" data-direction={columnIndex % 2 === 0 ? 'down' : 'up'}>
							<div class="photo-column__track">
								<div class="photo-column__group" data-group="primary">
									{
										columnItems.map((item) => (
											<figure class="photo-card">
												<div class="photo-card__media">
													<img src={item.src} alt={item.alt} loading="lazy" decoding="async" />
												</div>
											</figure>
										))
									}
								</div>
								<div class="photo-column__group" aria-hidden="true">
									{
										columnItems.map((item) => (
											<figure class="photo-card" aria-hidden="true">
												<div class="photo-card__media">
													<img src={item.src} alt="" loading="lazy" decoding="async" />
												</div>
											</figure>
										))
									}
								</div>
							</div>
						</div>
					))
				}
			</section>
		</main>
		<Footer />
		<script type="application/json" data-gallery-fallback set:html={galleryFallbackJson}></script>

		<script is:inline>
			(() => {
				const flow = document.querySelector('[data-photo-flow]');
				const count = document.querySelector('[data-gallery-count]');
				const fallback = document.querySelector('[data-gallery-fallback]');
				if (!(flow instanceof HTMLElement)) return;

				const fallbackItems =
					fallback instanceof HTMLScriptElement && fallback.textContent ? JSON.parse(fallback.textContent) : [];
				let currentItems = Array.isArray(fallbackItems) ? fallbackItems : [];
				let currentColumnCount = 0;
				let measureFrame = 0;
				let animationFrame = 0;
				let lastTick = 0;
				let columnStates = [];

				const getColumnCount = () => {
					if (window.matchMedia('(max-width: 520px)').matches) return 1;
					if (window.matchMedia('(max-width: 720px)').matches) return 2;
					if (window.matchMedia('(max-width: 980px)').matches) return 3;
					return 4;
				};

				const splitIntoColumns = (items, columnCount) => {
					const totalColumns = Math.max(1, Math.min(columnCount, items.length || 1));
					const columns = Array.from({ length: totalColumns }, () => []);

					items.forEach((item, index) => {
						columns[index % totalColumns].push(item);
					});

					return columns;
				};

				const stopColumnAnimation = () => {
					window.cancelAnimationFrame(animationFrame);
					animationFrame = 0;
					lastTick = 0;
				};

				const applyColumnTransform = (state) => {
					if (!(state.track instanceof HTMLElement)) return;

					const translateY = state.direction === 'down' ? -state.distance + state.offset : -state.offset;
					state.track.style.transform = `translateY(${translateY}px)`;
				};

				const stepColumns = (timestamp) => {
					if (!columnStates.length) {
						stopColumnAnimation();
						return;
					}

					if (!lastTick) {
						lastTick = timestamp;
					}

					const delta = Math.min(48, timestamp - lastTick);
					lastTick = timestamp;

					columnStates.forEach((state) => {
						if (!Number.isFinite(state.distance) || state.distance <= 0) return;

						state.offset = (state.offset + (state.speed * delta) / 1000) % state.distance;
						applyColumnTransform(state);
					});

					animationFrame = window.requestAnimationFrame(stepColumns);
				};

				const startColumnAnimation = () => {
					stopColumnAnimation();
					if (!columnStates.length) return;
					animationFrame = window.requestAnimationFrame(stepColumns);
				};

				const measureColumns = () => {
					stopColumnAnimation();
					columnStates = [];

					const columns = flow.querySelectorAll('.photo-column');
					columns.forEach((column, columnIndex) => {
						if (!(column instanceof HTMLElement)) return;
						const track = column.querySelector('.photo-column__track');
						const primaryGroup = column.querySelector('[data-group="primary"]');
						if (!(track instanceof HTMLElement) || !(primaryGroup instanceof HTMLElement)) return;

						const trackStyles = window.getComputedStyle(track);
						const gap = Number.parseFloat(trackStyles.rowGap || trackStyles.gap || '0');
						const distance = primaryGroup.getBoundingClientRect().height + gap;
						if (!Number.isFinite(distance) || distance <= 0) return;

						const direction = column.dataset.direction === 'down' ? 'down' : 'up';
						const speed = 26 + columnIndex * 4;
						const offset = direction === 'down' ? 0 : 0;
						const state = { direction, distance, offset, speed, track };

						columnStates.push(state);
						applyColumnTransform(state);
					});

					startColumnAnimation();
				};

				const scheduleMeasure = () => {
					window.cancelAnimationFrame(measureFrame);
					measureFrame = window.requestAnimationFrame(() => {
						measureColumns();
					});
				};

				const createPhotoCard = (item, isClone = false) => {
					const figure = document.createElement('figure');
					figure.className = 'photo-card';
					if (isClone) {
						figure.setAttribute('aria-hidden', 'true');
					}

					const image = document.createElement('img');
					image.addEventListener(
						'load',
						() => {
							scheduleMeasure();
						},
						{ once: true },
					);
					image.alt = isClone ? '' : item.alt || '图片库图片';
					image.loading = 'lazy';
					image.decoding = 'async';
					image.src = item.src;

					const media = document.createElement('div');
					media.className = 'photo-card__media';

					media.append(image);
					figure.append(media);

					if (image.complete) {
						scheduleMeasure();
					}

					return figure;
				};

				const createPhotoColumn = (items, columnIndex) => {
					const column = document.createElement('div');
					column.className = 'photo-column';
					column.dataset.direction = columnIndex % 2 === 0 ? 'down' : 'up';

					const track = document.createElement('div');
					track.className = 'photo-column__track';

					const primaryGroup = document.createElement('div');
					primaryGroup.className = 'photo-column__group';
					primaryGroup.dataset.group = 'primary';

					const cloneGroup = document.createElement('div');
					cloneGroup.className = 'photo-column__group';
					cloneGroup.setAttribute('aria-hidden', 'true');

					items.forEach((item) => {
						primaryGroup.append(createPhotoCard(item));
						cloneGroup.append(createPhotoCard(item, true));
					});

					track.append(primaryGroup, cloneGroup);
					column.append(track);
					return column;
				};

				const renderFlow = (items) => {
					currentItems = Array.isArray(items) ? items : [];
					const columnCount = Math.max(1, Math.min(getColumnCount(), currentItems.length || 1));
					currentColumnCount = columnCount;
					const columns = splitIntoColumns(currentItems, columnCount);

					stopColumnAnimation();
					flow.replaceChildren(...columns.map((columnItems, columnIndex) => createPhotoColumn(columnItems, columnIndex)));
					if (count instanceof HTMLElement) {
						count.textContent = `${items.length} 张图片`;
					}
					scheduleMeasure();
				};

				if (Array.isArray(fallbackItems) && fallbackItems.length > 0) {
					renderFlow(fallbackItems);
				}

				fetch('/api/gallery', { headers: { Accept: 'application/json' } })
					.then((response) => (response.ok ? response.json() : null))
					.then((data) => {
						if (!data || !Array.isArray(data.images) || data.images.length === 0) return;
						renderFlow(data.images);
					})
					.catch(() => {
						// Keep the static wall as a fallback when the runtime API is unavailable.
					});

				window.addEventListener(
					'resize',
					() => {
						const nextColumnCount = Math.max(1, Math.min(getColumnCount(), currentItems.length || 1));
						if (nextColumnCount !== currentColumnCount) {
							renderFlow(currentItems);
							return;
						}

						scheduleMeasure();
					},
					{ passive: true },
				);

				document.addEventListener('visibilitychange', () => {
					if (document.hidden) {
						stopColumnAnimation();
						return;
					}

					scheduleMeasure();
				});

				if ('ResizeObserver' in window) {
					const observer = new ResizeObserver(() => {
						scheduleMeasure();
					});
					observer.observe(flow);
				}
			})();
		</script>
	</body>
</html>

<style>
	.gallery-page {
		display: grid;
		gap: 1rem;
	}

	.gallery-hero {
		display: flex;
		flex-wrap: wrap;
		align-items: flex-end;
		justify-content: space-between;
		gap: 1rem;
		padding: clamp(1.35rem, 2vw, 1.9rem);
	}

	.gallery-hero__copy {
		display: grid;
		gap: 0.8rem;
		max-width: 42rem;
	}

	.gallery-hero__copy h1 {
		margin-bottom: 0;
	}

	.gallery-hero__copy p:last-child,
	.gallery-hero__meta span {
		margin: 0;
		color: var(--color-subtext);
	}

	.gallery-hero__meta {
		display: flex;
		flex-wrap: wrap;
		align-items: center;
		gap: 0.8rem;
	}

	.gallery-hero__meta span {
		font-size: 0.95rem;
		font-weight: 700;
	}

	.photo-flow {
		--photo-flow-gap: 1rem;
		display: grid;
		grid-template-columns: repeat(4, minmax(0, 1fr));
		gap: var(--photo-flow-gap);
		height: clamp(24rem, 58vh, 34rem);
		overflow: hidden;
		align-items: stretch;
		mask-image: linear-gradient(to bottom, transparent 0%, black 6%, black 94%, transparent 100%);
		-webkit-mask-image: linear-gradient(to bottom, transparent 0%, black 6%, black 94%, transparent 100%);
	}

	.photo-column {
		min-width: 0;
		overflow: hidden;
	}

	.photo-column__track {
		display: flex;
		flex-direction: column;
		gap: var(--photo-flow-gap);
		will-change: transform;
		transform: translateY(0);
	}

	.photo-column__group {
		display: grid;
		gap: var(--photo-flow-gap);
	}

	.photo-card {
		margin: 0;
		padding: 0.8rem;
		border-radius: 28px;
		border: 1px solid rgba(187, 231, 245, 0.74);
		background:
			linear-gradient(180deg, rgba(255, 255, 255, 0.98), rgba(240, 248, 252, 0.92)),
			radial-gradient(circle at top left, rgba(204, 255, 255, 0.44), transparent 56%);
		box-shadow:
			0 18px 36px rgba(112, 159, 176, 0.12),
			inset 0 1px 0 rgba(255, 255, 255, 0.84);
		transition:
			transform 180ms ease,
			box-shadow 180ms ease,
			border-color 180ms ease;
	}

	.photo-card:hover {
		transform: translateY(-3px);
		border-color: rgba(153, 230, 255, 0.82);
		box-shadow:
			0 22px 42px rgba(112, 159, 176, 0.16),
			inset 0 1px 0 rgba(255, 255, 255, 0.88);
	}

	.photo-card__media {
		width: 100%;
		overflow: hidden;
		border-radius: 22px;
		background: linear-gradient(180deg, rgba(248, 252, 255, 0.9), rgba(232, 244, 249, 0.86));
	}

	.photo-card img {
		display: block;
		width: 100%;
		height: auto;
	}

	@media (max-width: 980px) {
		.photo-flow {
			grid-template-columns: repeat(3, minmax(0, 1fr));
			height: clamp(22rem, 54vh, 30rem);
		}
	}

	@media (max-width: 720px) {
		.gallery-hero {
			padding: 1.15rem;
		}

		.photo-flow {
			--photo-flow-gap: 0.8rem;
			grid-template-columns: repeat(2, minmax(0, 1fr));
			height: clamp(20rem, 50vh, 26rem);
		}
	}

	@media (max-width: 520px) {
		.photo-flow {
			grid-template-columns: 1fr;
			height: clamp(18rem, 46vh, 22rem);
		}
	}

</style>
