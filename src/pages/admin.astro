---
const pageTitle = '博客后台';
---

<!doctype html>
<html lang="zh-CN">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<meta name="robots" content="noindex,nofollow,noarchive" />
		<title>{pageTitle}</title>
		<style>
			:root {
				color-scheme: light;
				--color-bg: #f8feff;
				--color-primary: #ccffff;
				--color-primary-soft: #e6faff;
				--color-primary-deep: #99e6ff;
				--color-text: #1f2937;
				--color-subtext: #6b7280;
				--color-border: #e0f2f7;
				--color-accent-pink: #ffd6e8;
				--color-accent-yellow: #fff4cc;
				--shadow-strong: 0 30px 64px rgba(112, 159, 176, 0.16);
				font-family:
					"Atkinson",
					"PingFang SC",
					"Hiragino Sans GB",
					"Microsoft YaHei",
					sans-serif;
				background:
					radial-gradient(circle at 18% 0%, rgba(204, 255, 255, 0.9) 0, rgba(204, 255, 255, 0) 30%),
					radial-gradient(circle at 82% 12%, rgba(255, 214, 232, 0.22) 0, rgba(255, 214, 232, 0) 24%),
					linear-gradient(180deg, #f8feff 0%, #f5fcfe 54%, #f8feff 100%);
				color: var(--color-text);
			}

			body {
				margin: 0;
				min-height: 100vh;
				background: transparent;
			}

			.shell {
				box-sizing: border-box;
				display: grid;
				place-items: center;
				min-height: 100vh;
				padding: 2rem;
			}

			.panel {
				width: min(36rem, 100%);
				border: 1px solid var(--color-border);
				border-radius: 28px;
				background: linear-gradient(180deg, rgba(255, 255, 255, 0.92), rgba(242, 253, 255, 0.84));
				box-shadow: var(--shadow-strong);
				padding: 2rem;
			}

			h1 {
				margin: 0 0 0.75rem;
				font-size: clamp(1.8rem, 4vw, 2.5rem);
				line-height: 1;
			}

			p {
				margin: 0;
				line-height: 1.65;
				color: var(--color-subtext);
			}

			.status {
				margin-top: 1.25rem;
				padding-top: 1.25rem;
				border-top: 1px solid var(--color-border);
				color: var(--color-text);
			}
		</style>
	</head>
	<body>
		<div id="cms-shell" class="shell">
			<div class="panel">
				<h1>{pageTitle}</h1>
				<p>正在加载写作后台并校验运行时配置。</p>
				<p id="cms-status" class="status">如果这里停留太久，请检查 Cloudflare Pages 的环境变量、后台访问密码和 GitHub OAuth 配置。</p>
			</div>
		</div>

		<script>
			import CMS from 'decap-cms-app';

			const shell = document.getElementById('cms-shell');
			const status = document.getElementById('cms-status');

			async function initCms() {
				try {
					const response = await fetch('/api/cms/config', {
						headers: { Accept: 'application/json' },
					});
					const payload = await response.json().catch(() => ({}));

					if (!response.ok) {
						if (response.status === 401) {
							throw new Error(
								'后台接口已启用密码保护。请刷新页面，并在浏览器弹出的登录框里输入 CMS_ADMIN_USERNAME 和 CMS_ADMIN_PASSWORD。',
							);
						}

						if (response.status === 404) {
							throw new Error(
								'你现在运行的是 Astro 本地开发服务器，/api/cms 这组 Cloudflare Pages Functions 还没有启动。请直接访问 /admin 看入口；如果要测试登录，请先 npm run build，再运行 npx wrangler pages dev dist。',
							);
						}

						throw new Error(payload.message ?? '无法读取 CMS 配置。');
					}

					CMS.init({ config: payload });
					shell?.remove();
				} catch (error) {
					if (status) {
						status.textContent = error instanceof Error ? error.message : '后台加载失败。';
					}
				}
			}

			void initCms();
		</script>
	</body>
</html>
