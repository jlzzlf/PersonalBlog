---
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import Header from '../../components/Header.astro';
import BlogIndexView from '../../components/views/BlogIndexView.astro';
import { SITE_TITLE } from '../../consts';
import { getSortedBlogEntries } from '../../lib/blog';
import { BLOG_PAGE_SIZE, paginateItems } from '../../lib/pagination';

const pageTitle = `技术博客 | ${SITE_TITLE}`;
const allPosts = await getSortedBlogEntries();
const pagination = paginateItems(allPosts, BLOG_PAGE_SIZE, 1);
---

<!doctype html>
<html lang="zh-CN">
	<head>
		<BaseHead title={pageTitle} description="浏览学习记录、技术笔记、面试整理和随想随笔。" />
	</head>
	<body>
		<Header />
		<BlogIndexView
			posts={pagination.items}
			currentPage={pagination.currentPage}
			totalPages={pagination.totalPages}
			totalItems={pagination.totalItems}
			basePath="/blog"
		/>
		<Footer />
	</body>
</html>
