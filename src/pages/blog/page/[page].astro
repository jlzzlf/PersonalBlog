---
import BaseHead from '../../../components/BaseHead.astro';
import Footer from '../../../components/Footer.astro';
import Header from '../../../components/Header.astro';
import BlogIndexView from '../../../components/views/BlogIndexView.astro';
import { SITE_TITLE } from '../../../consts';
import { getSortedBlogEntries } from '../../../lib/blog';
import { BLOG_PAGE_SIZE, paginateItems } from '../../../lib/pagination';

export async function getStaticPaths() {
	const allPosts = await getSortedBlogEntries();
	const firstPage = paginateItems(allPosts, BLOG_PAGE_SIZE, 1);

	if (firstPage.totalPages <= 1) {
		return [];
	}

	return Array.from({ length: firstPage.totalPages - 1 }, (_, index) => {
		const currentPage = index + 2;
		const pagination = paginateItems(allPosts, BLOG_PAGE_SIZE, currentPage);

		return {
			params: { page: String(currentPage) },
			props: { pagination },
		};
	});
}

const { pagination } = Astro.props;
const pageTitle = `技术博客 第 ${pagination.currentPage} 页 | ${SITE_TITLE}`;
---

<!doctype html>
<html lang="zh-CN">
	<head>
		<BaseHead
			title={pageTitle}
			description={`技术博客分页列表，第 ${pagination.currentPage} 页，共 ${pagination.totalPages} 页。`}
		/>
	</head>
	<body>
		<Header />
		<BlogIndexView
			posts={pagination.items}
			currentPage={pagination.currentPage}
			totalPages={pagination.totalPages}
			totalItems={pagination.totalItems}
			basePath="/blog"
		/>
		<Footer />
	</body>
</html>
