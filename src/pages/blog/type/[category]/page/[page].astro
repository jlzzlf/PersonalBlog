---
import BaseHead from '../../../../../components/BaseHead.astro';
import Footer from '../../../../../components/Footer.astro';
import Header from '../../../../../components/Header.astro';
import BlogIndexView from '../../../../../components/views/BlogIndexView.astro';
import { SITE_TITLE } from '../../../../../consts';
import {
	getBlogCategoryCounts,
	getBlogCategoryPath,
	getPostsByBlogCategory,
	getSortedBlogEntries,
} from '../../../../../lib/blog';
import { BLOG_PAGE_SIZE, paginateItems } from '../../../../../lib/pagination';

export async function getStaticPaths() {
	const allPosts = await getSortedBlogEntries();
	const categoryCounts = getBlogCategoryCounts(allPosts);

	return categoryCounts.flatMap(({ category, count }) => {
		if (count <= BLOG_PAGE_SIZE) return [];

		const categoryPosts = getPostsByBlogCategory(allPosts, category);
		const totalPages = paginateItems(categoryPosts, BLOG_PAGE_SIZE, 1).totalPages;

		return Array.from({ length: totalPages - 1 }, (_, index) => {
			const currentPage = index + 2;
			const pagination = paginateItems(categoryPosts, BLOG_PAGE_SIZE, currentPage);

			return {
				params: { category, page: String(currentPage) },
				props: { category, categoryCounts, pagination },
			};
		});
	});
}

const { category, categoryCounts, pagination } = Astro.props;
const pageTitle = `${category} · 第 ${pagination.currentPage} 页 | ${SITE_TITLE}`;
---

<!doctype html>
<html lang="zh-CN">
	<head>
		<BaseHead title={pageTitle} description={`${category}文章列表，第 ${pagination.currentPage} 页。`} />
	</head>
	<body>
		<Header />
		<BlogIndexView
			posts={pagination.items}
			categoryCounts={categoryCounts}
			activeCategory={category}
			currentPage={pagination.currentPage}
			totalPages={pagination.totalPages}
			totalItems={pagination.totalItems}
			basePath={getBlogCategoryPath(category)}
		/>
		<Footer />
	</body>
</html>
