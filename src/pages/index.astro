---
import { getCollection } from 'astro:content';
import Banner from '../components/Banner.astro';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import HomeBlogShowcase from '../components/home/HomeBlogShowcase.astro';
import HomeProfileCard from '../components/home/HomeProfileCard.astro';
import HomeProjectLogShowcaseCard from '../components/home/HomeProjectLogShowcaseCard.astro';
import HomeQuickNavCard from '../components/home/HomeQuickNavCard.astro';
import HomeRecentCommentsCard from '../components/home/HomeRecentCommentsCard.astro';
import HomeSiteStatsCard from '../components/home/HomeSiteStatsCard.astro';
import HomeKnowledgeEntryCard from '../components/home/HomeKnowledgeEntryCard.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
import { buildHomePageViewModel, getLatestContentUpdatedDate } from '../lib/homepage';
import { buildHomeProjectLogItems } from '../lib/project-logs';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
const projectLogs = await getCollection('projectLogs');
const interviews = await getCollection('interviews');

const latestContentUpdatedDate = getLatestContentUpdatedDate([...posts, ...projectLogs, ...interviews]);
const { recentPosts, siteStats } = buildHomePageViewModel(posts, latestContentUpdatedDate);
const projectLogItems = buildHomeProjectLogItems(projectLogs);
---

<!doctype html>
<html lang="zh-CN">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body class="home-page" data-banner-mode="background">
		<Banner mode="background" />
		<Header />
		<main class="home" data-parallax-home>
			<section id="hero" class="home-section home-hero" aria-label="首页介绍">
				<HomeProfileCard />
				<HomeKnowledgeEntryCard />
			</section>

			<section id="project-logs" class="home-section projects-section" aria-labelledby="home-projects-title">
				<div class="section-heading section-heading--split home-reveal" data-reveal-card>
					<div>
						<p class="section-kicker">Project Logs</p>
						<h2 id="home-projects-title">项目日志</h2>
					</div>
					<a class="text-link" href="/projects/">查看全部日志<span aria-hidden="true">→</span></a>
				</div>
				<HomeProjectLogShowcaseCard items={projectLogItems} />
			</section>

			<section id="blog" class="home-section blog-section" aria-labelledby="home-blog-title">
				<div class="section-heading section-heading--split home-reveal" data-reveal-card>
					<div>
						<p class="section-kicker">Latest Articles</p>
						<h2 id="home-blog-title">博客文章</h2>
					</div>
					<a class="text-link" href="/blog/">查看全部文章<span aria-hidden="true">→</span></a>
				</div>
				<HomeBlogShowcase posts={recentPosts} />
			</section>

			<section id="links" class="home-section links-section" aria-label="快捷导航">
				<HomeQuickNavCard />
			</section>

			<section id="comments" class="home-section comments-section" aria-labelledby="home-comments-title">
				<HomeRecentCommentsCard />
			</section>

			<section class="home-section stats-section" aria-labelledby="home-stats-title">
				<div class="section-heading section-heading--center home-reveal" data-reveal-card>
					<p class="section-kicker">Site Statistics</p>
					<h2 id="home-stats-title">站点数据</h2>
				</div>
				<HomeSiteStatsCard stats={siteStats} />
			</section>
		</main>
		<Footer />
	</body>
</html>

<style is:global>
	.home {
		position: relative;
		z-index: 5;
		display: grid;
		gap: clamp(2.75rem, 5vw, 4.75rem);
		width: min(1360px, calc(100% - 2rem));
		margin: 0 auto;
		padding: clamp(7rem, 18vh, 10rem) 0 4.5rem;
		isolation: isolate;
	}

	body.home-page {
		--color-bg: #ebfcff;
	}

	body.home-page[data-banner-mode='background'] main.home {
		padding: clamp(7rem, 18vh, 50rem) 0 4.5rem;
	}

	.home-section {
		position: relative;
		z-index: 1;
	}

	.home-hero {
		display: grid;
		grid-template-columns: minmax(0, 1.08fr) minmax(20rem, 26rem);
		gap: clamp(1.25rem, 3vw, 2.5rem);
		align-items: center;
		width: min(1180px, 100%);
		min-height: clamp(32rem, 62svh, 40rem);
		margin: 0 auto;
	}

	.home-card {
		position: relative;
		overflow: hidden;
		border: 1px solid rgba(198, 215, 219, 0.5);
		border-radius: 1.5rem;
		background: rgba(255, 255, 255, 0.7);
		box-shadow: 0 8px 32px rgba(198, 215, 219, 0.1);
		backdrop-filter: blur(20px);
		-webkit-backdrop-filter: blur(20px);
	}

	.home-card::before {
		content: '';
		position: absolute;
		inset: 0;
		z-index: 0;
		background: linear-gradient(135deg, rgba(198, 215, 219, 0.22), transparent 48%);
		opacity: 0;
		transition: opacity 180ms ease;
		pointer-events: none;
	}

	.home-card > * {
		position: relative;
		z-index: 1;
	}

	.home-card:hover::before {
		opacity: 1;
	}

	.home-reveal {
		opacity: 0;
		transform: translateY(30px);
		transition:
			opacity 180ms ease,
			transform 180ms ease,
			border-color 180ms ease,
			background-color 180ms ease,
			box-shadow 180ms ease;
		transition-delay: var(--reveal-delay, 0ms);
	}

	.home-reveal.is-visible {
		opacity: 1;
		transform: translateY(0);
	}

	.home-card.home-reveal:hover {
		transition-delay: 0ms;
		transform: translateY(-5px);
		border-color: rgba(198, 215, 219, 0.6);
		box-shadow: none;
	}

	.section-heading {
		display: flex;
		align-items: end;
		justify-content: space-between;
		gap: 1rem;
		margin-bottom: 2rem;
	}

	.section-heading--center {
		display: grid;
		justify-items: center;
		text-align: center;
	}

	.section-heading--left {
		display: grid;
		justify-items: start;
		margin-bottom: 0.9rem;
	}

	.section-heading h2,
	.recent-card__header h2,
	.project-feature-card h3,
	.project-more-card h3,
	.blog-entry-card h3 {
		color: #002f6c;
	}

	.section-kicker {
		margin: 0 0 0.45rem;
		color: var(--color-link);
		font-size: 0.82rem;
		font-weight: 700;
		letter-spacing: 0.16em;
		text-transform: uppercase;
	}

	.text-link,
	.blog-card-link,
	.project-more-card__button {
		display: inline-flex;
		align-items: center;
		gap: 0.45rem;
		color: var(--color-link);
		font-size: 0.9rem;
		font-weight: 700;
		text-decoration: none;
		transition:
			color 220ms ease,
			transform 220ms ease;
	}

	.text-link:hover,
	.blog-card-link:hover,
	.project-more-card__button:hover {
		color: var(--color-link);
	}

	.text-link:hover span,
	.blog-card-link:hover span,
	.project-more-card__button:hover span {
		transform: translateX(0.2rem);
	}

	.text-link span,
	.blog-card-link span,
	.project-more-card__button span {
		transition: transform 220ms ease;
	}

	.profile-card {
		display: grid;
		gap: clamp(1.35rem, 2.4vw, 1.9rem);
		align-content: center;
	}

	.profile-copy {
		display: grid;
		gap: clamp(1.35rem, 2.5vw, 2rem);
		max-width: 36rem;
	}

	.profile-heading {
		display: grid;
		gap: 0.42rem;
	}

	.profile-kicker {
		margin: 0;
		color: #ffffff;
		font-size: 0.9rem;
		font-weight: 700;
		letter-spacing: 0.16em;
		text-transform: uppercase;
	}

	.profile-name {
		margin: 0;
		color: #ffffff;
		font-size: clamp(64px, 8vw, 6.8rem);
		font-weight: 800;
		line-height: 0.96;
		letter-spacing: 1px;
		text-shadow: 0 4px 20px rgba(0, 47, 108, 0.3);
	}

	.profile-role {
		margin: 0;
		color: rgba(255, 255, 255, 0.9);
		font-size: 1.2rem;
		font-weight: 400;
		text-shadow: 0 1px 3px rgba(0, 47, 108, 0.15);
	}

	.profile-intro {
		display: grid;
		gap: 0.35rem;
	}

	.profile-intro p {
		margin: 0;
		color: #ffffff;
		font-size: 1.05rem;
		line-height: 1.75;
		text-shadow: 0 1px 3px rgba(0, 47, 108, 0.15);
	}

	.profile-tags {
		display: flex;
		flex-wrap: wrap;
		gap: 0.65rem;
	}

	.profile-tags {
		margin-top: 0.1rem;
	}

	.profile-tags span {
		display: inline-flex;
		align-items: center;
		padding: 0.48rem 0.95rem;
		border-radius: 999px;
		background: var(--color-primary-deep);
		color: var(--color-on-accent);
		font-size: 0.86rem;
		font-weight: 700;
		box-shadow: 0 10px 20px rgba(198, 215, 219, 0.16);
		transition:
			transform 300ms ease,
			box-shadow 300ms ease;
	}

	.profile-tags span:hover {
		transform: translateY(-5px);
		box-shadow: 0 20px 40px rgba(198, 215, 219, 0.2);
	}

	.profile-contacts {
		display: grid;
		gap: 0.55rem;
		padding-top: 0.1rem;
	}

	.profile-contact {
		display: flex;
		flex-wrap: wrap;
		align-items: center;
		gap: 0.7rem;
		margin: 0;
		color: rgba(255, 255, 255, 0.92);
		font-size: 0.95rem;
	}

	.profile-contact span {
		color: #ffffff;
	}

	.profile-contact__copy {
		padding: 0;
		border: 0;
		background: transparent;
		color: #002f6c;
		font: inherit;
		cursor: pointer;
		transition:
			color 180ms ease,
			opacity 180ms ease;
	}

	.profile-card .profile-kicker,
	.profile-card .profile-name,
	.profile-card .profile-role,
	.profile-card .profile-intro p,
	.profile-card .profile-contact,
	.profile-card .profile-contact span,
	.profile-card .profile-contact__copy {
		color: #0055a6;
	}

	.profile-card .profile-name {
		color: #002f6c;
	}

	.profile-contact__copy:hover,
	.profile-contact__copy.is-copied {
		color: var(--color-link);
	}

	.profile-actions {
		display: flex;
		flex-wrap: wrap;
		gap: 0.85rem;
		margin-top: -0.25rem;
	}

	.profile-action {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: 3rem;
		height: 3rem;
		border: 1px solid rgba(198, 215, 219, 0.5);
		border-radius: 0.85rem;
		background: rgba(255, 255, 255, 0.7);
		box-shadow: 0 8px 32px rgba(198, 215, 219, 0.1);
		text-decoration: none;
		transition:
			transform 300ms ease,
			background-color 300ms ease,
			box-shadow 300ms ease;
	}

	.profile-action:hover {
		transform: translateY(-5px);
		background: rgba(198, 215, 219, 0.4);
		box-shadow: 0 20px 40px rgba(198, 215, 219, 0.2);
	}

	.profile-action-image {
		width: 1.3rem;
		height: 1.3rem;
		object-fit: contain;
	}

	.profile-action-image.is-leetcode {
		transform: translateX(-0.12rem);
	}

	.recent-card {
		display: grid;
		align-self: center;
		gap: 1.45rem;
		margin-top: clamp(3rem, 9vh, 6.5rem);
		padding: clamp(1.35rem, 2.4vw, 2rem);
		border-color: rgba(198, 215, 219, 0.68);
		border-radius: 1.75rem;
		box-shadow:
			0 20px 40px rgba(0, 47, 108, 0.12),
			0 0 34px rgba(198, 215, 219, 0.28);
	}

	.resource-card {
		display: grid;
		gap: 1.2rem;
		align-self: center;
		margin-top: 0;
		padding: clamp(1.3rem, 2.2vw, 1.8rem);
		border-color: rgba(198, 215, 219, 0.68);
		box-shadow:
			0 20px 40px rgba(0, 47, 108, 0.12),
			0 0 34px rgba(198, 215, 219, 0.28);
	}

	.resource-card__header {
		display: grid;
		gap: 0.35rem;
	}

	.resource-card__header h2,
	.resource-entry__copy strong {
		color: #002f6c;
	}

	.resource-card__header h2 {
		margin: 0;
		font-size: clamp(1.6rem, 3vw, 2rem);
	}

	.resource-card__header p:last-child {
		margin: 0;
		color: var(--color-subtext);
		font-size: 0.92rem;
		line-height: 1.58;
	}

	.resource-card__entries {
		display: grid;
		gap: 0.75rem;
	}

	.resource-entry {
		display: grid;
		grid-template-columns: auto minmax(0, 1fr) auto;
		gap: 0.75rem;
		align-items: center;
		padding: 0.9rem;
		border: 1px solid rgba(198, 215, 219, 0.42);
		border-radius: 1rem;
		background: rgba(255, 255, 255, 0.56);
		color: inherit;
		text-decoration: none;
		transition:
			transform 220ms ease,
			border-color 220ms ease,
			background-color 220ms ease,
			box-shadow 220ms ease;
	}

	.resource-entry:hover {
		transform: translateY(-2px);
		border-color: rgba(198, 215, 219, 0.72);
		background: rgba(198, 215, 219, 0.24);
		box-shadow: 0 14px 28px rgba(198, 215, 219, 0.12);
	}

	.resource-entry__badge {
		display: inline-grid;
		place-items: center;
		width: 2.75rem;
		height: 2.75rem;
		border-radius: 0.78rem;
		background: linear-gradient(135deg, #c6d7db, #a4e1ff);
		color: #002f6c;
		font-size: 0.72rem;
		font-weight: 900;
		letter-spacing: 0.05em;
	}

	.resource-entry__copy {
		display: grid;
		gap: 0.15rem;
		min-width: 0;
	}

	.resource-entry__copy strong {
		font-size: 0.98rem;
		line-height: 1.3;
	}

	.resource-entry__copy small {
		overflow: hidden;
		color: var(--color-subtext);
		font-size: 0.76rem;
		font-weight: 700;
		line-height: 1.35;
		text-overflow: ellipsis;
		white-space: nowrap;
	}

	.resource-entry__arrow {
		color: var(--color-link);
		font-size: 1.1rem;
		font-weight: 800;
		transition: transform 220ms ease;
	}

	.resource-entry:hover .resource-entry__arrow {
		transform: translateX(0.18rem);
	}

	.recent-card__avatar {
		display: flex;
		align-items: center;
		gap: 1rem;
	}

	.recent-card__avatar-frame {
		width: 4rem;
		height: 4rem;
		flex: 0 0 auto;
		padding: 0.12rem;
		border-radius: 1rem;
		background: linear-gradient(135deg, #c6d7db, #a4e1ff, #c6d7db);
	}

	.recent-card__avatar-image {
		width: 100%;
		height: 100%;
		border-radius: 0.9rem;
		object-fit: cover;
	}

	.recent-card__avatar p {
		margin: 0 0 0.2rem;
		color: #002f6c;
		font-weight: 700;
		line-height: 1.45;
	}

	.recent-card__avatar span {
		color: var(--color-subtext);
		font-size: 0.85rem;
	}

	.recent-card__header {
		display: flex;
		align-items: end;
		justify-content: space-between;
		gap: 1rem;
	}

	.recent-card__header h2 {
		margin: 0;
		font-size: clamp(1.6rem, 3vw, 2rem);
	}

	.recent-list {
		display: grid;
		gap: 1rem;
	}

	.recent-item {
		display: grid;
		gap: 0.45rem;
		padding: 1rem;
		border: 1px solid rgba(198, 215, 219, 0.3);
		border-radius: 1.2rem;
		background: rgba(255, 255, 255, 0.5);
		color: inherit;
		text-decoration: none;
		transition:
			transform 300ms ease,
			border-color 300ms ease,
			background-color 300ms ease,
			box-shadow 300ms ease;
	}

	.recent-item:hover {
		transform: translateY(-2px);
		border-color: rgba(198, 215, 219, 0.5);
		background: rgba(198, 215, 219, 0.3);
		box-shadow: 0 16px 30px rgba(198, 215, 219, 0.12);
	}

	.recent-item__meta,
	.blog-card-meta {
		display: flex;
		flex-wrap: wrap;
		align-items: center;
		gap: 0.75rem;
		color: var(--color-subtext);
		font-size: 0.85rem;
		font-weight: 700;
	}

	.recent-item__meta {
		justify-content: space-between;
	}

	.recent-item__meta strong {
		padding: 0.22rem 0.55rem;
		border-radius: 999px;
		background: rgba(198, 215, 219, 0.5);
		color: var(--color-link);
		font-size: 0.72rem;
	}

	.recent-item__body {
		display: grid;
		gap: 0.25rem;
	}

	.recent-item__body strong,
	.blog-entry-card h3 {
		color: #002f6c;
		line-height: 1.45;
		transition: color 300ms ease;
	}

	.recent-item:hover .recent-item__body strong,
	.blog-entry-card:hover h3,
	.project-feature-card:hover h3,
	.quick-nav-tile:hover strong {
		color: var(--color-link);
	}

	.recent-item__body p,
	.project-feature-card p,
	.project-more-card p,
	.blog-entry-card p,
	.quick-nav-copy,
	.quick-nav-tile__body p {
		margin: 0;
		color: var(--color-subtext);
		line-height: 1.68;
	}

	.stats-grid {
		display: grid;
		grid-template-columns: repeat(4, minmax(0, 1fr));
		gap: 1.05rem;
		margin: 0;
	}

	.stat-card {
		display: grid;
		grid-template-columns: 3.5rem minmax(0, 1fr);
		grid-template-rows: auto auto;
		align-items: center;
		column-gap: 1rem;
		row-gap: 0.2rem;
		min-height: 8.6rem;
		padding: 1.4rem;
		border-radius: 1.25rem;
	}

	.stat-card dt {
		display: contents;
		margin: 0;
	}

	.stat-card__label {
		grid-column: 2;
		grid-row: 1;
		min-width: 0;
		color: var(--color-subtext);
		font-size: 0.86rem;
		line-height: 1.3;
		white-space: nowrap;
	}

	.stat-card dd {
		grid-column: 2;
		grid-row: 2;
		min-width: 0;
		margin: 0;
		color: #002f6c;
		font-size: 2rem;
		font-weight: 800;
		line-height: 1.1;
		font-variant-numeric: tabular-nums;
	}

	.stat-card dd small {
		margin-left: 0.25rem;
		color: var(--color-link);
		font-size: 1rem;
	}

	.stat-card__link {
		display: inline-flex;
		align-items: center;
		gap: 0.3rem;
		color: var(--color-link-hover);
		font-size: 1.05rem;
		font-weight: 800;
		text-decoration: none;
	}

	.stat-card__link:hover {
		text-decoration: underline;
		text-underline-offset: 0.2em;
	}

	.stat-card__icon,
	.project-feature-card__icon,
	.project-more-card__icon,
	.quick-nav-thumb {
		display: inline-grid;
		place-items: center;
		border-radius: 0.9rem;
		background: linear-gradient(135deg, #c6d7db, #a4e1ff);
		color: #002f6c;
		box-shadow: 0 12px 24px rgba(198, 215, 219, 0.2);
	}

	.stat-card__icon {
		grid-column: 1;
		grid-row: 1 / span 2;
		align-self: center;
		width: 3.5rem;
		height: 3.5rem;
		flex: 0 0 auto;
		font-size: 1.05rem;
		font-weight: 800;
	}

	.project-showcase-grid {
		display: grid;
		grid-template-columns: minmax(0, 2fr) minmax(18rem, 1fr);
		gap: 1.05rem;
	}

	.project-feature-card,
	.project-more-card {
		display: grid;
		align-content: space-between;
		padding: clamp(1.35rem, 2.4vw, 2rem);
	}

	.project-feature-card {
		min-height: 20rem;
		border-radius: 1.75rem;
		background:
			linear-gradient(135deg, rgba(198, 215, 219, 0.16), rgba(198, 215, 219, 0.14)),
			rgba(255, 255, 255, 0.7);
	}

	.project-feature-card__meta,
	.project-feature-card__actions,
	.project-more-card__header,
	.quick-nav-tile__top {
		display: flex;
		align-items: center;
		gap: 0.9rem;
	}

	.project-feature-card__meta {
		justify-content: space-between;
	}

	.project-feature-card__meta span:first-child {
		display: inline-flex;
		padding: 0.35rem 0.8rem;
		border-radius: 999px;
		background: rgba(198, 215, 219, 0.5);
		color: var(--color-link);
		font-size: 0.82rem;
		font-weight: 700;
	}

	.project-feature-card__type {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		padding: 0.42rem 0.86rem;
		border: 1px solid rgba(198, 215, 219, 0.28);
		border-radius: 999px;
		background: rgba(255, 255, 255, 0.62);
		color: var(--color-link);
		font-size: 0.76rem;
		font-weight: 900;
		letter-spacing: 0.08em;
		line-height: 1.1;
		text-transform: uppercase;
		box-shadow: 0 10px 20px rgba(198, 215, 219, 0.12);
