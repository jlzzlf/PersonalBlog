---
import { getCollection } from 'astro:content';
import { existsSync, readdirSync } from 'node:fs';
import { join } from 'node:path';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);

const toDayKey = (date: Date) =>
	`${date.getFullYear()}-${String(date.getMonth() + 1).padStart(2, '0')}-${String(
		date.getDate(),
	).padStart(2, '0')}`;

const formatPostDate = (date: Date) =>
	new Intl.DateTimeFormat('zh-CN', {
		year: 'numeric',
		month: 'short',
		day: 'numeric',
	}).format(date);

const postFeedItems = posts.map((post) => ({
	id: post.id,
	href: `/blog/${post.id}/`,
	title: post.data.title,
	description: post.data.description,
	pubDateISO: post.data.pubDate.toISOString(),
	pubDateLabel: formatPostDate(post.data.pubDate),
	dayKey: toDayKey(post.data.pubDate),
}));

const latestPosts = posts.slice(0, 6);
const archiveGroups = Array.from(
	posts.reduce((groups, post) => {
		const year = String(post.data.pubDate.getFullYear());
		const yearPosts = groups.get(year);
		if (yearPosts) {
			yearPosts.push(post);
		} else {
			groups.set(year, [post]);
		}
		return groups;
	}, new Map<string, typeof posts>()),
).map(([year, items]) => ({ year, items }));

const HOME_HERO_TITLE = '章立夫的个人主页';
const HOME_HERO_SUBTITLE = '欢迎访问';
const avatarImageSrc = encodeURI('/images/爱言叶5-裁切.jpg');
const profileActionButtons = [
	{ label: 'Bilibili', imageSrc: '/images/bilibili-fill.png', alt: 'Bilibili 图标' },
	{ label: 'GitHub', imageSrc: '/images/github.png', alt: 'GitHub 图标' },
	{ label: '力扣', imageSrc: '/images/LeetCode.png', alt: '力扣图标', iconClass: 'is-leetcode' },
];

const musicDirectory = join(process.cwd(), 'public', 'music');
const musicTracks = existsSync(musicDirectory)
	? readdirSync(musicDirectory)
			.filter((fileName) => /\.mp3$/i.test(fileName))
			.sort((left, right) =>
				left.localeCompare(right, 'zh-CN', { numeric: true, sensitivity: 'base' }),
			)
			.map((fileName, index) => ({
				index,
				label: fileName.replace(/\.mp3$/i, ''),
				src: encodeURI(`/music/${fileName}`),
			}))
	: [];

const siteLinks = [
	{ label: '项目展示', href: '/projects', note: '集中展示正在做的项目、作品和阶段计划' },
	{ label: '学习日报', href: '/study-log', note: '记录每天的学习进度、收获和复盘' },
	{ label: '个人简介', href: '/profile', note: '整理个人经历、兴趣方向和联系方式' },
];

const noticeItems = ['这里后面可以放最近更新、站点变动或想告诉访客的话。'];

const plannerItems = [
	'这里后面可以继续放标签、归档、天气或待办。',
	'右侧栏会保留成可继续加模块的区域。',
	'目前先把首页的整体结构搭清楚。',
];

const today = new Date();
const currentYear = today.getFullYear();
const currentMonth = today.getMonth();
const firstDayOfMonth = new Date(currentYear, currentMonth, 1);
const daysInMonth = new Date(currentYear, currentMonth + 1, 0).getDate();
const leadingEmptyDays = (firstDayOfMonth.getDay() + 6) % 7;
const weekDays = ['一', '二', '三', '四', '五', '六', '日'];
const calendarCells = [
	...Array.from({ length: leadingEmptyDays }, () => null),
	...Array.from({ length: daysInMonth }, (_, index) => {
		const dayNumber = index + 1;
		return {
			dayNumber,
			dayKey: `${currentYear}-${String(currentMonth + 1).padStart(2, '0')}-${String(
				dayNumber,
			).padStart(2, '0')}`,
			isToday:
				dayNumber === today.getDate() &&
				currentMonth === today.getMonth() &&
				currentYear === today.getFullYear(),
		};
	}),
];

while (calendarCells.length % 7 !== 0) {
	calendarCells.push(null);
}

const monthFormatter = new Intl.DateTimeFormat('zh-CN', {
	year: 'numeric',
	month: 'long',
});

const fullDateFormatter = new Intl.DateTimeFormat('zh-CN', {
	year: 'numeric',
	month: 'short',
	day: 'numeric',
});

const archiveDateFormatter = new Intl.DateTimeFormat('zh-CN', {
	month: 'short',
	day: 'numeric',
});
---

<!doctype html>
<html lang="zh-CN">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main class="home" data-parallax-home>
			<div class="home-video-layer" aria-hidden="true">
				<video class="stage-video" autoplay muted loop playsinline preload="metadata" aria-hidden="true">
					<source src="https://pub-c822d24319af435d89295bee4f959173.r2.dev/miku.mp4" type="video/mp4"  />
				</video>
				<div class="stage-overlay" aria-hidden="true"></div>
			</div>
			<div class="home-surface-layer" aria-hidden="true"></div>

			<section class="home-stage">
				<div class="stage-content">
					<h1>{HOME_HERO_TITLE}</h1>
					<p class="stage-subtitle" data-random-hero-subtitle>{HOME_HERO_SUBTITLE}</p>
				</div>
			</section>

			<section class="dashboard-layer">
				<section class="dashboard-grid">
				<aside class="sidebar left-column">
					<article class="surface-card panel profile-card">
						<p class="eyebrow">Profile</p>
						<div class="avatar-frame" aria-label="头像位置">
							<img src={avatarImageSrc} alt="头像" class="avatar-image" />
						</div>
						<h2 class="profile-name">章立夫</h2>
						<div class="profile-actions" aria-label="个人主页与联系方式入口">
							{
								profileActionButtons.map((item) => (
									<button class="profile-action" type="button" aria-label={item.label}>
										<img
											src={item.imageSrc}
											alt={item.alt}
											class:list={['profile-action-image', item.iconClass]}
										/>
										<span>{item.label}</span>
									</button>
								))
							}
						</div>
					</article>

					<article class="surface-card panel notice-card">
						<p class="eyebrow">Notice</p>
						<h2>公告</h2>
						<ul class="planner-list">
							{
								noticeItems.map((item) => (
									<li>{item}</li>
								))
							}
						</ul>
					</article>

					<article class="surface-card panel music-card">
						<p class="eyebrow">Music</p>
						<h2>音乐播放器</h2>
						{
							musicTracks.length > 0 ? (
								<>
									<p class="music-current" data-music-current>{musicTracks[0].label}</p>
									<audio
										class="music-audio"
										data-music-audio
										controls
										preload="metadata"
										src={musicTracks[0].src}
									></audio>
									<div class="music-playlist" aria-label="音乐播放列表">
										{
											musicTracks.map((track, index) => (
												<button
													type="button"
													class:list={['music-track', { active: index === 0 }]}
													data-music-track
													data-track-index={String(index)}
													data-track-src={track.src}
													data-track-label={track.label}
													aria-pressed={index === 0 ? 'true' : 'false'}
												>
													<span class="music-track-order">
														{String(index + 1).padStart(2, '0')}
													</span>
													<span class="music-track-label">{track.label}</span>
												</button>
											))
										}
									</div>
								</>
							) : (
								<div class="empty-music">
									<h3>还没有找到可播放的音乐。</h3>
									<p>把 `.mp3` 文件放进 `public/music` 文件夹后，这里会自动生成播放列表。</p>
								</div>
							)
						}
					</article>
				</aside>

				<section class="center-column">
					<article class="surface-card panel uploads-panel">
						<div class="uploads-header">
							<div>
								<p class="eyebrow">Latest Uploads</p>
								<h2>网站最新上传</h2>
								<p class="uploads-filter-note" data-uploads-filter-note>
									点击右侧日历按日期筛选，再点一次同一天可恢复默认列表。
								</p>
							</div>
							<span class="uploads-count" data-uploads-count>{latestPosts.length} 条内容</span>
						</div>

						<div class="uploads-content" data-uploads-content>
							{
								latestPosts.length > 0 ? (
									<div class="upload-list">
										{
											latestPosts.map((post, index) => (
												<a class="upload-item" href={`/blog/${post.id}/`}>
													<span class="upload-order">
														{String(index + 1).padStart(2, '0')}
													</span>
													<div class="upload-body">
														<div class="upload-meta">
															<span class="upload-tag">博客更新</span>
															<time datetime={post.data.pubDate.toISOString()}>
																{fullDateFormatter.format(post.data.pubDate)}
															</time>
														</div>
														<h3>{post.data.title}</h3>
														<p>{post.data.description}</p>
													</div>
													<span class="upload-action">查看</span>
												</a>
											))
										}
									</div>
								) : (
									<div class="empty-upload">
										<h3>这里会按发布时间显示最新内容。</h3>
										<p>等你继续添加文章之后，中间这一栏就会自动按时间从新到旧排列。</p>
									</div>
								)
							}
						</div>
						<script
							type="application/json"
							data-post-feed
							set:html={JSON.stringify(postFeedItems)}
						></script>
					</article>

					<article class="surface-card panel archive-panel">
						<div class="archive-header">
							<div>
								<p class="eyebrow">Archive</p>
								<h2>归档</h2>
								<p class="archive-copy">按时间线查看文章更新，后面也可以继续扩展成更完整的归档页。</p>
							</div>
							<span class="archive-count">{posts.length} 篇文章</span>
						</div>

						<div class="archive-timeline">
							{
								archiveGroups.map((group) => (
									<section class="archive-group">
										<div class="archive-year">{group.year}</div>
										<div class="archive-items">
											{
												group.items.map((post) => (
													<a class="archive-item" href={`/blog/${post.id}/`}>
														<time datetime={post.data.pubDate.toISOString()} class="archive-date">
															{archiveDateFormatter.format(post.data.pubDate)}
														</time>
														<div class="archive-item-body">
															<strong>{post.data.title}</strong>
															<p>{post.data.description}</p>
														</div>
													</a>
												))
											}
										</div>
									</section>
								))
							}
						</div>
					</article>
				</section>

				<aside class="sidebar right-column">
					<article class="surface-card panel clock-card">
						<div class="links-clock" aria-live="polite">
							<strong class="links-clock-time" data-current-time>--:--:--</strong>
						</div>
					</article>

					<article class="surface-card panel links-card">
						<p class="eyebrow">Pages</p>
						<h2>网页链接</h2>
						<div class="link-list">
							{
								siteLinks.map((link) => (
									<a class="link-item" href={link.href}>
										<div>
											<strong>{link.label}</strong>
											<p>{link.note}</p>
										</div>
										<span>进入</span>
									</a>
								))
							}
						</div>
					</article>

					<article class="surface-card panel calendar-card">
						<p class="eyebrow">Calendar</p>
						<div class="calendar-header">
							<h2>日历</h2>
							<span>{monthFormatter.format(today)}</span>
						</div>
						<div class="calendar-weekdays">
							{
								weekDays.map((day) => (
									<span>{day}</span>
								))
							}
						</div>
						<div class="calendar-grid">
							{
								calendarCells.map((cell) =>
									cell ? (
										<button
											type="button"
											class:list={['calendar-day', { today: cell.isToday }]}
											data-calendar-day
											data-day-key={cell.dayKey}
											aria-pressed="false"
										>
											{cell.dayNumber}
										</button>
									) : (
										<div class="calendar-day empty"></div>
									),
								)
							}
						</div>
					</article>

					<article class="surface-card panel planner-card">
						<p class="eyebrow">More Modules</p>
						<h2>右侧扩展区</h2>
						<ul class="planner-list">
							{
								plannerItems.map((item) => (
									<li>{item}</li>
								))
							}
						</ul>
					</article>
				</aside>
				</section>
			</section>

		</main>
		<Footer />
	</body>
</html>

<style>
	:global(body) {
		background: var(--page);
	}

	.home {
		--hero-height: clamp(22rem, 33vw, 27rem);
		--hero-overlap: clamp(4.5rem, 12vw, 8.5rem);
		--surface-overlap: clamp(0rem, 1.4vw, 1rem);
		--surface-shift: 0px;
		--surface-feather-height: 12rem;
		--surface-feather-offset: 7rem;
		--surface-feather-blur: 40px;
		--surface-ripple-x: 0px;
		--surface-ripple-y: 0px;
		--surface-ripple-scale: 1;
		--surface-ripple-opacity: 0.92;
		--surface-haze-x: 0px;
		--surface-haze-y: 0px;
		--surface-haze-scale: 1;
		--surface-haze-opacity: 0.68;
		display: grid;
		gap: 0;
		padding-top: 0;
		margin-top: -6.75rem;
		position: relative;
		isolation: isolate;
	}

	.home-video-layer,
	.home-surface-layer {
		position: fixed;
		left: 50%;
		width: 100vw;
		pointer-events: none;
		transform: translateX(-50%);
	}

	.home-video-layer {
		top: 0;
		height: var(--hero-height);
		overflow: hidden;
		z-index: 0;
	}

	.home-surface-layer {
		top: calc(var(--hero-height) - var(--surface-overlap));
		height: calc(100vh + 100svh);
		z-index: 2;
		transform: translate3d(-50%, var(--surface-shift), 0);
		will-change: transform;
		overflow: visible;
		isolation: isolate;
		background:
			linear-gradient(
				180deg,
				#faf6ef 0%,
				#f6efe5 18%,
				#f1e7d9 42%,
				var(--page) 100%
			);
	}

	.home-surface-layer::before {
		content: '';
		position: absolute;
		left: -8vw;
		right: -8vw;
		top: calc(var(--surface-feather-offset) * -1);
		height: calc(var(--surface-feather-height) + var(--surface-feather-offset));
		pointer-events: none;
		opacity: var(--surface-ripple-opacity);
		filter: blur(var(--surface-feather-blur));
		transform:
			translate3d(var(--surface-ripple-x), var(--surface-ripple-y), 0)
			scaleY(var(--surface-ripple-scale));
		transform-origin: center bottom;
		background:
			radial-gradient(circle at 15% 24%, rgba(118, 164, 136, 0.13), transparent 28%),
			radial-gradient(circle at 84% 18%, rgba(220, 173, 138, 0.14), transparent 24%),
			linear-gradient(
				180deg,
				rgba(250, 246, 239, 0) 0%,
				rgba(250, 246, 239, 0.12) 18%,
				rgba(247, 240, 230, 0.44) 42%,
				rgba(242, 233, 220, 0.88) 78%,
				rgba(240, 231, 218, 1) 100%
			);
		will-change: transform;
	}

	.home-surface-layer::after {
		content: '';
		position: absolute;
		left: -10vw;
		right: -10vw;
		top: calc(var(--surface-feather-offset) * -0.82);
		height: calc(var(--surface-feather-height) * 0.92);
		pointer-events: none;
		opacity: var(--surface-haze-opacity);
		filter: blur(calc(var(--surface-feather-blur) + 12px));
		transform:
			translate3d(var(--surface-haze-x), var(--surface-haze-y), 0)
			scaleY(var(--surface-haze-scale));
		transform-origin: center bottom;
		background:
			radial-gradient(
				ellipse at center top,
				rgba(255, 250, 243, 0.74) 0%,
				rgba(248, 240, 229, 0.48) 38%,
				rgba(242, 233, 220, 0) 76%
			);
		will-change: transform;
	}

	.home-stage {
		position: relative;
		width: 100vw;
		height: var(--hero-height);
		margin-left: calc(50% - 50vw);
		margin-right: calc(50% - 50vw);
		margin-bottom: 0;
		padding: 0;
		pointer-events: none;
		z-index: 1;
	}

	.stage-video,
	.stage-overlay {
		position: absolute;
		inset: 0;
	}

	.stage-video {
		width: 100%;
		height: 100%;
		object-fit: cover;
		object-position: center 38%;
		z-index: 0;
	}

	.stage-overlay {
		z-index: 1;
		background:
			linear-gradient(180deg, rgba(17, 21, 18, 0.28) 0%, rgba(17, 21, 18, 0.4) 100%),
			radial-gradient(circle at center, rgba(255, 255, 255, 0.05), transparent 60%);
	}

	.stage-content {
		position: absolute;
		top: clamp(6.8rem, 12vw, 9.4rem);
		left: 50%;
		z-index: 1;
		width: fit-content;
		max-width: calc(100vw - 2rem);
		display: grid;
		gap: 0.8rem;
		place-items: center;
		text-align: center;
		transform: translateX(-50%);
	}

	.stage-content h1 {
		display: block;
		margin-bottom: 0;
		margin-inline: auto;
		color: #fffaf0;
		font-size: clamp(2.2rem, 5.4vw, 4.5rem);
		max-width: calc(100vw - 2rem);
		line-height: 1.08;
		white-space: nowrap;
		text-shadow: 0 10px 30px rgba(0, 0, 0, 0.32);
	}

	.stage-subtitle {
		margin: 0;
		margin-inline: auto;
		max-width: calc(100vw - 3rem);
		color: #fffaf0;
		font-size: clamp(1rem, 2.2vw, 1.45rem);
		font-weight: 500;
		line-height: 1.25;
		white-space: nowrap;
		text-shadow: 0 8px 24px rgba(0, 0, 0, 0.28);
	}

	.dashboard-layer {
		position: relative;
		z-index: 4;
		margin-top: calc(var(--hero-overlap) * -1);
	}

	.dashboard-grid {
		display: grid;
		grid-template-columns: minmax(240px, 300px) minmax(0, 1fr) minmax(240px, 300px);
		grid-template-areas: 'left center right';
		gap: 1.4rem;
		align-items: start;
		position: relative;
		width: min(1360px, calc(100% - 2rem));
		margin: 0 auto;
	}

	.left-column {
		grid-area: left;
	}

	.center-column {
		grid-area: center;
		display: grid;
		gap: 1rem;
		align-content: start;
	}

	.right-column {
		grid-area: right;
	}

	.sidebar {
		display: grid;
		gap: 1rem;
	}

	.panel {
		padding: 1.4rem;
	}

	.panel h2 {
		margin-bottom: 0.8rem;
		font-size: 1.6rem;
	}

	.profile-card {
		gap: 1rem;
		text-align: center;
	}

	.clock-card {
		display: grid;
		place-items: center;
		padding: 1.15rem 1rem;
	}

	.profile-card .eyebrow {
		width: 100%;
		text-align: left;
	}

	.avatar-frame {
		display: grid;
		place-items: center;
		width: min(100%, clamp(9.5rem, 18vw, 13.5rem));
		aspect-ratio: 4 / 5;
		justify-self: center;
		margin: 0.15rem auto 0.55rem;
		border-radius: clamp(20px, 2.4vw, 28px);
		border: 1px solid rgba(56, 61, 56, 0.12);
		background:
			linear-gradient(180deg, rgba(255, 255, 255, 0.74) 0%, rgba(246, 239, 228, 0.92) 100%);
		box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.5);
		overflow: hidden;
	}

	.avatar-image {
		width: 100%;
		height: 100%;
		object-fit: cover;
		object-position: center;
		display: block;
	}

	.profile-name {
		margin: 0;
		font-size: clamp(1.45rem, 2.3vw, 1.9rem);
		letter-spacing: 0.04em;
	}

	.profile-actions {
		display: grid;
		grid-template-columns: repeat(3, minmax(0, 1fr));
		gap: 0.65rem;
		width: 100%;
	}

	.profile-action {
		display: grid;
		gap: 0.5rem;
		justify-items: center;
		padding: 0.75rem 0.5rem 0.7rem;
		border: 1px solid rgba(56, 61, 56, 0.08);
		border-radius: 20px;
		background: rgba(255, 255, 255, 0.5);
		color: rgb(var(--black));
		cursor: pointer;
		transition:
			transform 180ms ease,
			box-shadow 180ms ease,
			border-color 180ms ease;
	}

	.profile-action:hover {
		transform: translateY(-2px);
		border-color: rgba(22, 98, 74, 0.2);
		box-shadow: 0 16px 32px rgba(70, 67, 58, 0.08);
	}

