---
import { getCollection } from 'astro:content';
import Banner from '../components/Banner.astro';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import HomeArchiveEntryCard from '../components/home/HomeArchiveEntryCard.astro';
import HomeRecentCommentsCard from '../components/home/HomeRecentCommentsCard.astro';
import HomeProfileCard from '../components/home/HomeProfileCard.astro';
import HomeProjectShowcaseCard from '../components/home/HomeProjectShowcaseCard.astro';
import HomeQuickNavCard from '../components/home/HomeQuickNavCard.astro';
import HomeRecentPostsCard from '../components/home/HomeRecentPostsCard.astro';
import HomeSiteStatsCard from '../components/home/HomeSiteStatsCard.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
import { buildHomePageViewModel } from '../lib/homepage';
import { buildHomeProjectShowcaseItems, sortProjectEntries } from '../lib/projects';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
const projectEntries = sortProjectEntries(await getCollection('projects'));

const { recentPosts, siteStats, archiveEntryStats } = buildHomePageViewModel(posts);
const projectShowcaseItems = buildHomeProjectShowcaseItems(projectEntries);
---

<!doctype html>
<html lang="zh-CN">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body class="home-page" data-banner-mode="background">
		<Banner mode="background" />
		<Header />
		<main class="home" data-parallax-home>
			<section class="dashboard-layer">
				<section class="dashboard-grid">
					<HomeProfileCard />
					<HomeRecentPostsCard posts={recentPosts} />

					<section class="secondary-band">
						<HomeSiteStatsCard stats={siteStats} />
						<HomeProjectShowcaseCard items={projectShowcaseItems} />
					</section>

					<HomeQuickNavCard />
					<HomeArchiveEntryCard stats={archiveEntryStats} />
					<HomeRecentCommentsCard />
				</section>
			</section>
		</main>
		<Footer />
	</body>
</html>

	<style is:global>
		.home {
			position: relative;
			isolation: isolate;
		}

		.dashboard-layer {
			position: relative;
			z-index: 5;
		}

		.dashboard-grid {
			position: relative;
			display: grid;
			grid-template-columns: repeat(12, minmax(0, 1fr));
			grid-template-areas:
				'hero hero hero hero hero hero recent recent recent recent recent recent'
				'secondary secondary secondary secondary secondary secondary secondary secondary secondary secondary secondary secondary'
				'planner planner planner planner planner planner planner planner planner planner planner planner'
				'archive-entry archive-entry archive-entry archive-entry archive-entry archive-entry latest-comments latest-comments latest-comments latest-comments latest-comments latest-comments';
			gap: 1.05rem;
			align-items: stretch;
			width: min(1360px, calc(100% - 2rem));
			margin: 0 auto;
			padding-bottom: 1rem;
		}

		.panel {
			position: relative;
			overflow: hidden;
			min-height: 0;
			padding: 1.4rem;
		}

		.panel > * {
			position: relative;
			z-index: 1;
		}

		.panel::after {
			content: '';
			position: absolute;
			right: -4rem;
			bottom: -4rem;
			width: 11rem;
			height: 11rem;
			border-radius: 999px;
			background: radial-gradient(circle, rgba(204, 255, 255, 0.24), transparent 68%);
			pointer-events: none;
		}

		.panel h2 {
			margin-bottom: 0.65rem;
			font-size: 1.55rem;
		}

		.secondary-band {
			grid-area: secondary;
			display: grid;
			grid-template-columns: minmax(15.25rem, 17.5rem) minmax(0, 1fr);
			gap: 1.05rem;
			align-items: stretch;
			min-width: 0;
		}

		.secondary-band > * {
			min-width: 0;
		}

		.profile-card {
			grid-area: hero;
			display: grid;
			gap: 1.1rem;
			min-height: 0;
			padding: clamp(1.15rem, 1.65vw, 1.55rem);
			border-color: rgba(255, 255, 255, 0.28);
			background:
				radial-gradient(circle at 0% 0%, rgba(255, 214, 232, 0.14), transparent 24%),
				radial-gradient(circle at 100% 100%, rgba(204, 255, 255, 0.18), transparent 30%),
				linear-gradient(180deg, rgba(248, 254, 255, 0.34), rgba(230, 250, 255, 0.24));
			backdrop-filter: blur(4px) saturate(185%);
			-webkit-backdrop-filter: blur(18px) saturate(135%);
			box-shadow:
				0 20px 44px rgba(112, 159, 176, 0.15),
				inset 0 1px 0 rgba(255, 255, 255, 0.46);
		}

		.profile-card::before {
			content: '';
			position: absolute;
			inset: 0;
			background:
				linear-gradient(rgba(224, 242, 247, 0.72) 1px, transparent 1px),
				linear-gradient(90deg, rgba(224, 242, 247, 0.72) 1px, transparent 1px);
			background-size: 1.35rem 1.35rem;
			-webkit-mask-image: linear-gradient(135deg, rgba(0, 0, 0, 0.16), transparent 72%);
			mask-image: linear-gradient(135deg, rgba(0, 0, 0, 0.16), transparent 72%);
			opacity: 0.4;
			pointer-events: none;
		}

		.profile-card::after {
			right: -4.25rem;
			bottom: -4.5rem;
			width: 12rem;
			height: 12rem;
			background: radial-gradient(circle, rgba(153, 230, 255, 0.18), transparent 72%);
		}

		.profile-card__main {
			display: grid;
			grid-template-columns: minmax(0, 1fr) minmax(9.5rem, 10.8rem);
			gap: 1rem;
			align-items: start;
			min-width: 0;
		}

		.profile-copy {
			display: grid;
			gap: 0.82rem;
			min-width: 0;
			max-width: 31rem;
			align-content: start;
		}

		.profile-heading {
			display: grid;
			gap: 0.35rem;
		}

		.profile-kicker {
			margin: 0;
			color: var(--color-link-hover);
			font-size: 0.82rem;
			font-weight: 700;
			letter-spacing: 0.16em;
		}

		.profile-name {
			margin: 0;
			color: #14202d;
			font-size: clamp(2.9rem, 5.8vw, 4.35rem);
			font-weight: 800;
			line-height: 0.94;
			letter-spacing: -0.08em;
			white-space: nowrap;
		}

		.profile-role {
			margin: 0.12rem 0 0;
			display: inline-flex;
			align-items: center;
			gap: 0.62rem;
			width: fit-content;
			color: rgba(31, 41, 55, 0.88);
			font-size: 0.88rem;
			font-weight: 800;
			letter-spacing: 0.12em;
		}

		.profile-role::before {
			content: '';
			width: 2.1rem;
			height: 1px;
			border-radius: 999px;
			background: rgba(31, 41, 55, 0.16);
		}

		.profile-intro {
			display: grid;
			gap: 0.2rem;
			max-width: 25rem;
		}

		.profile-intro p {
			margin: 0;
			color: var(--color-text);
			font-size: 0.98rem;
			line-height: 1.68;
			font-weight: 700;
		}

		.profile-tags {
			display: flex;
			flex-wrap: wrap;
			gap: 0.45rem;
			margin-top: 0.15rem;
		}

		.profile-tags span {
			display: inline-flex;
			align-items: center;
			padding: 0.24rem 0.72rem;
			border: 1px solid rgba(153, 230, 255, 0.4);
			border-radius: 999px;
			background: rgba(230, 250, 255, 0.88);
			color: var(--color-link-hover);
			font-size: 0.74rem;
			font-weight: 700;
			letter-spacing: 0.02em;
		}

		.profile-aside {
			display: grid;
			gap: 0.85rem;
			align-content: start;
			justify-items: end;
			min-width: 0;
		}

		.avatar-frame {
			position: relative;
			display: grid;
			place-items: center;
			width: min(100%, 10.8rem);
			aspect-ratio: 5 / 6;
			padding: 0.42rem;
			border: 1px solid rgba(255, 255, 255, 0.4);
			border-radius: 1.6rem;
			background:
				linear-gradient(180deg, rgba(255, 255, 255, 0.58), rgba(246, 252, 254, 0.36)),
				linear-gradient(145deg, rgba(255, 214, 232, 0.12), transparent 50%);
			box-shadow:
				inset 0 1px 0 rgba(255, 255, 255, 0.62),
				0 14px 28px rgba(112, 159, 176, 0.1);
		}

		.avatar-frame::before {
			content: '';
			position: absolute;
			inset: 0.48rem;
			border: 1px solid rgba(153, 230, 255, 0.26);
			border-radius: 1.18rem;
			pointer-events: none;
		}

		.avatar-frame::after {
			content: '';
			position: absolute;
			right: 0.95rem;
			top: 0.95rem;
			width: 0.68rem;
			height: 0.68rem;
			border-radius: 999px;
			background: rgba(255, 214, 232, 0.9);
			box-shadow: 0 0 0 0.22rem rgba(255, 255, 255, 0.88);
			pointer-events: none;
		}

		.avatar-image {
			display: block;
			width: 100%;
			height: 100%;
			border-radius: 1.14rem;
			object-fit: cover;
			object-position: center;
			box-shadow: 0 12px 24px rgba(112, 159, 176, 0.08);
		}

		.profile-note {
			margin: 0;
			max-width: 10.2rem;
			color: rgba(31, 41, 55, 0.82);
			font-size: 0.75rem;
			line-height: 1.6;
			font-weight: 700;
			text-align: right;
			opacity: 0.9;
		}

		.profile-card__footer {
			display: flex;
			flex-wrap: wrap;
			align-items: center;
			justify-content: space-between;
			gap: 0.7rem;
			padding-top: 0.3rem;
			border-top: 0;
		}

		.profile-contacts {
			display: grid;
			gap: 0.28rem;
			justify-items: start;
		}

		.profile-contact {
			display: flex;
			flex-wrap: wrap;
			align-items: center;
			gap: 0.4rem;
			margin: 0;
			color: rgba(31, 41, 55, 0.84);
			font-size: 0.84rem;
			font-weight: 700;
			line-height: 1.55;
		}

		.profile-contact span {
			color: var(--color-subtext);
		}

		.profile-contact__copy {
			padding: 0;
			border: 0;
			background: transparent;
			color: var(--color-link-hover);
			font: inherit;
			text-decoration: none;
			cursor: pointer;
			transition:
				color 180ms ease,
				opacity 180ms ease;
		}

		.profile-contact__copy:hover {
			opacity: 0.82;
			text-decoration: underline;
		}

		.profile-contact__copy.is-copied {
			color: #0f766e;
		}

		.profile-actions {
			display: inline-flex;
			flex-wrap: wrap;
			align-items: center;
			gap: 0.5rem;
		}

		.profile-action {
			display: inline-flex;
			align-items: center;
			justify-content: center;
			width: 2.55rem;
			height: 2.55rem;
			padding: 0;
			border: 1px solid rgba(255, 255, 255, 0.36);
			border-radius: 999px;
			background: rgba(255, 255, 255, 0.48);
			color: var(--color-text);
			text-decoration: none;
			cursor: pointer;
			transition:
				transform 180ms ease,
				box-shadow 180ms ease,
				border-color 180ms ease,
				background-color 180ms ease;
		}

		.profile-action:hover {
			transform: translateY(-1px);
			border-color: rgba(153, 230, 255, 0.72);
			background: rgba(230, 250, 255, 0.94);
			box-shadow: 0 12px 24px rgba(112, 159, 176, 0.1);
		}

		.profile-action-image {
			display: block;
			width: 1.3rem;
			height: 1.3rem;
			margin-inline: auto;
			padding: 0;
			object-fit: contain;
			object-position: center;
			background: transparent;
		}

		.profile-action-image.is-leetcode {
			transform: translateX(-0.12rem);
		}

		.archive-panel {
			grid-area: archive;
			display: flex;
			flex-direction: column;
			min-width: 0;
			height: var(--timeline-card-height);
			padding: 1.6rem;
			overflow: hidden;
			container-type: inline-size;
		}

		.recent-card {
			grid-area: recent;
			display: grid;
			align-content: start;
			min-height: 0;
			border-color: rgba(255, 255, 255, 0.28 );
			background: linear-gradient(180deg, rgba(248, 254, 255, 0.42), rgba(230, 250, 255, 0.22));
			backdrop-filter: blur(4px) saturate(182%);
			-webkit-backdrop-filter: blur(16px) saturate(132%);
			box-shadow:
				0 20px 42px rgba(112, 159, 176, 0.14),
				inset 0 1px 0 rgba(255, 255, 255, 0.44);
		}

		.recent-card::before {
			content: '';
			position: absolute;
			inset: 0;
			background: linear-gradient(135deg, rgba(255, 255, 255, 0.24), transparent 46%);
			pointer-events: none;
		}

		.recent-list {
			display: grid;
			gap: 0.85rem;
		}

		.recent-item {
			display: grid;
			gap: 0.7rem;
			padding: 1rem 1.05rem;
			border: 1px solid rgba(255, 255, 255, 0.28);
			border-radius: 22px;
			background: rgba(255, 255, 255, 0.38);
			color: var(--color-text);
			text-decoration: none;
			transition:
				transform 180ms ease,
				box-shadow 180ms ease,
				border-color 180ms ease,
				background-color 180ms ease;
		}

		.recent-item:hover {
			transform: translateY(-2px);
			border-color: rgba(153, 230, 255, 0.72);
			background: rgba(230, 250, 255, 0.88);
			box-shadow: 0 16px 32px rgba(112, 159, 176, 0.1);
		}

		.recent-item__meta {
			display: flex;
			align-items: center;
			justify-content: space-between;
			gap: 0.8rem;
		}

		.recent-item__meta span {
			color: var(--color-subtext);
			font-size: 0.86rem;
			font-weight: 700;
		}

		.recent-item__meta strong {
			color: var(--color-link-hover);
			font-size: 0.78rem;
			letter-spacing: 0.08em;
			text-transform: uppercase;
		}

		.recent-item__body {
			display: grid;
			gap: 0.35rem;
		}

		.recent-item__body strong {
			font-size: 1.05rem;
			line-height: 1.45;
		}

		.recent-item__body p {
			margin: 0;
			color: var(--color-subtext);
			font-size: 0.92rem;
			line-height: 1.6;
		}

		.stats-card {
			display: grid;
			align-content: start;
			gap: 0.75rem;
			height: 100%;
			min-height: 0;
			padding: 1.25rem 1.25rem 1.15rem;
			border-color: rgba(153, 230, 255, 0.46);
			background:
				radial-gradient(circle at 0% 0%, rgba(255, 214, 232, 0.22), transparent 30%),
				linear-gradient(180deg, rgba(248, 254, 255, 0.9), rgba(230, 250, 255, 0.78));
			backdrop-filter: blur(14px);
		}

		.stats-list {
			display: grid;
			gap: 0.1rem;
			margin: 0;
		}

		.stats-row {
			display: flex;
			align-items: baseline;
			justify-content: space-between;
			gap: 1rem;
			padding: 0.58rem 0;
			border-bottom: 1px solid rgba(224, 242, 247, 0.82);
		}

		.stats-row:last-child {
			padding-bottom: 0.2rem;
			border-bottom: 0;
		}

		.stats-row dt {
			color: var(--color-text);
			font-size: 0.94rem;
			font-weight: 500;
			white-space: nowrap;
		}

		.stats-row dd {
			margin: 0;
			color: var(--color-link-hover);
			font-size: 1.06rem;
			font-weight: 700;
			font-variant-numeric: tabular-nums;
		}

		.archive-entry-card {
			grid-area: archive-entry;
			display: grid;
			grid-template-columns: 1fr;
			gap: 1.1rem;
			align-items: stretch;
			min-height: 0;
			background:
				radial-gradient(circle at 0% 0%, rgba(255, 214, 232, 0.22), transparent 30%),
				radial-gradient(circle at 100% 100%, rgba(204, 255, 255, 0.22), transparent 34%),
				linear-gradient(135deg, rgba(255, 255, 255, 0.95), rgba(230, 250, 255, 0.82));
		}

		.latest-comments-card {
			grid-area: latest-comments;
			display: grid;
			align-content: start;
			gap: 0.9rem;
			min-height: 0;
			background:
				radial-gradient(circle at top right, rgba(255, 214, 232, 0.18), transparent 28%),
				radial-gradient(circle at bottom left, rgba(204, 255, 255, 0.2), transparent 34%),
				linear-gradient(180deg, rgba(255, 255, 255, 0.95), rgba(238, 248, 252, 0.9));
		}

		.latest-comments-card__header {
			display: flex;
			align-items: flex-start;
			justify-content: space-between;
			gap: 1rem;
		}

		.latest-comments-card__header h2 {
			margin-bottom: 0.35rem;
		}

		.latest-comments-copy {
			margin: 0;
			color: var(--color-subtext);
			font-size: 0.92rem;
			line-height: 1.65;
		}

		.latest-comments-card__action {
			flex: 0 0 auto;
		}

		.latest-comments-status,
		.latest-comments-empty {
			padding: 1rem 1.05rem;
			border: 1px solid rgba(153, 230, 255, 0.34);
			border-radius: 22px;
			background: rgba(255, 255, 255, 0.72);
			color: var(--color-subtext);
			font-size: 0.92rem;
			line-height: 1.65;
		}

		.latest-comments-list {
			display: grid;
			gap: 0.78rem;
		}

		.latest-comment-item {
			display: grid;
			gap: 0.72rem;
			padding: 1rem 1.05rem;
			border: 1px solid rgba(153, 230, 255, 0.34);
			border-radius: 22px;
			background: rgba(255, 255, 255, 0.78);
			color: var(--color-text);
			text-decoration: none;
			transition:
				transform 180ms ease,
				box-shadow 180ms ease,
				border-color 180ms ease,
				background-color 180ms ease;
		}

		.latest-comment-item:hover {
			transform: translateY(-2px);
			border-color: rgba(153, 230, 255, 0.72);
			background: rgba(230, 250, 255, 0.9);
			box-shadow: 0 16px 28px rgba(112, 159, 176, 0.1);
		}

		.latest-comment-item__meta {
			display: flex;
			align-items: flex-start;
			justify-content: space-between;
			gap: 0.85rem;
		}

		.latest-comment-item__author {
			display: flex;
			align-items: center;
			gap: 0.72rem;
			min-width: 0;
		}

		.latest-comment-item__avatar {
			display: block;
			width: 2.5rem;
			height: 2.5rem;
			border-radius: 999px;
			object-fit: cover;
			box-shadow: 0 10px 20px rgba(112, 159, 176, 0.12);
		}

		.latest-comment-item__author-copy {
			display: grid;
			gap: 0.12rem;
			min-width: 0;
		}

		.latest-comment-item__author-copy strong {
			font-size: 0.96rem;
			line-height: 1.2;
		}

		.latest-comment-item__author-copy span {
			color: var(--color-subtext);
			font-size: 0.8rem;
			line-height: 1.45;
			overflow: hidden;
			text-overflow: ellipsis;
			white-space: nowrap;
		}

		.latest-comment-item__time {
			color: var(--color-subtext);
			font-size: 0.82rem;
			font-weight: 700;
			white-space: nowrap;
		}

		.latest-comment-item__body {
			display: grid;
			gap: 0.55rem;
		}

		.latest-comment-item__body p {
			margin: 0;
			color: var(--color-text);
			font-size: 0.92rem;
			line-height: 1.7;
		}

		.latest-comment-item__tag {
			display: inline-flex;
			align-items: center;
			width: fit-content;
			padding: 0.28rem 0.62rem;
			border: 1px solid rgba(153, 230, 255, 0.42);
			border-radius: 999px;
			background: rgba(230, 250, 255, 0.84);
			color: var(--color-link-hover);
			font-size: 0.74rem;
			font-weight: 700;
		}

		.archive-entry-card__copy {
			display: grid;
			align-content: start;
			gap: 0.8rem;
		}

		.archive-entry-copy {
			margin: 0;
			max-width: 38rem;
			color: var(--color-subtext);
			font-size: 0.95rem;
			line-height: 1.75;
		}

		.archive-entry-actions {
			display: flex;
			flex-wrap: wrap;
			gap: 0.75rem;
			margin-top: 0.2rem;
		}

		.archive-entry-card__aside {
			display: grid;
			gap: 0.9rem;
			align-content: start;
		}

		.archive-entry-metrics {
			display: grid;
			grid-template-columns: repeat(3, minmax(0, 1fr));
			gap: 0.7rem;
		}

		.archive-entry-metric {
			display: grid;
			gap: 0.24rem;
			padding: 0.95rem 0.9rem;
			border: 1px solid rgba(153, 230, 255, 0.38);
			border-radius: 20px;
			background: rgba(255, 255, 255, 0.76);
		}

		.archive-entry-metric strong {
			font-size: 1.18rem;
			line-height: 1.15;
			color: var(--color-text);
		}

		.archive-entry-metric span {
			color: var(--color-subtext);
			font-size: 0.8rem;
			font-weight: 700;
			letter-spacing: 0.04em;
		}

		.archive-entry-features {
			display: grid;
			gap: 0.75rem;
			padding: 0;
			margin: 0;
			list-style: none;
		}

		.archive-entry-features li {
