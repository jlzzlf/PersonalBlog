---
import { getImage, Image } from 'astro:assets';
import { getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import HomeAvatar from '../assets/home-avatar.jpg';
import HomeMobileHero from '../assets/home-mobile-hero.jpg';
import heroQuotesText from '../data/hero-quotes.txt?raw';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);

const toDayKey = (date: Date) =>
	`${date.getFullYear()}-${String(date.getMonth() + 1).padStart(2, '0')}-${String(
		date.getDate(),
	).padStart(2, '0')}`;

const formatArchiveDate = (date: Date) =>
	new Intl.DateTimeFormat('zh-CN', {
		month: 'short',
		day: 'numeric',
	}).format(date);

const postFeedItems = posts.map((post) => ({
	id: post.id,
	href: `/blog/${post.id}/`,
	title: post.data.title,
	description: post.data.description,
	pubDateISO: post.data.pubDate.toISOString(),
	archiveDateLabel: formatArchiveDate(post.data.pubDate),
	year: String(post.data.pubDate.getFullYear()),
	dayKey: toDayKey(post.data.pubDate),
}));

const archiveGroups = Array.from(
	posts.reduce((groups, post) => {
		const year = String(post.data.pubDate.getFullYear());
		const yearPosts = groups.get(year);
		if (yearPosts) {
			yearPosts.push(post);
		} else {
			groups.set(year, [post]);
		}
		return groups;
	}, new Map<string, typeof posts>()),
).map(([year, items]) => ({ year, items }));

const HOME_HERO_TITLE = '章立夫的个人主页';
const HOME_HERO_SUBTITLE = '欢迎访问';
const STAGE_VIDEO_SRC = 'https://cdn.joylife-zhang.site/miku_3mb.mp4';
const mobileHeroImage = await getImage({
	src: HomeMobileHero,
	width: 960,
	format: 'webp',
	quality: 72,
});
const heroQuotes = heroQuotesText
	.split(/\r?\n/)
	.map((line) => line.trim())
	.filter((line) => line && !line.startsWith('#'));
const profileActionButtons = [
	{
		label: 'Bilibili',
		imageSrc: '/images/bilibili-fill.png',
		alt: 'Bilibili 图标',
		href: 'https://space.bilibili.com/13105791?spm_id_from=333.1007.0.0',
	},
	{
		label: 'GitHub',
		imageSrc: '/images/github.png',
		alt: 'GitHub 图标',
		href: 'https://github.com/jlzzlf',
	},
	{
		label: '力扣',
		imageSrc: '/images/LeetCode.png',
		alt: '力扣图标',
		iconClass: 'is-leetcode',
		href: 'https://leetcode.cn/u/fdrksk6o8H/',
	},
];

const siteLinks = [
	{ label: '项目展示', href: '/projects', note: '集中展示正在做的项目、作品和阶段计划' },
	{ label: '技术博客', href: '/blog', note: '按分类查看学习记录、技术笔记与整理文章' },
	{ label: '个人简介', href: '/profile', note: '整理个人经历、兴趣方向和联系方式' },
];

const noticeItems = ['这里后面可以放最近更新、站点变动或想告诉访客的话。'];

const plannerItems = [
	'这里后面可以继续放标签、归档、天气或待办。',
	'右侧栏会保留成可继续加模块的区域。',
	'目前先把首页的整体结构搭清楚。',
];

const today = new Date();
const currentYear = today.getFullYear();
const currentMonth = today.getMonth();
const firstDayOfMonth = new Date(currentYear, currentMonth, 1);
const daysInMonth = new Date(currentYear, currentMonth + 1, 0).getDate();
const leadingEmptyDays = (firstDayOfMonth.getDay() + 6) % 7;
const weekDays = ['一', '二', '三', '四', '五', '六', '日'];
const calendarCells = [
	...Array.from({ length: leadingEmptyDays }, () => null),
	...Array.from({ length: daysInMonth }, (_, index) => {
		const dayNumber = index + 1;
		return {
			dayNumber,
			dayKey: `${currentYear}-${String(currentMonth + 1).padStart(2, '0')}-${String(
				dayNumber,
			).padStart(2, '0')}`,
			isToday:
				dayNumber === today.getDate() &&
				currentMonth === today.getMonth() &&
				currentYear === today.getFullYear(),
		};
	}),
];

while (calendarCells.length % 7 !== 0) {
	calendarCells.push(null);
}

const monthFormatter = new Intl.DateTimeFormat('zh-CN', {
	year: 'numeric',
	month: 'long',
});

const archiveDateFormatter = new Intl.DateTimeFormat('zh-CN', {
	month: 'short',
	day: 'numeric',
});
---

<!doctype html>
<html lang="zh-CN">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main
			class="home"
			data-parallax-home
			style={`--mobile-hero-image: url('${mobileHeroImage.src}')`}
		>
			<div class="home-video-layer" aria-hidden="true">
				<video
					class="stage-video"
					muted
					loop
					playsinline
					preload="none"
					aria-hidden="true"
					data-video-src={STAGE_VIDEO_SRC}
				></video>
				<div class="stage-overlay" aria-hidden="true"></div>
			</div>
			<div class="home-surface-layer" aria-hidden="true"></div>

			<section class="home-stage">
				<div class="stage-content">
					<h1>{HOME_HERO_TITLE}</h1>
					<p class="stage-subtitle" data-random-hero-subtitle>{HOME_HERO_SUBTITLE}</p>
				</div>
			</section>

			<section class="dashboard-layer">
				<section class="dashboard-grid">
				<aside class="sidebar left-column">
					<article class="surface-card panel profile-card">
						<p class="eyebrow">Profile</p>
						<div class="avatar-frame" aria-label="头像位置">
							<Image
								src={HomeAvatar}
								alt="头像"
								class="avatar-image"
								width={480}
								loading="eager"
								decoding="async"
								quality={72}
							/>
						</div>
						<h2 class="profile-name">章立夫</h2>
						<div class="profile-actions" aria-label="个人主页与联系方式入口">
							{
								profileActionButtons.map((item) => (
									item.href ? (
										<a
											class="profile-action"
											href={item.href}
											target="_blank"
											rel="noreferrer"
											aria-label={item.label}
										>
											<img
												src={item.imageSrc}
												alt={item.alt}
												class:list={['profile-action-image', item.iconClass]}
											/>
											<span>{item.label}</span>
										</a>
									) : (
										<button class="profile-action" type="button" aria-label={item.label}>
											<img
												src={item.imageSrc}
												alt={item.alt}
												class:list={['profile-action-image', item.iconClass]}
											/>
											<span>{item.label}</span>
										</button>
									)
								))
							}
						</div>
					</article>

					<article class="surface-card panel clock-card">
						<div class="links-clock" aria-live="polite">
							<strong class="links-clock-time" data-current-time>--:--:--</strong>
						</div>
					</article>

					<article class="surface-card panel notice-card">
						<p class="eyebrow">Notice</p>
						<h2>公告</h2>
						<ul class="planner-list">
							{
								noticeItems.map((item) => (
									<li>{item}</li>
								))
							}
						</ul>
					</article>

				</aside>

				<section class="center-column">
					<article class="surface-card panel archive-panel">
						<div class="archive-header">
							<div>
								<p class="eyebrow">Archive</p>
								<h2>归档</h2>
								<p class="archive-copy">按时间线查看文章更新，点日历可以只看某一天的归档内容。</p>
							</div>
							<span class="archive-count" data-archive-count>{posts.length} 篇文章</span>
						</div>

						<div class="archive-timeline" data-archive-timeline>
							{
								archiveGroups.map((group) => (
									<section class="archive-group">
										<div class="archive-year">{group.year}</div>
										<div class="archive-items">
											{
												group.items.map((post) => (
													<a class="archive-item" href={`/blog/${post.id}/`}>
														<time datetime={post.data.pubDate.toISOString()} class="archive-date">
															{archiveDateFormatter.format(post.data.pubDate)}
														</time>
														<div class="archive-item-body">
															<strong>{post.data.title}</strong>
														</div>
													</a>
												))
											}
										</div>
									</section>
								))
							}
						</div>
						<script
							type="application/json"
							data-post-feed
							set:html={JSON.stringify(postFeedItems)}
						></script>
						<script
							type="application/json"
							data-hero-quotes
							set:html={JSON.stringify(heroQuotes)}
						></script>
					</article>
				</section>

				<aside class="sidebar right-column">
					<article class="surface-card panel links-card">
						<p class="eyebrow">Pages</p>
						<h2>网页链接</h2>
						<div class="link-list">
							{
								siteLinks.map((link) => (
									<a class="link-item" href={link.href}>
										<div>
											<strong>{link.label}</strong>
											<p>{link.note}</p>
										</div>
										<span>进入</span>
									</a>
								))
							}
						</div>
					</article>

					<article class="surface-card panel calendar-card">
						<p class="eyebrow">Calendar</p>
						<div class="calendar-header">
							<h2>日历</h2>
							<span>{monthFormatter.format(today)}</span>
						</div>
						<div class="calendar-weekdays">
							{
								weekDays.map((day) => (
									<span>{day}</span>
								))
							}
						</div>
						<div class="calendar-grid">
							{
								calendarCells.map((cell) =>
									cell ? (
										<button
											type="button"
											class:list={['calendar-day', { today: cell.isToday }]}
											data-calendar-day
											data-day-key={cell.dayKey}
											aria-pressed="false"
										>
											{cell.dayNumber}
										</button>
									) : (
										<div class="calendar-day empty"></div>
									),
								)
							}
						</div>
					</article>

					<article class="surface-card panel planner-card">
						<p class="eyebrow">More Modules</p>
						<h2>右侧扩展区</h2>
						<ul class="planner-list">
							{
								plannerItems.map((item) => (
									<li>{item}</li>
								))
							}
						</ul>
					</article>
				</aside>
				</section>
			</section>

		</main>
		<Footer />
	</body>
</html>

<style>
	:global(body) {
		background: var(--page);
	}

	.home {
		--hero-height: clamp(22rem, 33vw, 27rem);
		--hero-overlap: clamp(4.5rem, 12vw, 8.5rem);
		--surface-overlap: clamp(0rem, 1.4vw, 1rem);
		--surface-shift: 0px;
		display: grid;
		gap: 0;
		padding-top: 0;
		margin-top: -6.75rem;
		position: relative;
		isolation: isolate;
	}

	.home-video-layer,
	.home-surface-layer {
		position: fixed;
		left: 50%;
		width: 100vw;
		pointer-events: none;
		transform: translateX(-50%);
	}

	.home-video-layer {
		top: 0;
		height: var(--hero-height);
		overflow: hidden;
		z-index: 0;
		background:
			radial-gradient(circle at 18% 22%, rgba(255, 240, 214, 0.24), transparent 22%),
			radial-gradient(circle at 82% 20%, rgba(118, 164, 136, 0.22), transparent 26%),
			linear-gradient(180deg, #5d6f68 0%, #38463f 56%, #212723 100%);
	}

	.home-surface-layer {
		top: calc(var(--hero-height) - var(--surface-overlap));
		height: calc(100vh + 100svh);
		z-index: 2;
		transform: translate3d(-50%, var(--surface-shift), 0);
		will-change: transform;
		background:
			linear-gradient(
				180deg,
				#faf6ef 0%,
				#f6efe5 18%,
				#f1e7d9 42%,
				var(--page) 100%
			);
	}

	.home-stage {
		position: relative;
		width: 100vw;
		height: var(--hero-height);
		margin-left: calc(50% - 50vw);
		margin-right: calc(50% - 50vw);
		margin-bottom: 0;
		padding: 0;
		pointer-events: none;
		z-index: 1;
	}

	.stage-video,
	.stage-overlay {
		position: absolute;
		inset: 0;
	}

	.stage-video {
		width: 100%;
		height: 100%;
		object-fit: cover;
		object-position: center 38%;
		z-index: 0;
		opacity: 0;
		transition: opacity 260ms ease;
	}

	.stage-video.is-ready {
		opacity: 1;
	}

	.stage-overlay {
		z-index: 1;
		background:
			linear-gradient(180deg, rgba(17, 21, 18, 0.28) 0%, rgba(17, 21, 18, 0.4) 100%),
			radial-gradient(circle at center, rgba(255, 255, 255, 0.05), transparent 60%);
	}

	.stage-content {
		position: absolute;
		top: clamp(6.8rem, 12vw, 9.4rem);
		left: 50%;
		z-index: 1;
		width: fit-content;
		max-width: calc(100vw - 2rem);
		display: grid;
		gap: 0.8rem;
		place-items: center;
		text-align: center;
		transform: translateX(-50%);
	}

	.stage-content h1 {
		display: block;
		margin-bottom: 0;
		margin-inline: auto;
		color: #fffaf0;
		font-size: clamp(2.2rem, 5.4vw, 4.5rem);
		max-width: calc(100vw - 2rem);
		line-height: 1.08;
		white-space: nowrap;
		text-shadow: 0 10px 30px rgba(0, 0, 0, 0.32);
	}

	.stage-subtitle {
		margin: 0;
		margin-inline: auto;
		max-width: calc(100vw - 3rem);
		color: #fffaf0;
		font-size: clamp(1rem, 2.2vw, 1.45rem);
		font-weight: 500;
		line-height: 1.25;
		white-space: nowrap;
		text-shadow: 0 8px 24px rgba(0, 0, 0, 0.28);
	}

	.dashboard-layer {
		position: relative;
		z-index: 4;
		margin-top: calc(var(--hero-overlap) * -1);
	}

	.dashboard-grid {
		display: grid;
		grid-template-columns: minmax(230px, 290px) minmax(0, 1fr) minmax(230px, 290px);
		grid-template-areas: 'left center right';
		gap: 1.4rem;
		align-items: start;
		position: relative;
		width: min(1360px, calc(100% - 2rem));
		margin: 0 auto;
	}

	.left-column {
		grid-area: left;
		min-width: 0;
	}

	.center-column {
		grid-area: center;
		display: grid;
		gap: 1rem;
		align-content: start;
		min-width: 0;
	}

	.right-column {
		grid-area: right;
		min-width: 0;
	}

	.sidebar {
		display: grid;
		gap: 1rem;
	}

	.panel {
		padding: 1.4rem;
	}

	.panel h2 {
		margin-bottom: 0.8rem;
		font-size: 1.6rem;
	}

	.profile-card {
		gap: 1rem;
		text-align: center;
	}

	.clock-card {
		display: grid;
		place-items: center;
		padding: 1.15rem 1rem;
	}

	.profile-card .eyebrow {
		width: 100%;
		text-align: left;
	}

	.avatar-frame {
		display: grid;
		place-items: center;
		width: min(100%, clamp(9.5rem, 18vw, 13.5rem));
		aspect-ratio: 4 / 5;
		justify-self: center;
		margin: 0.15rem auto 0.55rem;
		border-radius: clamp(20px, 2.4vw, 28px);
		border: 1px solid rgba(56, 61, 56, 0.12);
		background:
			linear-gradient(180deg, rgba(255, 255, 255, 0.74) 0%, rgba(246, 239, 228, 0.92) 100%);
		box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.5);
		overflow: hidden;
	}

	.avatar-image {
		width: 100%;
		height: 100%;
		object-fit: cover;
		object-position: center;
		display: block;
	}

	.profile-name {
		margin: 0;
		font-size: clamp(1.45rem, 2.3vw, 1.9rem);
		letter-spacing: 0.04em;
	}

	.profile-actions {
		display: grid;
		grid-template-columns: repeat(3, minmax(0, 1fr));
		gap: 0.65rem;
		width: 100%;
	}

	.profile-action {
		display: grid;
		gap: 0.5rem;
		justify-items: center;
		padding: 0.75rem 0.5rem 0.7rem;
		border: 1px solid rgba(56, 61, 56, 0.08);
		border-radius: 20px;
		background: rgba(255, 255, 255, 0.5);
		color: rgb(var(--black));
		text-decoration: none;
		cursor: pointer;
		transition:
			transform 180ms ease,
			box-shadow 180ms ease,
			border-color 180ms ease;
	}

	.profile-action:hover {
		transform: translateY(-2px);
		border-color: rgba(22, 98, 74, 0.2);
		box-shadow: 0 16px 32px rgba(70, 67, 58, 0.08);
	}

	.profile-action-image {
		width: min(100%, 3rem);
		height: min(3rem, 100%);
		padding: 0.35rem;
		border-radius: 14px;
		margin-inline: auto;
		background: transparent;
		object-position: center;
		object-fit: contain;
		display: block;
	}

	.profile-action-image.is-leetcode {
		transform: translateX(-0.12rem);
	}

	.profile-action span {
		font-size: 0.76rem;
		font-weight: 700;
		letter-spacing: 0.06em;
		text-transform: uppercase;
	}

	.planner-list {
		display: grid;
		gap: 0.9rem;
		padding: 0;
		margin: 0;
		list-style: none;
	}

	.planner-list li {
		padding: 0.95rem 1rem;
		border-radius: 20px;
		background: rgba(255, 255, 255, 0.66);
		border: 1px solid rgba(56, 61, 56, 0.08);
	}

	.link-list {
		display: grid;
		gap: 0.85rem;
	}

	.links-clock {
		display: grid;
		width: 100%;
		min-height: 6.8rem;
		padding: 0;
		align-content: center;
		justify-items: center;
		place-items: center;
	}

	.links-clock-time {
		font-size: clamp(2.1rem, 4.2vw, 3.4rem);
		line-height: 1;
		color: rgb(var(--black));
		font-variant-numeric: tabular-nums;
		letter-spacing: 0.04em;
	}

	.link-item {
		display: grid;
		grid-template-columns: minmax(0, 1fr) auto;
		gap: 0.75rem;
		align-items: center;
		padding: 1rem 1.05rem;
		border-radius: 22px;
		background: rgba(255, 255, 255, 0.66);
		border: 1px solid rgba(56, 61, 56, 0.08);
		color: rgb(var(--black));
		text-decoration: none;
		transition:
			transform 180ms ease,
			box-shadow 180ms ease,
			border-color 180ms ease;
	}

	.link-item:hover {
		transform: translateY(-2px);
		border-color: rgba(22, 98, 74, 0.2);
		box-shadow: 0 16px 32px rgba(70, 67, 58, 0.08);
	}

	.link-item strong {
		display: block;
		margin-bottom: 0.3rem;
	}

	.link-item p {
		margin: 0;
		color: rgb(var(--gray));
		font-size: 0.95rem;
	}

	.link-item span {
		color: var(--accent-dark);
		font-weight: 700;
	}

	.archive-panel {
		padding: 1.5rem;
		min-width: 0;
		container-type: inline-size;
	}

	.archive-header {
		display: flex;
		align-items: end;
		justify-content: space-between;
		gap: 1rem;
		margin-bottom: 1.1rem;
	}

	.archive-copy {
		margin: 0.45rem 0 0;
		color: rgb(var(--gray));
		font-size: 0.92rem;
	}

	.archive-count {
		padding: 0.45rem 0.8rem;
		border-radius: 999px;
		background: rgba(22, 98, 74, 0.08);
		color: var(--accent-dark);
		font-size: 0.9rem;
		font-weight: 700;
		white-space: nowrap;
	}

	.archive-timeline {
		display: grid;
		gap: 1.35rem;
	}

	:global(.archive-group) {
		display: grid;
		grid-template-columns: auto minmax(0, 1fr);
		gap: 1rem;
		align-items: start;
	}

	:global(.archive-year) {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		min-width: 4.6rem;
		padding: 0.55rem 0.8rem;
		border-radius: 999px;
		background: rgba(255, 255, 255, 0.72);
		border: 1px solid rgba(56, 61, 56, 0.08);
		color: var(--accent-dark);
		font-size: 0.95rem;
		font-weight: 700;
		letter-spacing: 0.06em;
	}

	:global(.archive-items) {
		position: relative;
		display: grid;
		gap: 0.9rem;
		padding-left: 1.25rem;
	}

	:global(.archive-items)::before {
		content: '';
		position: absolute;
		left: 0.3rem;
		top: 0.55rem;
		bottom: 0.55rem;
		width: 2px;
