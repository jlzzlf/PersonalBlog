</style>

<script is:inline>
	(() => {
		const home = document.querySelector('[data-parallax-home]');
		if (!(home instanceof HTMLElement)) return;

		const heroSubtitle = home.querySelector('[data-random-hero-subtitle]');
		const currentTime = home.querySelector('[data-current-time]');
		const postFeedData = home.querySelector('[data-post-feed]');
		const uploadsContent = home.querySelector('[data-uploads-content]');
		const uploadsCount = home.querySelector('[data-uploads-count]');
		const uploadsFilterNote = home.querySelector('[data-uploads-filter-note]');
		const calendarDayButtons = Array.from(home.querySelectorAll('[data-calendar-day]'));
		const musicAudio = home.querySelector('[data-music-audio]');
		const musicCurrent = home.querySelector('[data-music-current]');
		const musicTrackButtons = Array.from(home.querySelectorAll('[data-music-track]'));
		const videoLayer = home.querySelector('.home-video-layer');
		const surfaceLayer = home.querySelector('.home-surface-layer');
		const stage = home.querySelector('.home-stage');
		const dashboardLayer = home.querySelector('.dashboard-layer');

		if (
			!(videoLayer instanceof HTMLElement) ||
			!(surfaceLayer instanceof HTMLElement) ||
			!(stage instanceof HTMLElement) ||
			!(dashboardLayer instanceof HTMLElement)
		) {
			return;
		}

		const clamp = (min, value, max) => Math.min(Math.max(value, min), max);
		const readRem = () =>
			parseFloat(getComputedStyle(document.documentElement).fontSize || '16') || 16;

		let postFeedItems = [];
		try {
			postFeedItems = postFeedData ? JSON.parse(postFeedData.textContent || '[]') : [];
		} catch (_error) {
			postFeedItems = [];
		}

		const reducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)');
		let selectedDayKey = '';
		let hasCalendarInteracted = false;
		let activeMusicTrackIndex = Math.max(
			musicTrackButtons.findIndex((button) => button.classList.contains('active')),
			0,
		);
		let layoutFrame = 0;
		let subtitleFrame = 0;
		let surfaceFrame = 0;

		const getLayoutValues = () => {
			const rem = readRem();
			const width = window.innerWidth;
			const heroHeight = width <= 720 ? 17 * rem : clamp(2.5 * rem, width * 0.83, 39 * rem);

			let heroOverlap;
			if (width <= 860) {
				heroOverlap = clamp(1.75 * rem, heroHeight * 0.1, 3 * rem);
			} else if (width <= 1040) {
				heroOverlap = clamp(3 * rem, heroHeight * 0.12, 5 * rem);
			} else {
				heroOverlap = clamp(1.5 * rem, heroHeight * 0.33, 15 * rem);
			}

			return {
				heroHeight,
				heroOverlap,
				surfaceOverlap: clamp(0, width * 0.014, 1 * rem),
				transitionHeight: clamp(9 * rem, heroHeight * 0.28, 17 * rem),
			};
		};

		const applyLayout = (scrollY) => {
			const { heroHeight, heroOverlap, surfaceOverlap, transitionHeight } = getLayoutValues();
			const scrollBlend = clamp(0, scrollY / Math.max(heroHeight * 0.72, 1), 1);
			const featherOffset = transitionHeight * (0.58 + scrollBlend * 0.08);
			const featherBlur = 34 + scrollBlend * 16;
			const surfaceShift = reducedMotion.matches ? 0 : scrollY * -0.18;

			videoLayer.style.height = `${heroHeight}px`;
			stage.style.height = `${heroHeight}px`;
			surfaceLayer.style.top = `${heroHeight - surfaceOverlap}px`;
			dashboardLayer.style.marginTop = `${heroOverlap * -1}px`;
			surfaceLayer.style.setProperty('--surface-feather-height', `${transitionHeight}px`);
			surfaceLayer.style.setProperty('--surface-feather-offset', `${featherOffset}px`);
			surfaceLayer.style.setProperty('--surface-feather-blur', `${featherBlur}px`);
			surfaceLayer.style.transform = `translate3d(-50%, ${surfaceShift}px, 0)`;
		};

		const fitHeroSubtitle = () => {
			if (!(heroSubtitle instanceof HTMLElement)) return;

			heroSubtitle.style.fontSize = '';
			heroSubtitle.style.letterSpacing = '';

			const rem = readRem();
			const maxWidth = Math.max(
				Math.min(stage.clientWidth || window.innerWidth, window.innerWidth) - 32,
				0,
			);

			if (!maxWidth) return;

			const minSize = window.innerWidth <= 720 ? 1.05 * rem : 1.45 * rem;
			let fontSize = parseFloat(getComputedStyle(heroSubtitle).fontSize || '0');

			while (heroSubtitle.scrollWidth > maxWidth && fontSize > minSize) {
				fontSize -= 1;
				heroSubtitle.style.fontSize = `${fontSize}px`;
			}

			if (heroSubtitle.scrollWidth > maxWidth) {
				heroSubtitle.style.letterSpacing = '-0.04em';
			}
		};

		const requestSubtitleFit = () => {
			if (subtitleFrame) return;
			subtitleFrame = window.requestAnimationFrame(() => {
				subtitleFrame = 0;
				fitHeroSubtitle();
			});
		};

		const formatSelectedDate = (dayKey) => {
			const [year, month, day] = dayKey.split('-').map(Number);
			return new Intl.DateTimeFormat('zh-CN', {
				year: 'numeric',
				month: 'long',
				day: 'numeric',
			}).format(new Date(year, month - 1, day));
		};

		const createUploadItem = (item, index) => {
			const link = document.createElement('a');
			link.className = 'upload-item';
			link.href = item.href;

			const order = document.createElement('span');
			order.className = 'upload-order';
			order.textContent = String(index + 1).padStart(2, '0');

			const body = document.createElement('div');
			body.className = 'upload-body';

			const meta = document.createElement('div');
			meta.className = 'upload-meta';

			const tag = document.createElement('span');
			tag.className = 'upload-tag';
			tag.textContent = '博客更新';

			const time = document.createElement('time');
			time.dateTime = item.pubDateISO;
			time.textContent = item.pubDateLabel;

			const title = document.createElement('h3');
			title.textContent = item.title;

			const description = document.createElement('p');
			description.textContent = item.description;

			const action = document.createElement('span');
			action.className = 'upload-action';
			action.textContent = '查看';

			meta.append(tag, time);
			body.append(meta, title, description);
			link.append(order, body, action);
			return link;
		};

		const renderUploadItems = () => {
			if (
				!(uploadsContent instanceof HTMLElement) ||
				!(uploadsCount instanceof HTMLElement) ||
				!(uploadsFilterNote instanceof HTMLElement)
			) {
				return;
			}

			const filteredItems = selectedDayKey
				? postFeedItems.filter((item) => item.dayKey === selectedDayKey)
				: postFeedItems.slice(0, 6);

			uploadsContent.textContent = '';
			uploadsCount.textContent = `${filteredItems.length} 条内容`;

			if (selectedDayKey) {
				const selectedDate = formatSelectedDate(selectedDayKey);
				uploadsFilterNote.textContent =
					filteredItems.length > 0
						? `已筛选 ${selectedDate} 的上传内容，再点一次同一天可恢复默认列表。`
						: `${selectedDate} 还没有上传内容，再点一次同一天可恢复默认列表。`;
			} else {
				uploadsFilterNote.textContent = '点击右侧日历按日期筛选，再点一次同一天可恢复默认列表。';
			}

			if (!filteredItems.length) {
				const emptyState = document.createElement('div');
				emptyState.className = 'empty-upload';

				const title = document.createElement('h3');
				title.textContent = '这一天还没有找到上传内容。';

				const copy = document.createElement('p');
				copy.textContent = '你可以换一天试试看，或者再次点击当前日期恢复默认的最新上传列表。';

				emptyState.append(title, copy);
				uploadsContent.append(emptyState);
				return;
			}

			const list = document.createElement('div');
			list.className = 'upload-list';
			filteredItems.forEach((item, index) => {
				list.append(createUploadItem(item, index));
			});

			uploadsContent.append(list);
		};

		const syncCalendarSelection = () => {
			calendarDayButtons.forEach((button) => {
				if (!(button instanceof HTMLElement)) return;
				const isSelected = button.dataset.dayKey === selectedDayKey;
				button.classList.toggle('selected', isSelected);
				button.setAttribute('aria-pressed', String(isSelected));
				if (hasCalendarInteracted) {
					button.classList.remove('today');
				}
			});
		};

		const handleCalendarSelection = (event) => {
			const button = event.currentTarget;
			if (!(button instanceof HTMLElement)) return;

			const dayKey = button.dataset.dayKey || '';
			hasCalendarInteracted = true;
			selectedDayKey = selectedDayKey === dayKey ? '' : dayKey;
			syncCalendarSelection();
			renderUploadItems();
		};

		const updateClock = () => {
			if (!(currentTime instanceof HTMLElement)) return;
			currentTime.textContent = new Intl.DateTimeFormat('zh-CN', {
				hour: '2-digit',
				minute: '2-digit',
				second: '2-digit',
				hour12: false,
			}).format(new Date());
		};

		const setActiveMusicTrack = (index, { autoplay = false } = {}) => {
			if (
				!(musicAudio instanceof HTMLAudioElement) ||
				!(musicCurrent instanceof HTMLElement) ||
				!musicTrackButtons.length ||
				index < 0
			) {
				return;
			}

			const nextButton = musicTrackButtons[index];
			if (!(nextButton instanceof HTMLElement)) return;

			const nextSrc = nextButton.dataset.trackSrc || '';
			const nextLabel = nextButton.dataset.trackLabel || '';
			if (!nextSrc) return;

			musicTrackButtons.forEach((button, buttonIndex) => {
				if (!(button instanceof HTMLElement)) return;
				const isActive = buttonIndex === index;
				button.classList.toggle('active', isActive);
				button.setAttribute('aria-pressed', String(isActive));
			});

			if (musicAudio.getAttribute('src') !== nextSrc) {
				musicAudio.src = nextSrc;
				musicAudio.load();
			}

			activeMusicTrackIndex = index;
			musicCurrent.textContent = nextLabel;

			if (autoplay) {
				musicAudio.play().catch(() => {
					// Ignore autoplay interruptions triggered by the browser.
				});
			}
		};

		const applyRandomHeroSubtitle = async () => {
			if (!(heroSubtitle instanceof HTMLElement)) return;

			try {
				const response = await fetch('/data/hero-quotes.txt', { cache: 'no-store' });
				if (!response.ok) return;

				const quotes = (await response.text())
					.split(/\r?\n/)
					.map((line) => line.trim())
					.filter((line) => line && !line.startsWith('#'));

				if (!quotes.length) return;

				heroSubtitle.textContent = quotes[Math.floor(Math.random() * quotes.length)];
				requestSubtitleFit();
			} catch (_error) {
				// Keep the fallback subtitle when the quotes file cannot be read.
			}
		};

		const applySurfaceMotion = (time) => {
			if (reducedMotion.matches) {
				surfaceLayer.style.setProperty('--surface-ripple-x', '0px');
				surfaceLayer.style.setProperty('--surface-ripple-y', '0px');
				surfaceLayer.style.setProperty('--surface-ripple-scale', '1');
				surfaceLayer.style.setProperty('--surface-ripple-opacity', '0.92');
				surfaceLayer.style.setProperty('--surface-haze-x', '0px');
				surfaceLayer.style.setProperty('--surface-haze-y', '0px');
				surfaceLayer.style.setProperty('--surface-haze-scale', '1');
				surfaceLayer.style.setProperty('--surface-haze-opacity', '0.68');
				return;
			}

			const rippleX = Math.sin(time * 0.00018 + 0.6) * 22;
			const rippleY = Math.sin(time * 0.00054 + 1.1) * 14 + Math.sin(time * 0.00092 + 2.6) * 5;
			const rippleScale = 1 + Math.sin(time * 0.00041 + 0.2) * 0.12;
			const rippleOpacity = 0.88 + Math.sin(time * 0.00033 + 0.7) * 0.08;
			const hazeX = Math.sin(time * 0.00014 + 2.1) * 16;
			const hazeY = Math.sin(time * 0.00047 + 0.4) * 10;
			const hazeScale = 1 + Math.sin(time * 0.00028 + 1.8) * 0.08;
			const hazeOpacity = 0.62 + Math.sin(time * 0.00025 + 2.2) * 0.08;

			surfaceLayer.style.setProperty('--surface-ripple-x', `${rippleX}px`);
			surfaceLayer.style.setProperty('--surface-ripple-y', `${rippleY}px`);
			surfaceLayer.style.setProperty('--surface-ripple-scale', `${rippleScale}`);
			surfaceLayer.style.setProperty('--surface-ripple-opacity', `${clamp(0, rippleOpacity, 1)}`);
			surfaceLayer.style.setProperty('--surface-haze-x', `${hazeX}px`);
			surfaceLayer.style.setProperty('--surface-haze-y', `${hazeY}px`);
			surfaceLayer.style.setProperty('--surface-haze-scale', `${hazeScale}`);
			surfaceLayer.style.setProperty('--surface-haze-opacity', `${clamp(0, hazeOpacity, 1)}`);
		};

		const requestLayoutUpdate = () => {
			if (layoutFrame) return;
			layoutFrame = window.requestAnimationFrame(() => {
				layoutFrame = 0;
				applyLayout(Math.max(window.scrollY || 0, 0));
			});
		};

		const tickSurfaceMotion = (time) => {
			applySurfaceMotion(time);
			surfaceFrame = window.requestAnimationFrame(tickSurfaceMotion);
		};

		applyRandomHeroSubtitle();
		requestSubtitleFit();
		updateClock();
		window.setInterval(updateClock, 1000);
		syncCalendarSelection();
		renderUploadItems();
		requestLayoutUpdate();
		surfaceFrame = window.requestAnimationFrame(tickSurfaceMotion);

		if (musicTrackButtons.length && musicAudio instanceof HTMLAudioElement) {
			setActiveMusicTrack(activeMusicTrackIndex);
			musicTrackButtons.forEach((button, index) => {
				button.addEventListener('click', () => {
					setActiveMusicTrack(index, { autoplay: true });
				});
			});
			musicAudio.addEventListener('ended', () => {
				const nextIndex = (activeMusicTrackIndex + 1) % musicTrackButtons.length;
				setActiveMusicTrack(nextIndex, { autoplay: true });
			});
		}

		calendarDayButtons.forEach((button) => {
			button.addEventListener('click', handleCalendarSelection);
		});

		window.addEventListener('scroll', requestLayoutUpdate, { passive: true });
		window.addEventListener('resize', requestLayoutUpdate);
		window.addEventListener('resize', requestSubtitleFit);
		window.addEventListener('load', requestSubtitleFit, { once: true });

		if (typeof reducedMotion.addEventListener === 'function') {
			reducedMotion.addEventListener('change', () => {
				requestLayoutUpdate();
				if (surfaceFrame) {
					window.cancelAnimationFrame(surfaceFrame);
				}
				surfaceFrame = window.requestAnimationFrame(tickSurfaceMotion);
			});
		}
	})();
</script>


